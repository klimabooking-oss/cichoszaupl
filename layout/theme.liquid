<!DOCTYPE html>
<html lang="{{ request.locale.iso_code }}" style="background-color:#221022; color:#ededed">
<head>
  <!-- Deferred Marketing Scripts (GTM, Meta, GAds) to improve Mobile LCP/TBT -->
  <script>
    window.marketingScriptsLoaded = false;
    function loadMarketingScripts() {
      if (window.marketingScriptsLoaded) return;
      window.marketingScriptsLoaded = true;
      
      // 1. Google Tag Manager
      (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
      new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
      j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
      'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
      })(window,document,'script','dataLayer','GTM-59TNWQ5Z');

      // 2. Google Ads / Analytics (gtag.js)
      var gtagScript = document.createElement('script');
      gtagScript.async = true;
      gtagScript.src = "https://www.googletagmanager.com/gtag/js?id=AW-16732141783";
      document.head.appendChild(gtagScript);
      
      window.dataLayer = window.dataLayer || [];
      window.gtag = function(){window.dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'AW-16732141783', {'allow_enhanced_conversions': true});
      gtag('config', 'G-PMNKPRT86T');

      // 3. PageView Segmentation for Google Ads
      let pageSegment = 'General';
      const path = window.location.pathname;
      if (path === '/' || path === '') {
          pageSegment = 'Strona Główna';
      } else if (path.includes('firmowe') || path.includes('b2b') || path.includes('konferencje') || path.includes('festiwal') || path.includes('teatr')) {
          pageSegment = 'B2B';
      } else if (path.includes('wynajem') || path.includes('cennik')) {
          pageSegment = 'Wynajem';
      }
      
      gtag('event', 'page_view', { page_category: pageSegment, send_to: ['AW-16732141783', 'G-PMNKPRT86T'] });

      // Clean up event listeners
      ['scroll','mousemove','touchstart'].forEach(function(e){ window.removeEventListener(e, loadMarketingScripts, {passive:true}); });
    }

    // Trigger on first interaction or max timeout
    ['scroll','mousemove','touchstart'].forEach(function(e){ window.addEventListener(e, loadMarketingScripts, {passive:true}); });
    setTimeout(loadMarketingScripts, 3500);
  </script>
  <!-- End Deferred Marketing Scripts -->
