<body style="background-color:#221022" class="antialiased overflow-x-hidden">
  <!-- ANTI-FOUC SCRIPT / CURTAIN -->
  <div id="flicker-preloader" style="position:fixed;top:0;left:0;width:100%;height:100%;background-color:#221022;z-index:2147483647;pointer-events:none;transition:opacity 0.4s ease-out;"></div>
  <script>
    window.addEventListener("load", function() {
      setTimeout(function() {
        var preloader = document.getElementById("flicker-preloader");
        if(preloader) {
          preloader.style.opacity = '0';
          setTimeout(function(){ preloader.parentNode.removeChild(preloader); }, 400);
        }
      }, 50); // Minimal time for paint to finish
    });
  </script>
