<!DOCTYPE html>
<html class="dark scroll-smooth" lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="theme-color" content="">
    <link rel="canonical" href="{{ canonical_url }}">
    
    <title>
      {{ page_title }}
      {%- if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif -%}
      {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif -%}
      {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
    </title>

    {% if page_description %}
      <meta name="description" content="{{ page_description | escape }}">
    {% endif %}

    {{ content_for_header }}

    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@300;400;500;600;700;800&display=swap" rel="stylesheet"/>
    <style>
        body { font-family: 'Manrope', sans-serif; }
        .text-stroke {
            -webkit-text-stroke: 1px rgba(255, 255, 255, 0.3);
            color: transparent;
        }
        .text-shadow-glow { text-shadow: 0 0 20px rgba(242, 13, 242, 0.5); }
        .btn-glow {
            box-shadow: 0 0 20px rgba(242, 13, 242, 0.4);
            animation: pulse-glow 2s infinite;
        }
        @keyframes pulse-glow {
            0% { box-shadow: 0 0 20px rgba(242, 13, 242, 0.4); }
            50% { box-shadow: 0 0 40px rgba(242, 13, 242, 0.7); }
            100% { box-shadow: 0 0 20px rgba(242, 13, 242, 0.4); }
        }
        .gradient-text-festival {
            background: linear-gradient(to right, #f20df2, #FF5F1F, #FFD700);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }
        ::-webkit-scrollbar { width: 10px; }
        ::-webkit-scrollbar-track { background: #0a050a; }
        ::-webkit-scrollbar-thumb { background: #f20df2; border-radius: 5px; }
    </style>
    
    {{ 'base.css' | asset_url | stylesheet_tag }}
    <script src="{{ 'global.js' | asset_url }}" defer="defer"></script>
    
  {%- render 'foxify-head' -%}</head>

  <body class="bg-background-light dark:bg-background-dark text-gray-800 dark:text-gray-100 font-display antialiased selection:bg-primary selection:text-white overflow-x-hidden"> {% sections 'foxify-header-group' %} 
    <div class="min-h-screen bg-background-dark text-white selection:bg-primary selection:text-white overflow-hidden">
        
        

        <main id="MainContent" class="content-for-layout focus-none" role="main" tabindex="-1">
            <div class="foxify-container">{{ content_for_layout }}</div>
        </main>

        
        {% section 'map' %}

        <!-- Interactive drawers mapped to global.js logic -->
        {% render 'cart-drawer' %}
        {% render 'auth-modal' %}
    </div>
  {%- render 'foxify-footer' -%} {% sections 'foxify-footer-group' %} </body>
</html>
