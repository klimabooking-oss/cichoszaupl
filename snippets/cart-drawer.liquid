<!-- Backdrop -->
<div 
  id="cart-drawer-backdrop"
  class="fixed inset-0 bg-black/60 backdrop-blur-sm z-[60] transition-opacity duration-300 opacity-0 pointer-events-none"
  data-cart-close
></div>

<!-- Drawer -->
<div 
  id="cart-drawer"
  class="fixed top-0 right-0 h-full w-full max-w-md bg-surface-darker border-l border-white/10 shadow-2xl z-[70] transform transition-transform duration-300 flex flex-col translate-x-full"
>
  
  <!-- Header -->
  <div class="p-6 border-b border-[#f20df2]/40 shadow-[0_0_15px_rgba(242,13,242,0.1)] flex justify-between items-center bg-surface-dark">
    <h2 class="text-xl font-black text-white uppercase italic">Twój Koszyk</h2>
    <button data-cart-close class="text-gray-400 hover:text-white transition">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
    </button>
  </div>

  <!-- Items Container (Populated by JS) -->
  <div id="cart-drawer-items" class="flex-grow overflow-y-auto p-6 space-y-6 custom-scrollbar">
    <!-- Empty State Template -->
    <div id="cart-drawer-empty" class="h-full flex flex-col items-center justify-center text-center opacity-50">
        <div class="w-16 h-16 bg-white/5 rounded-full flex items-center justify-center mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
        </div>
        <p class="text-lg font-bold">Koszyk jest pusty</p>
        <p class="text-sm">Dodaj coś ekstra na swoją imprezę!</p>
    </div>
  </div>

  <!-- Footer -->
  <div id="cart-drawer-footer" class="hidden p-6 bg-surface-dark border-t border-[#f20df2]/40 shadow-[0_0_15px_rgba(242,13,242,0.1)]">
      <div class="flex justify-between items-center mb-6">
          <span class="text-gray-400 font-bold uppercase text-sm">Suma</span>
          <span id="cart-drawer-total" class="text-2xl font-black text-white">0.00 zł</span>
      </div>
      <a 
          href="/checkout"
          class="w-full py-4 rounded-xl bg-gradient-to-r from-primary to-purple-600 text-white font-black uppercase tracking-wider shadow-[0_0_20px_rgba(242,13,242,0.4)] hover:shadow-[0_0_40px_rgba(242,13,242,0.6)] transition-all flex items-center justify-center gap-2 group"
      >
          Do kasy <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:translate-x-1 transition-transform"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
      </a>
  </div>
</div>
