<div class="min-h-screen flex items-center justify-center p-4 pt-32" style="background-color:#221022">

    {% comment %} Success screen after registration {% endcomment %}
    {%- form 'create_customer' -%}
        {%- if form.posted_successfully? -%}
            <div class="max-w-md w-full text-center border border-[#f20df2]/30 p-10 rounded-3xl shadow-[0_0_60px_rgba(242,13,242,0.15)]" style="background-color:#221022">
                <div class="w-20 h-20 rounded-full bg-[#f20df2]/20 flex items-center justify-center mx-auto mb-6">
                    <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#f20df2" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 7.07 19.79 19.79 0 0 1 1.61 .45 2 2 0 0 1 3.6 0h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 7.91a16 16 0 0 0 6.12 6.12l.96-.96a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21.73 15z"/><path d="M14.05 2a9 9 0 0 1 8 7.94"/><path d="M14.05 6A5 5 0 0 1 18 10"/></svg>
                </div>
                <h2 class="text-3xl font-black text-white uppercase italic tracking-wider mb-4">Sprawdź Email! 📬</h2>
                <p class="text-gray-300 mb-2">Konto zostało założone. Wysłaliśmy Ci <span class="text-[#f20df2] font-bold">link aktywacyjny</span> na podany adres email.</p>
                <p class="text-gray-500 text-sm mb-8">Kliknij w link w emailu aby aktywować konto i zalogować się. Jeśli nie widzisz wiadomości, sprawdź folder <strong class="text-gray-400">Spam</strong>.</p>
                <a href="{{ routes.account_login_url }}" class="inline-block bg-[#f20df2] text-white font-black uppercase tracking-widest px-8 py-4 rounded-xl hover:bg-white hover:text-[#0a050a] transition-all duration-300 shadow-[0_0_20px_rgba(242,13,242,0.3)]">
                    Przejdź do logowania
                </a>
            </div>
        {%- else -%}
        <div class="max-w-md w-full border border-white/10 p-8 rounded-3xl relative overflow-hidden group" style="background-color:#221022">
            <div class="absolute inset-0 bg-gradient-to-b from-[#f20df2]/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none"></div>
            
            <div class="text-center mb-10 relative z-10">
                <h1 class="text-3xl font-black text-white uppercase italic tracking-wider mb-2">Utwórz Konto</h1>
                <p class="text-gray-400 text-sm">Dołącz do społeczności Cichoszau</p>
            </div>

            {{ form.errors | default_errors }}
            
            <div class="grid grid-cols-2 gap-4 relative z-10">
                <div class="space-y-2">
                    <label for="FirstName" class="block text-xs font-bold text-gray-400 uppercase tracking-widest">Imię</label>
                    <input type="text"
                        name="customer[first_name]"
                        id="FirstName"
                        class="w-full bg-black/50 border border-white/10 rounded-xl px-4 py-3 text-white placeholder-gray-600 focus:outline-none focus:border-[#f20df2] focus:ring-1 focus:ring-[#f20df2] transition-colors"
                        autocomplete="given-name"
                    >
                </div>
                <div class="space-y-2">
                    <label for="LastName" class="block text-xs font-bold text-gray-400 uppercase tracking-widest">Nazwisko</label>
                    <input type="text"
                        name="customer[last_name]"
                        id="LastName"
                        class="w-full bg-black/50 border border-white/10 rounded-xl px-4 py-3 text-white placeholder-gray-600 focus:outline-none focus:border-[#f20df2] focus:ring-1 focus:ring-[#f20df2] transition-colors"
                        autocomplete="family-name"
                    >
                </div>
            </div>

            <div class="space-y-2 mt-4 relative z-10">
                <label for="Email" class="block text-xs font-bold text-gray-400 uppercase tracking-widest">Email</label>
                <input type="email"
                    name="customer[email]"
                    id="Email"
                    class="w-full bg-black/50 border border-white/10 rounded-xl px-4 py-3 text-white placeholder-gray-600 focus:outline-none focus:border-[#f20df2] focus:ring-1 focus:ring-[#f20df2] transition-colors"
                    spellcheck="false"
                    autocapitalize="off"
                    autocomplete="email"
                    aria-required="true"
                    required
                >
            </div>

            <div class="space-y-2 mt-4 relative z-10">
                <label for="CreatePassword" class="block text-xs font-bold text-gray-400 uppercase tracking-widest">Hasło</label>
                <input type="password"
                    name="customer[password]"
                    id="CreatePassword"
                    class="w-full bg-black/50 border border-white/10 rounded-xl px-4 py-3 text-white placeholder-gray-600 focus:outline-none focus:border-[#f20df2] focus:ring-1 focus:ring-[#f20df2] transition-colors"
                    aria-required="true"
                    required
                >
            </div>

            <button type="submit" class="w-full bg-[#f20df2] text-white font-black uppercase tracking-widest py-4 rounded-xl hover:bg-white hover:text-[#0a050a] transition-all duration-300 shadow-[0_0_20px_rgba(242,13,242,0.3)] hover:shadow-none mt-6 relative z-10">
                Zarejestruj się
            </button>
            
            <div class="text-center mt-6 relative z-10">
                <a href="{{ routes.account_login_url }}" class="text-sm text-gray-400 hover:text-white transition-colors">Masz już konto? Zaloguj się</a>
            </div>
        </div>
        {%- endif -%}
    {%- endform -%}
</div>
