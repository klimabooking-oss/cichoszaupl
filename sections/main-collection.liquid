<section style="background-color:#221022; padding-top: 60px; padding-bottom: 60px;" class="min-h-screen relative" id="main-collection">
    <!-- Static grain overlay -->
    <div class="absolute inset-0 bg-[url('https://grainy-gradients.vercel.app/noise.svg')] opacity-20 pointer-events-none mix-blend-overlay"></div>
    <div class="bg-[#f20df2]/5 w-[500px] h-[500px] rounded-full absolute top-0 left-1/2 transform -translate-x-1/2 blur-[100px] pointer-events-none" style="animation: blob 7s infinite alternate ease-in-out;"></div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        
        <!-- Collection Header -->
        <div class="mb-16 px-4">
            <span class="text-[#f20df2] font-bold tracking-widest text-[10px] uppercase block mb-4">
                DIGITAL STOREHOUSE
            </span>
            <div class="mt-2 text-left">
                <h1 class="text-5xl md:text-7xl font-black text-white uppercase italic tracking-tighter mb-6 leading-none cursor-default">
                    ELITE <span class="text-transparent" style="-webkit-text-stroke: 1px gray;">BOOKING</span>
                </h1>
            </div>
            <p class="text-gray-400 max-w-2xl text-sm md:text-base font-medium">
                {{ collection.description | default: 'Zarządzaj swoim wydarzeniem z poziomu najbardziej zaawansowanego konfiguratora Silent Disco na rynku. Wybierz jakość, której zaufali liderzy branży.' }}
            </p>
            
            <div class="flex flex-wrap gap-4 mt-12">
                <button class="bg-[#f20df2] text-white font-black text-[11px] uppercase tracking-wider py-2.5 px-6 rounded-full border border-[#f20df2] shadow-[0_0_15px_rgba(242,13,242,0.4)]">Wszystkie</button>
                <button class="bg-white/5 border border-white/10 text-gray-400 font-bold text-[11px] uppercase tracking-wider py-2.5 px-6 rounded-full hover:bg-white/10 transition">Zestawy</button>
                <button class="bg-white/5 border border-white/10 text-gray-400 font-bold text-[11px] uppercase tracking-wider py-2.5 px-6 rounded-full hover:bg-white/10 transition">Słuchawki</button>
                <button class="bg-white/5 border border-white/10 text-gray-400 font-bold text-[11px] uppercase tracking-wider py-2.5 px-6 rounded-full hover:bg-white/10 transition">Nadajniki</button>
                <button class="bg-white/5 border border-white/10 text-gray-400 font-bold text-[11px] uppercase tracking-wider py-2.5 px-6 rounded-full hover:bg-white/10 transition">Akcesoria</button>
            </div>
        </div>


        <!-- Products Grid using Liquid -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            {% for product in collection.products limit: 12 %}
                <a href="{{ product.url }}" class="group relative border border-white/5 rounded-3xl overflow-hidden hover:border-[#f20df2]/50 transition-all duration-300 shadow-xl hover:shadow-[#f20df2]/10 hover:-translate-y-2 flex flex-col h-full" style="background-color:#221022; text-decoration:none;">
                    
                    <div class="relative h-64 w-full overflow-hidden" style="background-color:#221022">
                        {% if product.featured_image %}
                            <img src="{{ product.featured_image | img_url: '800x' }}"
                                 alt="{{ product.featured_image.alt | default: product.title }}"
                                 class="w-full h-full object-cover opacity-80 group-hover:opacity-100 transition-all duration-500 transform group-hover:scale-110"
                                 loading="lazy">
                        {% else %}
                            <div class="w-full h-full flex items-center justify-center">
                                <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="rgba(242,13,242,0.3)" stroke-width="1"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg>
                            </div>
                        {% endif %}
                        <div class="absolute inset-0 bg-gradient-to-t from-[#221022] via-transparent to-transparent"></div>
                        
                        {% if product.available %}
                            <div class="absolute top-4 left-4 bg-black/60 backdrop-blur-md text-white text-[10px] font-black uppercase tracking-widest px-3 py-1.5 rounded-full border border-white/10 flex items-center gap-2">
                                <div class="w-2 h-2 rounded-full bg-[#f20df2] animate-pulse"></div>
                                Dostępne
                            </div>
                        {% else %}
                            <div class="absolute top-4 left-4 bg-black/60 backdrop-blur-md text-gray-400 text-[10px] font-black uppercase tracking-widest px-3 py-1.5 rounded-full border border-white/10">
                                Niedostępne
                            </div>
                        {% endif %}
                    </div>

                    <div class="p-8 flex flex-col flex-grow relative z-10">
                        <h3 class="text-2xl font-black text-white uppercase italic mb-2 tracking-tight">{{ product.title }}</h3>
                        
                        <div class="text-gray-400 text-sm mb-6 flex-grow line-clamp-3">{{ product.description | strip_html | truncate: 120 }}</div>

                        <div class="flex items-end justify-between mt-auto">
                            <div>
                                <div class="text-[10px] uppercase font-bold text-gray-500 tracking-wider mb-1">Od</div>
                                <div class="text-3xl font-black text-transparent bg-clip-text bg-gradient-to-r from-[#f20df2] to-[#ff5f1f]">
                                    {{ product.price_min | money }}
                                </div>
                            </div>
                            <div class="w-12 h-12 rounded-full flex items-center justify-center text-white group-hover:bg-[#f20df2] group-hover:border-[#f20df2] group-hover:-rotate-45 transition-all duration-300" style="background-color:rgba(255,255,255,0.05); border:1px solid rgba(255,255,255,0.1)">
                                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                            </div>
                        </div>
                    </div>
                </a>
            {% else %}
                <div class="col-span-3 text-center py-20 text-gray-500">
                    <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" class="mx-auto mb-6 opacity-30"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/><path d="M3 6h18"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
                    <p class="text-xl font-bold uppercase tracking-widest">Brak produktów w tej kolekcji</p>
                </div>
            {% endfor %}
        </div>

    </div>

    <!-- Product Modal (Hidden by default) -->
    <div id="product-modal" style="background-color:#221022" class="fixed inset-0 z-[100] /90 backdrop-blur-md flex items-center justify-center p-4 hidden opacity-0 transition-opacity duration-300">
        <div style="background-color:#221022" class=" border border-white/10 rounded-3xl w-full max-w-5xl max-h-[90vh] overflow-y-auto shadow-2xl relative flex flex-col md:flex-row transform scale-95 transition-transform duration-300" id="product-modal-content">
            
            <button id="close-modal" class="absolute top-4 right-4 z-50 w-12 h-12 bg-black/50 hover:bg-[#f20df2] rounded-full flex items-center justify-center text-white transition-all backdrop-blur-md border border-white/10 hover:rotate-90">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
            </button>

            <!-- Product Context dynamically inserted via JS to update product ID -->
            <div id="modal-shopify-context-wrapper" class="w-full flex flex-col md:flex-row">
                <!-- Inner HTML will hold <shopify-context> for selected product -->
            </div>
            
        </div>
    </div>

    <script>
        function openProductModal(productId) {
            const modal = document.getElementById('product-modal');
            const wrapper = document.getElementById('modal-shopify-context-wrapper');
            const content = document.getElementById('product-modal-content');

            // Inject the context for the specific product dynamically
            wrapper.innerHTML = `
                <shopify-context type="product" product="${productId}">
                    <template>
                        <div class="w-full md:w-1/2 min-h-[400px] relative bg-black">
                            <shopify-media media="image" class="w-full h-full object-cover opacity-80"></shopify-media>
                            <div class="absolute inset-0 bg-gradient-to-t md:bg-gradient-to-r from-surface-dark via-transparent to-transparent"></div>
                        </div>
                        <div class="w-full md:w-1/2 p-8 md:p-12 flex flex-col">
                            <div class="inline-block px-3 py-1 rounded-full bg-[#f20df2]/20 border border-[#f20df2]/30 text-[#f20df2] text-[10px] font-black uppercase tracking-widest mb-6 self-start">
                                Szczegóły
                            </div>
                            
                            <h2 class="text-3xl md:text-5xl font-black text-white uppercase italic mb-4 leading-tight">
                                <shopify-text>title</shopify-text>
                            </h2>
                            
                            <div class="text-3xl font-black text-transparent bg-clip-text bg-gradient-to-r from-[#f20df2] to-[#ff5f1f] mb-8">
                                <shopify-money>price_min</shopify-money>
                            </div>
                            
                            <div class="prose prose-invert max-w-none text-gray-400 mb-8 border-b border-white/5 pb-8">
                                <shopify-text>description</shopify-text>
                            </div>

                            <!-- Cart Integration -->
                            <div class="mt-auto space-y-4">
                                <shopify-variant-selector>
                                    <template>
                                        <div class="mb-4">
                                            <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-2"><shopify-text>name</shopify-text></label>
                                            <select style="background-color:#221022" class="w-full  border border-white/10 rounded-xl px-4 py-3 text-white focus:border-[#f20df2] outline-none">
                                                <option value="[data-variant-id]"><shopify-text>value</shopify-text></option>
                                            </select>
                                        </div>
                                    </template>
                                </shopify-variant-selector>
                                
                                <shopify-cart>
                                    <template>
                                        <button data-add-to-cart class="w-full py-4 rounded-xl bg-white text-black font-black uppercase tracking-wider text-sm shadow-[0_0_30px_rgba(255,255,255,0.1)] hover:bg-[#f20df2] hover:text-white transition-all transform hover:scale-[1.02] flex items-center justify-center gap-2">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="8" cy="21" r="1"/><circle cx="19" cy="21" r="1"/><path d="M2.05 2.05h2l2.66 12.42a2 2 0 0 0 2 1.58h9.78a2 2 0 0 0 1.95-1.57l1.65-7.43H5.12"/></svg>
                                            Do Koszyka
                                        </button>
                                    </template>
                                </shopify-cart>
                            </div>
                        </div>
                    </template>
                </shopify-context>
            `;

            modal.classList.remove('hidden');
            // Small delay to allow display:flex to apply before animating opacity
            setTimeout(() => {
                modal.classList.remove('opacity-0');
                content.classList.remove('scale-95');
                content.classList.add('scale-100');
            }, 10);
            document.body.style.overflow = 'hidden';
        }

        document.addEventListener('DOMContentLoaded', () => {
            const modal = document.getElementById('product-modal');
            const closeBtn = document.getElementById('close-modal');
            const content = document.getElementById('product-modal-content');

            function closeModal() {
                modal.classList.add('opacity-0');
                content.classList.remove('scale-100');
                content.classList.add('scale-95');
                setTimeout(() => {
                    modal.classList.add('hidden');
                    document.getElementById('modal-shopify-context-wrapper').innerHTML = '';
                    document.body.style.overflow = '';
                }, 300);
            }

            closeBtn.addEventListener('click', closeModal);
            modal.addEventListener('click', (e) => {
                if (e.target === modal) {
                    closeModal();
                }
            });

            document.addEventListener('keydown', (e) => {
                if (e.key === 'Escape' && !modal.classList.contains('hidden')) {
                    closeModal();
                }
            });
        });
    </script>
</section>

{% schema %}
{
  "name": "Collection Grid",
  "settings": [],
  "presets": [
    {
      "name": "Collection Grid"
    }
  ]
}
{% endschema %}
