<section class="overflow-hidden relative" id="event-slider" style="background-color:#221022; padding-top:6px; padding-bottom:6px">
    <div class="section-sep" aria-hidden="true"></div>
    <div class="absolute inset-0 pointer-events-none" style="background-image:url('https://grainy-gradients.vercel.app/noise.svg');opacity:0.15;mix-blend-mode:overlay"></div>

    <div class="relative z-10">
        {% comment %} Split blocks into two rows {% endcomment %}
        {% assign all_blocks = section.blocks %}
        {% assign half = all_blocks.size | divided_by: 2 %}

        {% comment %} Row 1 — forward {% endcomment %}
        <div class="overflow-hidden mb-3"
             onmouseenter="this.querySelector('.mq1').style.animationPlayState='paused';this.querySelector('.mq1b').style.animationPlayState='paused'"
             onmouseleave="this.querySelector('.mq1').style.animationPlayState='running';this.querySelector('.mq1b').style.animationPlayState='running'">
            <div style="display:flex; width:max-content">
                <div class="mq1" style="display:flex; gap:12px; animation:mq-fwd 40s linear infinite; flex-shrink:0">
                    {% for block in all_blocks %}
                        {% if forloop.index0 < half or half == 0 %}
                            <div style="width:260px; height:220px; flex-shrink:0; border-radius:20px; overflow:hidden; background-color:#221022; border:1px solid rgba(255,255,255,0.06)">
                                {% if block.settings.image %}
                                    <img src="{{ block.settings.image | img_url: '600x' }}" alt="Event" style="width:100%;height:100%;object-fit:cover" loading="lazy">
                                {% else %}
                                    <div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="rgba(242,13,242,0.3)" stroke-width="1"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="m21 15-5-5L5 21"/></svg>
                                    </div>
                                {% endif %}
                            </div>
                        {% endif %}
                    {% else %}
                        {% comment %} Placeholder tiles when no blocks {% endcomment %}
                        {% for i in (1..8) %}
                            <div style="width:260px; height:220px; flex-shrink:0; border-radius:20px; overflow:hidden; background-color:#221022; border:1px solid rgba(242,13,242,0.15); display:flex; align-items:center; justify-content:center; flex-direction:column; gap:8px">
                                <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="rgba(242,13,242,0.3)" stroke-width="1"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="m21 15-5-5L5 21"/></svg>
                                <p style="font-size:9px;font-weight:800;text-transform:uppercase;letter-spacing:0.15em;color:rgba(242,13,242,0.4)">Dodaj zdjęcie</p>
                            </div>
                        {% endfor %}
                    {% endfor %}
                </div>
                {% comment %} Duplicate for seamless loop {% endcomment %}
                <div class="mq1b" style="display:flex; gap:12px; animation:mq-fwd 40s linear infinite; flex-shrink:0" aria-hidden="true">
                    {% for block in all_blocks %}
                        {% if forloop.index0 < half or half == 0 %}
                            <div style="width:260px; height:220px; flex-shrink:0; border-radius:20px; overflow:hidden; background-color:#221022; border:1px solid rgba(255,255,255,0.06)">
                                {% if block.settings.image %}
                                    <img src="{{ block.settings.image | img_url: '600x' }}" alt="Event" style="width:100%;height:100%;object-fit:cover" loading="lazy">
                                {% else %}
                                    <div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="rgba(242,13,242,0.3)" stroke-width="1"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="m21 15-5-5L5 21"/></svg>
                                    </div>
                                {% endif %}
                            </div>
                        {% endif %}
                    {% else %}
                        {% for i in (1..8) %}
                            <div style="width:260px; height:220px; flex-shrink:0; border-radius:20px; overflow:hidden; background-color:#221022; border:1px solid rgba(242,13,242,0.15); display:flex; align-items:center; justify-content:center">
                                <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="rgba(242,13,242,0.3)" stroke-width="1"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="m21 15-5-5L5 21"/></svg>
                            </div>
                        {% endfor %}
                    {% endfor %}
                </div>
            </div>
        </div>

        {% comment %} Row 2 — reverse {% endcomment %}
        <div class="overflow-hidden"
             onmouseenter="this.querySelector('.mq2').style.animationPlayState='paused';this.querySelector('.mq2b').style.animationPlayState='paused'"
             onmouseleave="this.querySelector('.mq2').style.animationPlayState='running';this.querySelector('.mq2b').style.animationPlayState='running'">
            <div style="display:flex; width:max-content">
                <div class="mq2" style="display:flex; gap:12px; animation:mq-rev 45s linear infinite; flex-shrink:0">
                    {% for block in all_blocks %}
                        {% if forloop.index0 >= half %}
                            <div style="width:260px; height:220px; flex-shrink:0; border-radius:20px; overflow:hidden; background-color:#221022; border:1px solid rgba(255,255,255,0.06)">
                                {% if block.settings.image %}
                                    <img src="{{ block.settings.image | img_url: '600x' }}" alt="Event" style="width:100%;height:100%;object-fit:cover" loading="lazy">
                                {% else %}
                                    <div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="rgba(242,13,242,0.3)" stroke-width="1"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="m21 15-5-5L5 21"/></svg>
                                    </div>
                                {% endif %}
                            </div>
                        {% endif %}
                    {% else %}
                        {% for i in (1..8) %}
                            <div style="width:260px; height:220px; flex-shrink:0; border-radius:20px; overflow:hidden; background-color:#221022; border:1px solid rgba(242,13,242,0.15); display:flex; align-items:center; justify-content:center">
                                <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="rgba(242,13,242,0.3)" stroke-width="1"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="m21 15-5-5L5 21"/></svg>
                            </div>
                        {% endfor %}
                    {% endfor %}
                </div>
                <div class="mq2b" style="display:flex; gap:12px; animation:mq-rev 45s linear infinite; flex-shrink:0" aria-hidden="true">
                    {% for block in all_blocks %}
                        {% if forloop.index0 >= half %}
                            <div style="width:260px; height:220px; flex-shrink:0; border-radius:20px; overflow:hidden; background-color:#221022; border:1px solid rgba(255,255,255,0.06)">
                                {% if block.settings.image %}
                                    <img src="{{ block.settings.image | img_url: '600x' }}" alt="Event" style="width:100%;height:100%;object-fit:cover" loading="lazy">
                                {% else %}
                                    <div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="rgba(242,13,242,0.3)" stroke-width="1"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="m21 15-5-5L5 21"/></svg>
                                    </div>
                                {% endif %}
                            </div>
                        {% endif %}
                    {% else %}
                        {% for i in (1..8) %}
                            <div style="width:260px; height:220px; flex-shrink:0; border-radius:20px; overflow:hidden; background-color:#221022; border:1px solid rgba(242,13,242,0.15); display:flex; align-items:center; justify-content:center">
                                <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="rgba(242,13,242,0.3)" stroke-width="1"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="m21 15-5-5L5 21"/></svg>
                            </div>
                        {% endfor %}
                    {% endfor %}
                </div>
            </div>
        </div>
    </div>

    <style>
        @keyframes mq-fwd {
            from { transform: translateX(0); }
            to   { transform: translateX(-100%); }
        }
        @keyframes mq-rev {
            from { transform: translateX(-100%); }
            to   { transform: translateX(0); }
        }
    </style>
</section>

{% schema %}
{
  "name": "Event Slider",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Tytuł sekcji",
      "default": "Nasze Eventy"
    }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Zdjęcie eventu",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Zdjęcie"
        }
      ]
    }
  ],
  "max_blocks": 20,
  "presets": [
    {
      "name": "Event Slider"
    }
  ]
}
{% endschema %}
