<section class="bg-[#221022] py-16 relative overflow-hidden" id="b2b-explainer">
    <div class="max-w-5xl mx-auto px-5 relative z-20">
        
        <div class="glass-card border border-[#f20df2]/40 shadow-[0_0_30px_rgba(242,13,242,0.15)] rounded-3xl p-8 md:p-12 overflow-hidden relative">
            <div class="absolute -top-40 -right-40 w-80 h-80 bg-[#f20df2] rounded-full blur-[100px] opacity-20 pointer-events-none"></div>
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-10 items-center">
                
                <div data-animate="fade-right">
                    <h3 class="text-2xl md:text-3xl font-black text-white uppercase italic mb-6">Jak dobraliśmy sprzęt dla Twojej ekipy?</h3>
                    <div class="space-y-6">
                        <div class="flex gap-4">
                            <div class="mt-1 w-8 h-8 rounded-full bg-[#f20df2]/20 flex items-center justify-center shrink-0">
                                <span class="text-[#f20df2] font-black text-sm">1</span>
                            </div>
                            <div>
                                <h4 class="text-white font-bold text-lg mb-1">Dla imprez do 200 osób</h4>
                                <p class="text-gray-400 text-sm leading-relaxed">
                                    Najlepiej sprawdza się model <strong class="text-white">„2 DJ-ów + 1 Playlista”</strong>. Dwa różne kanały grają na żywo (np. pop & rock versus house & techno), a trzeci puszcza dedykowaną playlistę np. przebojów latino. To minimalizuje koszty i zachowuje magię 3 kanałów.
                                </p>
                            </div>
                        </div>

                        <div class="flex gap-4">
                            <div class="mt-1 w-8 h-8 rounded-full bg-[#3b82f6]/20 flex items-center justify-center shrink-0">
                                <span class="text-[#3b82f6] font-black text-sm">2</span>
                            </div>
                            <div>
                                <h4 class="text-white font-bold text-lg mb-1">Pełna organizacja na miejscu</h4>
                                <p class="text-gray-400 text-sm leading-relaxed">
                                    W paczce "obsługa i oprawa" zapewniamy naszą ekipę rozliczającą wydania sprzętu, podświetlenie sceny / strefy DJ oraz pamiątkowe Wideo z eventu (bardzo pożądane przez działy HR do firmowych formatów Video Marketingowych np. na LinkedIn / Reels).
                                </p>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="relative glass-card border border-white/10 rounded-2xl p-6 bg-black/40" data-animate="fade-left">
                    <div class="absolute -top-3 -left-3 px-4 py-1.5 rounded-full bg-gradient-to-r from-[#f20df2] to-[#ff5f1f] text-white text-[10px] font-black uppercase tracking-widest shadow-lg">Nasza misja</div>
                    
                    <h4 class="text-xl font-bold text-white mb-4 mt-2">Darmowa Wycena</h4>
                    <p class="text-gray-400 text-sm mb-6 leading-relaxed">
                        Wykorzystaj nasz niezawodny sprzęt o zasięgu do 500 metrów z bateriami na 10h zabawy. Skorzystaj z kalkulatora powyżej, aby wygenerować niezobowiązujący wstępny szacunek dla wybranej wielkości zespołu.
                    </p>
                    <ul class="text-sm text-gray-300 space-y-3 font-medium">
                        <li class="flex items-center gap-2">
                            <svg class="text-[#f20df2]" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                            Faktury VAT (z odroczonym terminem)
                        </li>
                        <li class="flex items-center gap-2">
                            <svg class="text-[#f20df2]" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                            Zabezpieczone stany magazynowe
                        </li>
                        <li class="flex items-center gap-2">
                            <svg class="text-[#f20df2]" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                            Sprawdzona ekipa i umowa B2B
                        </li>
                    </ul>
                </div>
            </div>

        </div>
    </div>
</section>

{% schema %}
{
  "name": "B2B Explainer",
  "settings": [],
  "presets": [
    {
      "name": "B2B Explainer"
    }
  ]
}
{% endschema %}
