                <span class="text-gray-500 text-xs mt-2 uppercase tracking-widest">Seanse letnie</span>
            </a>
            
            <a id="link-konferencje" href="#" class="flex flex-col items-center justify-center p-6 bg-[#221022] border border-white/10 rounded-2xl hover:border-[#00ccff] hover:bg-[#00ccff]/10 transition-all group">
                <h3 class="text-white font-black uppercase tracking-wider group-hover:text-[#00ccff] transition-colors">Konferencje</h3>
                <span class="text-gray-500 text-xs mt-2 uppercase tracking-widest">Tłumaczenia i panele</span>
            </a>
            
            <a id="link-teatr" href="#" class="flex flex-col items-center justify-center p-6 bg-[#221022] border border-white/10 rounded-2xl hover:border-[#9900ff] hover:bg-[#9900ff]/10 transition-all group">
                <h3 class="text-white font-black uppercase tracking-wider group-hover:text-[#9900ff] transition-colors">Teatr Silent</h3>
                <span class="text-gray-500 text-xs mt-2 uppercase tracking-widest">Spektakle & Sztuka</span>
            </a>
        </div>
    </div>
</div>

<script>
    const modal = document.getElementById('city-services-modal');
    const modalBox = document.getElementById('modal-content-box');
    const cityNameLabel = document.getElementById('modal-city-name');

    // Linki
    const linkWynajem = document.getElementById('link-wynajem');
    const linkB2B = document.getElementById('link-b2b');
    const linkBeach = document.getElementById('link-beach');
    const linkFest = document.getElementById('link-festiwale');
    const linkKino = document.getElementById('link-kino');
    const linkKonf = document.getElementById('link-konferencje');
    const linkTeatr = document.getElementById('link-teatr');

    function openCityModal(handle, name) {
        cityNameLabel.innerText = name;
        
        // Jeśli separator myślnik "-" np. "oferta-beach-bary" zgłasza błędy u użytkownika, 
        // można tu płynnie to przepisać (zostawiłem z podłogą jako standard podziału Metaobject-URL).
        // UWAGA: Standardowo Shopify wypuszcza Metaobiekty jako /pages/{type_handle}/{handle}
        linkWynajem.href = `/pages/wynajem-sluchawek-silent-disco#rental`;
        linkB2B.href = `/pages/oferta-eventy-firmowe/${handle}`;
        linkBeach.href = `/pages/oferta-beach-bary/${handle}`;
        linkFest.href = `/pages/oferta-festiwale/${handle}`;
        linkKino.href = `/pages/oferta-kino-plenerowe/${handle}`;
        linkKonf.href = `/pages/oferta-konferencje/${handle}`;
        linkTeatr.href = `/pages/oferta-teatr-silent/${handle}`;

        modal.classList.remove('hidden');
        modal.classList.add('flex');
        
        // Płynne wejście
        setTimeout(() => {
            modal.classList.remove('opacity-0');
            modalBox.classList.remove('scale-95');
            modalBox.classList.add('scale-100');
        }, 10);
    }

    function closeCityModal() {
        modal.classList.add('opacity-0');
        modalBox.classList.remove('scale-100');
        modalBox.classList.add('scale-95');
        
        setTimeout(() => {
            modal.classList.add('hidden');
            modal.classList.remove('flex');
        }, 300);
    }

    // Zamknij po kliknięciu w tło
    modal.addEventListener('click', (e) => {
        if (e.target === modal) closeCityModal();
    });
    
    // Zablokuj skrolowanie pod modalem jeśli potrzeba (opcjonalnie)

    // Intercept city card clicks to open the modal instead of redirecting
    // Używamy event delegation dla większej pewności
    document.addEventListener('click', (e) => {
        const card = e.target.closest('.city-card');
        if (!card) return;
        
        e.preventDefault();
        e.stopPropagation();
        e.stopImmediatePropagation();
        
        // Pobierz nazwę miasta z h3
        const cityNameElement = card.querySelector('h3');
        const cityName = cityNameElement ? cityNameElement.innerText.trim() : 'Miasto';
        
        // Pobierz 'handle' z adresu URL
        const url = new URL(card.href, window.location.origin);
        const pathParts = url.pathname.split('/').filter(Boolean); // filter usuwa puste stringi
        const handle = pathParts[pathParts.length - 1]; 
        
        openCityModal(handle, cityName);
    }, true); // Używamy fazy capture, aby przechwycić zdarzenie przed innymi
</script>

