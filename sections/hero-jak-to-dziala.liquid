<section class="relative min-h-[100svh] md:min-h-[80vh] w-full flex flex-col overflow-x-clip" id="hero-section" style="padding-top: clamp(100px, 12vw, 120px); padding-bottom: clamp(50px, 6vw, 60px); background-color: transparent !important;">
    <!-- === Tło Hero (Parallax & Video/Image) === -->
    <div id="hero-bg-wrapper" class="fixed inset-0 w-full h-[100svh] pointer-events-none z-0">
        <!-- === WARSTWA 1: Zwykłe czarne tło (najniżej) === -->
        <div class="absolute inset-0 pointer-events-none bg-[#000000]" style="z-index: 0;"></div>

        <!-- === WARSTWA 2: Film / Zdjęcie === -->
        {% if section.settings.bg_video != blank or section.settings.bg_video_mobile != blank %}
            <div class="absolute inset-x-0 top-0 h-[100svh] md:h-full md:inset-0 pointer-events-none overflow-hidden" style="z-index: 10;">
                {% if section.settings.bg_video != blank %}
                <video
                    id="hero-bg-video-desktop"
                    class="w-full h-full object-cover will-change-transform {% if section.settings.bg_video_mobile != blank %}hidden md:block{% else %}block{% endif %}"
                    style="opacity: 0.85; object-position: center 15%;"
                    autoplay loop muted playsinline preload="auto" fetchpriority="high"
                    {% if section.settings.bg_image %}poster="{{ section.settings.bg_image | image_url: width: 1920 }}"{% endif %}
                >
                    {% for source in section.settings.bg_video.sources %}
                        <source src="{{ source.url }}" type="video/{{ source.format }}">
                    {% endfor %}
                </video>
                {% endif %}

                {% if section.settings.bg_video_mobile != blank %}
                <video
                    id="hero-bg-video-mobile"
                    class="w-full h-full object-cover aspect-[9/16] will-change-transform {% if section.settings.bg_video != blank %}block md:hidden{% else %}block{% endif %}"
                    style="opacity: 0.85; object-position: center 15%;"
                    autoplay loop muted playsinline preload="auto" fetchpriority="high"
                    {% if section.settings.bg_image_mobile %}poster="{{ section.settings.bg_image_mobile | image_url: width: 800 }}"{% elsif section.settings.bg_image %}poster="{{ section.settings.bg_image | image_url: width: 800 }}"{% endif %}
                >
                    {% for source in section.settings.bg_video_mobile.sources %}
                        <source src="{{ source.url }}" type="video/{{ source.format }}">
                    {% endfor %}
                </video>
                {% endif %}
                <!-- Delikatniejszy gradient po fioletowej poświacie -->
                <div class="absolute inset-0 bg-gradient-to-r from-[#221022]/60 md:from-[#221022] via-[#221022]/30 md:via-[#221022]/70 to-transparent" style="z-index: 20;"></div>
            </div>
        {% elsif section.settings.bg_image or section.settings.bg_image_mobile %}
            <div class="absolute inset-x-0 top-0 h-[100svh] md:h-full md:inset-0 pointer-events-none overflow-hidden" style="z-index: 10;">
                <picture>
                    {% if section.settings.bg_image_mobile %}
                    <source media="(max-width: 767px)" srcset="{{ section.settings.bg_image_mobile | image_url: width: 600, format: 'webp' }} 600w, {{ section.settings.bg_image_mobile | image_url: width: 800, format: 'webp' }} 800w">
                    {% endif %}
                    {% if section.settings.bg_image %}
                    <source media="(min-width: 768px)" srcset="{{ section.settings.bg_image | image_url: width: 1200, format: 'webp' }} 1200w, {{ section.settings.bg_image | image_url: width: 1920, format: 'webp' }} 1920w">
                    <img
                        alt="{{ section.settings.bg_image.alt | default: 'CICHOSZAU Silent Disco' }}"
                        class="w-full h-full object-cover transition-all duration-1000 will-change-transform"
                        style="opacity: 0.85; object-position: center 15%;"
                        id="hero-bg-img"
                        src="{{ section.settings.bg_image | image_url: width: 1920, format: 'webp' }}"
                        fetchpriority="high"
                        loading="eager"
                    />
                    {% elsif section.settings.bg_image_mobile %}
                    <img
                        alt="{{ section.settings.bg_image_mobile.alt | default: 'CICHOSZAU Silent Disco Mobile' }}"
                        class="w-full h-full object-cover aspect-[9/16] transition-all duration-1000 will-change-transform"
                        style="opacity: 0.85; object-position: center 15%;"
                        id="hero-bg-img"
                        src="{{ section.settings.bg_image_mobile | image_url: width: 800, format: 'webp' }}"
                        fetchpriority="high"
                        loading="eager"
                    />
                    {% endif %}
                </picture>
                <div class="absolute inset-0 bg-gradient-to-r from-[#221022]/60 md:from-[#221022] via-[#221022]/30 md:via-[#221022]/70 to-transparent" style="z-index: 20;"></div>
            </div>
        {% else %}
            <div class="absolute inset-x-0 top-0 h-[100svh] md:h-full md:inset-0 pointer-events-none overflow-hidden" style="z-index: 10;">
                <img
                    alt="Silent Disco Party Crowd"
                    class="w-full h-full object-cover transition-all duration-1000 will-change-transform"
                    style="opacity: 0.85; object-position: center 15%;"
                    id="hero-bg-img"
                    src="https://images.unsplash.com/photo-1516450360452-9312f5e86fc7?q=80&w=1920&auto=format&fit=crop"
                    fetchpriority="high"
                    loading="eager"
                />
                <div class="absolute inset-0 bg-gradient-to-r from-[#221022]/60 md:from-[#221022] via-[#221022]/30 md:via-[#221022]/70 to-transparent" style="z-index: 20;"></div>
            </div>
        {% endif %}

        <!-- Dynamic overlay gradients -->
        <div class="absolute inset-0 z-[15] pointer-events-none">
            <div class="absolute inset-0 bg-gradient-to-b from-[#221022]/50 md:from-[#221022]/90 via-[#221022]/20 md:via-[#221022]/40 to-[#221022]/80 md:to-[#221022] z-10 pointer-events-none"></div>
            <div class="absolute inset-0 bg-[#f20df2]/10 mix-blend-overlay z-10"></div>
            <!-- Pulsing mesh gradient overlay -->
            <div class="absolute inset-0 opacity-40 bg-[radial-gradient(circle_at_50%_50%,rgba(242,13,242,0.2),transparent_70%)]" style="animation: pulse-slow 8s infinite ease-in-out;"></div>
            <div class="absolute inset-0 opacity-20 bg-[radial-gradient(circle_at_20%_30%,rgba(255,95,31,0.2),transparent_50%)]" style="animation: pulse-slow 8s infinite ease-in-out; animation-delay: 2s;"></div>
        </div>
    </div>

    <!-- Animated Blobs with Wavy Motion -->
    <div class="bg-[#f20df2] w-[300px] md:w-[600px] h-[300px] md:h-[600px] rounded-full absolute top-[-10%] left-[-10%] blur-[120px] opacity-30 z-10" style="animation: blob 7s infinite alternate ease-in-out;" data-parallax="0.15"></div>
    <div class="bg-[#ff5f1f] w-[250px] md:w-[500px] h-[250px] md:h-[500px] rounded-full absolute bottom-[-5%] right-[-5%] blur-[100px] opacity-30 z-10" style="animation: blob 7s infinite alternate ease-in-out; animation-delay: 3s;" data-parallax="-0.12"></div>
    <div class="bg-[#ffd700] w-[200px] md:w-[400px] h-[200px] md:h-[400px] rounded-full absolute top-[40%] right-[10%] opacity-10 blur-[80px] z-10" style="animation: blob 7s infinite alternate ease-in-out; animation-delay: 5s;" data-parallax="0.08"></div>

    <div class="relative w-full max-w-7xl m-auto px-5 text-center z-20 flex flex-col justify-center items-center pb-12 md:pb-16 md:min-h-0" style="min-height: calc(100svh - clamp(100px, 12vw, 120px) + 4px);">
        <div class="inline-flex items-center px-6 py-2 rounded-full border border-[#f20df2]/50 glass-card mb-8 transform -rotate-2 hover:rotate-0 transition-transform duration-300">
            <span class="flex h-3 w-3 rounded-full bg-[#ffd700] mr-3 animate-ping"></span>
            <span class="text-sm font-bold text-white tracking-widest uppercase">High Energy Events Agency</span>
        </div>
        
        <h1 class="sr-only">Wypożyczalnia słuchawek Silent Disco, organizacja imprez i festiwali bezprzewodowych | CICHOSZAU</h1>
        <div aria-hidden="true" class="text-[11vw] sm:text-5xl md:text-8xl lg:text-9xl font-black text-white tracking-tighter mb-8 leading-[0.9] drop-shadow-2xl">
            <div class="transform -rotate-1 hover:rotate-0 transition-transform duration-500"><span id="hero-typewriter">SILENT DISCO</span><span class="hero-cursor" style="border-right:3px solid #f20df2;margin-left:2px;animation:blink-cursor 0.75s step-end infinite;"> </span></div>
            <div class="text-transparent bg-clip-text bg-gradient-to-r from-[#f20df2] via-[#ff5f1f] to-[#ffd700] transform rotate-2 hover:rotate-0 transition-transform duration-500 pb-2">TECHNOLOGIA</div>
            <div class="transform -rotate-1 hover:rotate-0 transition-transform duration-500" style="-webkit-text-stroke: 1px rgba(255, 255, 255, 0.4); color: transparent;">DOŚWIADCZENIE</div>
        </div>
        
        <p class="mt-8 max-w-3xl mx-auto text-lg md:text-2xl text-gray-200 mb-12 font-medium leading-relaxed drop-shadow-lg">
            Tworzymy <span class="text-[#ffd700] font-bold">niezapomniane</span> wydarzenia. Połącz magię dźwięku z festiwalową energią Twojej marki.
        </p>
        
        <!-- ═══ JAK TO DZIAŁA — IKONY KORZYŚCI ═══ -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-16 max-w-5xl mx-auto w-full" id="jtd-features">
            <!-- Feature 1 -->
            <div class="group relative flex flex-col items-center justify-center p-8 rounded-3xl border border-[#f20df2]/40 shadow-[0_0_20px_rgba(242,13,242,0.15)] glass-card overflow-hidden hover:border-[#f20df2]/60 transition-all duration-500 hover:shadow-[0_20px_60px_rgba(242,13,242,0.25)] text-center">
                <div class="absolute inset-0 bg-gradient-to-br from-[#f20df2]/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none rounded-3xl"></div>
                <div class="w-16 h-16 rounded-2xl bg-[#f20df2]/15 border border-[#f20df2]/30 flex items-center justify-center mb-5 group-hover:scale-110 group-hover:bg-[#f20df2]/25 transition-all duration-300">
                    <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[#f20df2]"><path d="M4.9 19.1C1 15.2 1 8.8 4.9 4.9"/><path d="M7.8 16.2c-2.3-2.3-2.3-6.1 0-8.5"/><circle cx="12" cy="12" r="2"/><path d="M16.2 7.8c2.3 2.3 2.3 6.1 0 8.5"/><path d="M19.1 4.9C23 8.8 23 15.2 19.1 19.1"/></svg>
                </div>
                <h3 class="text-xl md:text-2xl font-black text-white uppercase italic leading-tight mb-2 group-hover:text-[#f20df2] transition-colors">500m Zasięgu</h3>
                <p class="text-gray-400 text-sm leading-relaxed">Płynny i czysty dźwięk bez zakłóceń na dużej przestrzeni. Wolność od kabli.</p>
            </div>

            <!-- Feature 2 -->
            <div class="group relative flex flex-col items-center justify-center p-8 rounded-3xl border border-[#ff5f1f]/40 bg-[#ff5f1f]/5 backdrop-blur-md overflow-hidden hover:border-[#ff5f1f]/80 transition-all duration-500 hover:-translate-y-2 hover:shadow-[0_25px_70px_rgba(255,95,31,0.35)] text-center scale-[1.02]">
                <div class="absolute top-4 right-4 px-3 py-1 rounded-full bg-[#ff5f1f] text-white text-[10px] font-black uppercase tracking-widest animate-pulse">Standard</div>
                <div class="absolute inset-0 bg-gradient-to-br from-[#ff5f1f]/15 to-transparent pointer-events-none rounded-3xl"></div>
                <div class="w-16 h-16 rounded-2xl bg-[#ff5f1f]/20 border border-[#ff5f1f]/40 flex items-center justify-center mb-5 group-hover:scale-110 group-hover:bg-[#ff5f1f]/30 transition-all duration-300">
                    <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" class="text-[#ff5f1f]" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="21" x2="14" y1="4" y2="4"/><line x1="10" x2="3" y1="4" y2="4"/><line x1="21" x2="12" y1="12" y2="12"/><line x1="8" x2="3" y1="12" y2="12"/><line x1="21" x2="16" y1="20" y2="20"/><line x1="12" x2="3" y1="20" y2="20"/><line x1="14" x2="14" y1="2" y2="6"/><line x1="8" x2="8" y1="10" y2="14"/><line x1="16" x2="16" y1="18" y2="22"/></svg>
                </div>
                <h3 class="text-xl md:text-2xl font-black text-white uppercase italic leading-tight mb-2 group-hover:text-[#ff5f1f] transition-colors">3 Kanały</h3>
                <p class="text-gray-400 text-sm leading-relaxed">Muzyka z 3 różnych stacji jednocześnie. Każdy bawi się do swojego ulubionego rytmu.</p>
            </div>

            <!-- Feature 3 -->
            <div class="group relative flex flex-col items-center justify-center p-8 rounded-3xl border border-[#f20df2]/40 shadow-[0_0_20px_rgba(242,13,242,0.15)] glass-card overflow-hidden hover:border-[#ffd700]/60 transition-all duration-500 hover:shadow-[0_20px_60px_rgba(255,215,0,0.25)] text-center">
                <div class="absolute inset-0 bg-gradient-to-br from-[#ffd700]/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none rounded-3xl"></div>
                <div class="w-16 h-16 rounded-2xl bg-[#ffd700]/15 border border-[#ffd700]/30 flex items-center justify-center mb-5 group-hover:scale-110 group-hover:bg-[#ffd700]/25 transition-all duration-300">
                    <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[#ffd700]"><rect width="16" height="10" x="2" y="7" rx="2" ry="2"/><line x1="22" x2="22" y1="11" y2="13"/><line x1="6" x2="6" y1="11" y2="13"/><line x1="10" x2="10" y1="11" y2="13"/><line x1="14" x2="14" y1="11" y2="13"/></svg>
                </div>
                <h3 class="text-xl md:text-2xl font-black text-white uppercase italic leading-tight mb-2 group-hover:text-[#ffd700] transition-colors">12H Pracy</h3>
                <p class="text-gray-400 text-sm leading-relaxed">Jedno ładowanie zapewnia całonocną imprezę. Bateria wytrzyma każdy event.</p>
            </div>
        </div>
    </div>
</section>

{% schema %}
{
  "name": "Hero Jak to działa",
  "settings": [
    {
      "type": "video",
      "id": "bg_video",
      "label": "Video tla Hero (Desktop 16:9)"
    },
    {
      "type": "video",
      "id": "bg_video_mobile",
      "label": "Video tla Hero (Mobile 9:16)"
    },
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Zdjecie tla (Desktop 16:9 - fallback dla wideo or standalone)"
    },
    {
      "type": "image_picker",
      "id": "bg_image_mobile",
      "label": "Zdjecie tla (Mobile 9:16 - fallback dla wideo or standalone)"
    }
  ],
  "presets": [
    {
      "name": "Hero Jak to działa"
    }
  ]
}
{% endschema %}
