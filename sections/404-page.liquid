<section class="relative min-h-screen flex items-center justify-center overflow-hidden bg-[#221022]" style="padding-top: 15px; padding-bottom: 15px;">
    <div class="section-sep" aria-hidden="true"></div>

    <!-- Animated blobs -->
    <div class="absolute top-[-10%] left-[-10%] w-[500px] h-[500px] bg-[#f20df2] rounded-full blur-[140px] opacity-20" style="animation:blob 7s infinite alternate ease-in-out"></div>
    <div class="absolute bottom-[-10%] right-[-10%] w-[400px] h-[400px] bg-[#ff5f1f] rounded-full blur-[120px] opacity-20" style="animation:blob 7s infinite alternate ease-in-out;animation-delay:3s"></div>

    <div class="relative z-10 text-center px-4 max-w-2xl mx-auto">

        <!-- Animated headphone icon -->
        <div class="flex justify-center mb-8">
            <div class="relative" style="animation:float-y 3s ease-in-out infinite">
                <svg xmlns="http://www.w3.org/2000/svg" width="120" height="120" viewBox="0 0 24 24" fill="none" stroke="url(#g404)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="drop-shadow-[0_0_30px_rgba(242,13,242,0.8)]">
                    <defs>
                        <linearGradient id="g404" x1="0%" y1="0%" x2="100%" y2="100%">
                            <stop offset="0%" stop-color="#f20df2"/>
                            <stop offset="100%" stop-color="#ff5f1f"/>
                        </linearGradient>
                    </defs>
                    <path d="M3 14h3a2 2 0 0 1 2 2v3a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-7a9 9 0 0 1 18 0v7a2 2 0 0 1-2 2h-1a2 2 0 0 1-2-2v-3a2 2 0 0 1 2-2h3"/>
                </svg>
                <!-- Disco light rings -->
                <div class="absolute inset-0 rounded-full border border-[#f20df2]/30" style="animation:ping 1.5s cubic-bezier(0,0,0.2,1) infinite"></div>
                <div class="absolute inset-[-12px] rounded-full border border-[#ff5f1f]/20" style="animation:ping 1.5s cubic-bezier(0,0,0.2,1) infinite;animation-delay:0.5s"></div>
            </div>
        </div>

        <!-- Glitch 404 -->
        <div class="relative inline-block mb-2">
            <h1 class="text-[10rem] md:text-[14rem] font-black leading-none tracking-tighter" id="glitch-404" style="background:linear-gradient(135deg,#f20df2,#ff5f1f,#ffd700);-webkit-background-clip:text;color:transparent;">404</h1>
        </div>

        <h2 class="text-2xl md:text-4xl font-black text-white uppercase tracking-tight mb-4">
            Ups! Ta strona zgubiła się<br>
            <span class="text-[#f20df2]">na parkiecie 🎧</span>
        </h2>
        <p class="text-gray-400 font-medium mb-10 text-base md:text-lg">
            Strona, której szukasz, tańczy gdzieś w innym wymiarze.<br>
            Może zapodziała się między kanałami?
        </p>

        <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a href="/" class="btn-glow inline-flex items-center gap-3 px-8 py-4 rounded-full font-black text-sm uppercase tracking-widest text-white"
               style="background:#f20df2;box-shadow:0 0 24px rgba(242,13,242,0.55)">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                Wróć do domu
            </a>
            <a href="#rental" class="inline-flex items-center gap-3 px-8 py-4 rounded-full font-black text-sm uppercase tracking-widest text-white border border-white/15 hover:bg-white/5 transition-all">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 9a3 3 0 0 1 0 6v2a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-2a3 3 0 0 1 0-6V7a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2Z"/></svg>
                Zamów ofertę
            </a>
        </div>

        <!-- Fun disco balls decoration -->
        <div class="mt-16 flex justify-center gap-3 opacity-40">
            {% for i in (1..7) %}
            <div class="w-3 h-3 rounded-full" style="background:{% cycle '#f20df2','#ff5f1f','#ffd700','#fff','#f20df2','#00ffd5','#ff5f1f' %};animation:ping 2s ease-in-out infinite;animation-delay:{{ forloop.index | times: 0.2 | append: 's' }}"></div>
            {% endfor %}
        </div>

    </div>

    <style>
        @keyframes glitch {
            0%,100% { clip-path: inset(0 0 0 0); transform: translate(0); }
            10%      { clip-path: inset(10% 0 85% 0); transform: translate(-3px, 1px); }
            20%      { clip-path: inset(50% 0 30% 0); transform: translate(3px, -1px); }
            30%      { clip-path: inset(80% 0 5% 0); transform: translate(-2px, 2px); }
            40%,90%  { clip-path: inset(0 0 0 0); transform: translate(0); }
        }
        #glitch-404::before, #glitch-404::after {
            content: '404';
            position: absolute;
            inset: 0;
            background: linear-gradient(135deg,#f20df2,#ff5f1f,#ffd700);
            -webkit-background-clip: text;
            color: transparent;
        }
        #glitch-404::before {
            animation: glitch 3s infinite;
            animation-delay: 0.1s;
            opacity: 0.7;
            filter: blur(1px);
        }
        #glitch-404::after {
            animation: glitch 3s infinite;
            animation-delay: 0.2s;
            opacity: 0.5;
        }
        #glitch-404 { position: relative; }
    </style>
</section>
