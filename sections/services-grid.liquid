<section class="bg-[#221022] relative overflow-hidden" id="uslugi" style="padding-top: clamp(50px, 6vw, 60px); padding-bottom: clamp(50px, 6vw, 60px);">
    <div class="absolute inset-0 bg-[url('https://grainy-gradients.vercel.app/noise.svg')] opacity-10 pointer-events-none z-10 mix-blend-overlay"></div>

    <div class="absolute inset-0 z-0">
        <div class="absolute inset-0 bg-[#221022]/90 z-10"></div>
        <img
            src="https://images.unsplash.com/photo-1545128485-c400e7702796?q=80&w=1920&auto=format&fit=crop"
            alt="Background vibe"
            class="w-full h-full object-cover opacity-30 mix-blend-color-dodge"
        />
    </div>

    <div class="max-w-7xl mx-auto px-5 relative z-20">
        <div class="mb-16 text-center">
            <div class="flex justify-center">
                <h2 class="text-4xl md:text-6xl font-black text-white uppercase italic tracking-tighter mb-6 group cursor-default">
                    <span class="inline-block transform -rotate-1 group-hover:rotate-0 transition-transform duration-500 origin-bottom-left">
                        {{ section.settings.title | default: 'Nasze' | replace: '[MIASTO]', metaobject.nazwa.value | replace: ' [MIASTO]', '' }}
                    </span>
                    <br class="hidden md:block" />
                    <span class="inline-block text-transparent bg-clip-text bg-gradient-to-r from-[#f20df2] via-[#ff5f1f] to-[#ffd700] transform rotate-2 group-hover:rotate-0 transition-transform duration-500 origin-bottom-right pb-2">
                        {{ section.settings.highlight_text | default: 'Pakiety' }}
                    </span>
                </h2>
            </div>
            <div class="line-glow-scroll w-full h-px mt-6" style="margin-top: 20px !important; height: 1px; width: 100%; background: linear-gradient(to right, transparent, #f20df2, transparent); box-shadow: 0 0 20px rgba(242,13,242,0.8);"></div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-6">
            <!-- PAKIET 1: Mikro Integracja -->
            <div class="group glass-card p-8 rounded-3xl border border-[#f20df2]/40 shadow-[0_0_20px_rgba(242,13,242,0.15)] hover:shadow-[0_0_30px_rgba(242,13,242,0.3)] transition-all duration-500 hover:-translate-y-2 flex flex-col h-full bg-[#221022]">
                <div class="h-full bg-transparent p-0 relative overflow-hidden flex flex-col">
                    <div class="w-12 h-12 glass-card border border-[#f20df2]/40 shadow-[0_0_20px_rgba(242,13,242,0.15)] group-hover:border-[#f20df2]/50 rounded-xl flex items-center justify-center text-[#f20df2] transition-all duration-500 mb-6 group-hover:scale-110">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m7.5 4.27 9 5.15"/><path d="M21 8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16Z"/><path d="m3.3 7 8.7 5 8.7-5"/><path d="M12 22V12"/></svg>
                    </div>
                    <div class="text-[10px] font-bold text-[#f20df2] uppercase tracking-widest mb-2 transition-colors">Pakiet DIY</div>
                    <h3 class="text-2xl font-bold text-white mb-4">Mikro Integracja (Plug&Play)</h3>
                    <p class="text-gray-400 text-sm mb-6 leading-relaxed font-medium group-hover:text-gray-300">
                        Do 25 osób. Najprostsze rozwiązanie dla małych zespołów i biur.
                    </p>
                    <ul class="space-y-4 mb-8 flex-grow">
                        <li class="flex items-start text-sm text-gray-300 font-medium">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[#f20df2] mr-3 flex-shrink-0 mt-0.5"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                            <span>Wysyłka sprzętu kurierem</span>
                        </li>
                        <li class="flex items-start text-sm text-gray-300 font-medium">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[#f20df2] mr-3 flex-shrink-0 mt-0.5"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                            <span>Podłączasz i od razu działa</span>
                        </li>
                    </ul>
                    <div class="mt-auto border-t border-[#f20df2]/40 shadow-[0_0_20px_rgba(242,13,242,0.15)] pt-6 group-hover:border-white/20">
                        <a href="#rental" class="w-full py-4 rounded-xl bg-[#f20df2]/20 text-[#f20df2] border border-[#f20df2]/50 hover:bg-white/20 group-hover:bg-[#f20df2] group-hover:text-white font-bold transition-all flex items-center justify-center gap-2 text-sm uppercase">
                            Wyceń pakiet
                        </a>
                    </div>
                </div>
            </div>

            <!-- PAKIET 2: Standard Corporate -->
            <div class="group glass-card p-8 rounded-3xl border border-[#f20df2]/40 shadow-[0_0_20px_rgba(242,13,242,0.15)] hover:shadow-[0_0_30px_rgba(242,13,242,0.3)] transition-all duration-500 hover:-translate-y-2 flex flex-col h-full bg-[#221022]">
                <div class="h-full bg-transparent p-0 relative overflow-hidden flex flex-col">
                    <div class="absolute top-0 right-0">
                        <span class="bg-[#ff5f1f]/20 text-[#ff5f1f] border border-[#ff5f1f]/50 group-hover:bg-[#ff5f1f] group-hover:text-white transition-colors text-[10px] font-bold px-3 py-1.5 rounded-full uppercase tracking-wider">
                            Popularne
                        </span>
                    </div>
                    <div class="w-12 h-12 glass-card border border-[#f20df2]/40 shadow-[0_0_20px_rgba(242,13,242,0.15)] group-hover:border-[#ff5f1f]/50 rounded-xl flex items-center justify-center text-[#ff5f1f] transition-all duration-500 mb-6 group-hover:scale-110 group-hover:rotate-12">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 14h3a2 2 0 0 1 2 2v3a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-7a9 9 0 0 1 18 0v7a2 2 0 0 1-2 2h-1a2 2 0 0 1-2-2v-3a2 2 0 0 1 2-2h3"/></svg>
                    </div>
                    <div class="text-[10px] font-bold text-gray-500 group-hover:text-[#ff5f1f] uppercase tracking-widest mb-2 transition-colors">Pakiet Średni</div>
                    <h3 class="text-2xl font-bold text-white mb-4">Standard Corporate</h3>
                    <p class="text-gray-400 text-sm mb-6 leading-relaxed font-medium group-hover:text-gray-300">
                        Dla firm 50-150 osób. Dowóz, instalacja i zaplecze muzyczne.
                    </p>
                    <ul class="space-y-4 mb-8 flex-grow">
                        <li class="flex items-start text-sm text-gray-300 font-medium">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-gray-600 group-hover:text-[#ff5f1f] mr-3 flex-shrink-0 mt-0.5"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                            <span>Dowóz i pełne rozłożenie</span>
                        </li>
                        <li class="flex items-start text-sm text-gray-300 font-medium">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-gray-600 group-hover:text-[#ff5f1f] mr-3 flex-shrink-0 mt-0.5"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                            <span>2 Profesjonalnych DJ + playlista</span>
                        </li>
                    </ul>
                    <div class="mt-auto border-t border-[#f20df2]/40 shadow-[0_0_20px_rgba(242,13,242,0.15)] pt-6 group-hover:border-white/20">
                        <a href="#rental" class="w-full py-4 rounded-xl border border-[#f20df2]/40 shadow-[0_0_20px_rgba(242,13,242,0.15)] hover:bg-white/5 group-hover:bg-[#ff5f1f] group-hover:border-[#ff5f1f] text-white font-bold transition-all flex items-center justify-center gap-2 text-sm uppercase">
                            Wyceń pakiet
                        </a>
                    </div>
                </div>
            </div>

            <!-- PAKIET 3: Premium Experience -->
            <div class="group glass-card p-8 rounded-3xl border border-[#f20df2]/40 shadow-[0_0_20px_rgba(242,13,242,0.15)] hover:shadow-[0_0_30px_rgba(242,13,242,0.3)] transition-all duration-500 hover:-translate-y-2 flex flex-col h-full bg-[#221022]">
                <div class="h-full bg-transparent p-0 relative overflow-hidden flex flex-col">
                    <div class="absolute top-0 right-0">
                        <span class="border border-white/20 text-gray-400 group-hover:border-[#ffd700] group-hover:text-[#0a050a] group-hover:bg-[#ffd700] transition-all text-[10px] font-bold px-3 py-1.5 rounded-full uppercase tracking-wider">
                            Full Service
                        </span>
                    </div>
                    <div class="w-12 h-12 glass-card border border-[#f20df2]/40 shadow-[0_0_20px_rgba(242,13,242,0.15)] group-hover:border-[#ffd700]/50 rounded-xl flex items-center justify-center text-[#ffd700] transition-all duration-500 mb-6 group-hover:scale-110">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"/><path d="M5 3v4"/><path d="M19 17v4"/><path d="M3 5h4"/><path d="M17 19h4"/></svg>
                    </div>
                    <div class="text-[10px] font-bold text-gray-500 group-hover:text-[#ffd700] uppercase tracking-widest mb-2 transition-colors">Pakiet WOW</div>
                    <h3 class="text-2xl font-bold text-white mb-4">Premium Experience</h3>
                    <p class="text-gray-400 text-sm mb-6 leading-relaxed font-medium group-hover:text-gray-300">
                        Duże eventy korporacyjne. Pełen rozmach, światło i efekty.
                    </p>
                    <ul class="space-y-4 mb-8 flex-grow">
                        <li class="flex items-start text-sm text-gray-300 font-medium">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-gray-600 group-hover:text-[#ffd700] mr-3 flex-shrink-0 mt-0.5"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                            <span>"Bitwa DJ-ów" (3 DJ-ów na raz)</span>
                        </li>
                        <li class="flex items-start text-sm text-gray-300 font-medium">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-gray-600 group-hover:text-[#ffd700] mr-3 flex-shrink-0 mt-0.5"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                            <span>Obsługa aplikacją, lasery, ciężki dym</span>
                        </li>
                    </ul>
                    <div class="mt-auto border-t border-[#f20df2]/40 shadow-[0_0_20px_rgba(242,13,242,0.15)] pt-6 group-hover:border-white/20">
                        <a href="#rental" class="w-full py-4 rounded-xl border border-[#f20df2]/40 shadow-[0_0_20px_rgba(242,13,242,0.15)] hover:bg-white/5 group-hover:bg-[#ffd700] group-hover:border-[#ffd700] group-hover:text-black text-white font-bold transition-all flex items-center justify-center gap-2 text-sm uppercase">
                            Wyceń pakiet
                        </a>
                    </div>
                </div>
            </div>

            <!-- PAKIET 4: Silent Conference -->
            <div class="group glass-card p-[1px] rounded-3xl border border-[#f20df2]/40 shadow-[0_0_20px_rgba(242,13,242,0.15)] hover:shadow-[0_0_30px_rgba(242,13,242,0.3)] transition-all duration-500 hover:-translate-y-2 flex flex-col h-full bg-[#221022]">
                <div class="h-full bg-transparent rounded-[23px] p-8 relative overflow-hidden flex flex-col">
                    <div class="w-12 h-12 glass-card border border-[#f20df2]/40 shadow-[0_0_20px_rgba(242,13,242,0.15)] group-hover:border-[#3b82f6]/50 rounded-xl flex items-center justify-center text-gray-400 group-hover:text-[#3b82f6] transition-all duration-500 mb-6 group-hover:scale-110">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 22h16a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2H8a2 2 0 0 0-2 2v16a2 2 0 0 1-2 2Zm0 0a2 2 0 0 1-2-2v-9c0-1.1.9-2 2-2h2"/><path d="M18 14h-8"/><path d="M15 18h-5"/><path d="M10 6h8v4h-8V6Z"/></svg>
                    </div>
                    <div class="text-[10px] font-bold text-gray-500 group-hover:text-[#3b82f6] uppercase tracking-widest mb-2 transition-colors">Pakiet Biznesowy</div>
                    <h3 class="text-2xl font-bold text-white mb-4">Silent Conference</h3>
                    <p class="text-gray-400 text-sm mb-6 leading-relaxed font-medium group-hover:text-gray-300">
                        Do profesjonalnych prelekcji, paneli i targów. Idealnie czysty sygnał.
                    </p>
                    <ul class="space-y-4 mb-8 flex-grow">
                        <li class="flex items-start text-sm text-gray-300 font-medium">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-gray-600 group-hover:text-[#3b82f6] mr-3 flex-shrink-0 mt-0.5"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                            <span>Symultaniczne tłumaczenia bez szumów</span>
                        </li>
                        <li class="flex items-start text-sm text-gray-300 font-medium">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-gray-600 group-hover:text-[#3b82f6] mr-3 flex-shrink-0 mt-0.5"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                            <span>Nadajniki stacjonarne na 3 hale równocześnie</span>
                        </li>
                    </ul>
                    <div class="mt-auto border-t border-[#f20df2]/40 shadow-[0_0_20px_rgba(242,13,242,0.15)] pt-6 group-hover:border-white/20">
                        <a href="#rental" class="w-full py-4 rounded-xl border border-[#f20df2]/40 shadow-[0_0_20px_rgba(242,13,242,0.15)] hover:bg-white/5 group-hover:bg-[#3b82f6] group-hover:border-[#3b82f6] group-hover:text-white text-white font-bold transition-all flex items-center justify-center gap-2 text-sm uppercase">
                            Wyceń pakiet
                        </a>
                    </div>
                </div>
            </div>
        </div>    </div>
            
        </div>
    </div>
</section>

{% schema %}
{
  "name": "Services Grid",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Nasze"
    },
    {
      "type": "text",
      "id": "highlight_text",
      "label": "Highlight Text",
      "default": "Pakiety"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Wybierz bazę swojego wydarzenia i skonfiguruj ją w naszym sklepie, aby otrzymać natychmiastową wycenę."
    },
    {
      "type": "url",
      "id": "url_pakiet_a",
      "label": "Link: Pakiet A"
    },
    {
      "type": "url",
      "id": "url_pakiet_b",
      "label": "Link: Pakiet B"
    },
    {
      "type": "url",
      "id": "url_pakiet_c",
      "label": "Link: Pakiet C"
    }
  ],
  "presets": [
    {
      "name": "Services Grid"
    }
  ]
}
{% endschema %}
