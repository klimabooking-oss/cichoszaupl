<section class="bg-[#221022] relative overflow-hidden" id="uslugi" style="padding-top: 60px; padding-bottom: 60px;">
    <div class="section-sep" aria-hidden="true"></div>
    <div class="absolute inset-0 bg-[url('https://grainy-gradients.vercel.app/noise.svg')] opacity-10 pointer-events-none z-10 mix-blend-overlay"></div>

    <div class="absolute inset-0 z-0">
        <div class="absolute inset-0 bg-[#221022]/90 z-10"></div>
        <img
            src="https://images.unsplash.com/photo-1545128485-c400e7702796?q=80&w=1920&auto=format&fit=crop"
            alt="Background vibe"
            class="w-full h-full object-cover opacity-30 mix-blend-color-dodge"
        />
    </div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-20">
        <div class="mb-16 text-center">
            <div class="flex justify-center">
                <h2 class="text-4xl md:text-6xl font-black text-white uppercase italic tracking-tighter mb-6 group cursor-default">
                    <span class="inline-block transform -rotate-1 group-hover:rotate-0 transition-transform duration-500 origin-bottom-left">
                        {{ section.settings.title | default: 'Nasze' }}
                    </span>
                    <br class="hidden md:block" />
                    <span class="inline-block text-transparent bg-clip-text bg-gradient-to-r from-[#f20df2] via-[#ff5f1f] to-[#ffd700] transform rotate-2 group-hover:rotate-0 transition-transform duration-500 origin-bottom-right pb-2">
                        {{ section.settings.highlight_text | default: 'Pakiety' }}
                    </span>
                </h2>
            </div>
            <p class="text-gray-400 max-w-2xl mx-auto text-lg">
                {{ section.settings.description | default: 'Wybierz bazę swojego wydarzenia i skonfiguruj ją w naszym sklepie, aby otrzymać natychmiastową wycenę.' }}
            </p>
            <div class="line-glow-scroll w-full h-[1px] mt-8 bg-gradient-to-r from-transparent via-[#f20df2] to-transparent shadow-[0_0_20px_rgba(242,13,242,0.8)]"></div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            <!-- PAKIET A -->
            <div class="group relative p-[1px] rounded-3xl bg-gradient-to-b from-[#f20df2]/30 to-purple-600/10 hover:from-[#f20df2] hover:to-purple-600 transition-all duration-500 shadow-[0_0_20px_rgba(242,13,242,0.15)] hover:shadow-[0_0_40px_rgba(242,13,242,0.4)] hover:-translate-y-2">
                <div class="h-full bg-[#221022] rounded-[23px] p-8 relative overflow-hidden flex flex-col group-hover:bg-[#221022] transition-colors duration-500">
                    <div class="absolute top-6 right-6">
                        <span class="bg-[#f20df2]/20 text-[#f20df2] border border-[#f20df2]/50 group-hover:bg-[#f20df2] group-hover:text-white transition-colors text-[10px] font-bold px-3 py-1.5 rounded-full uppercase tracking-wider">
                            Najpopularniejszy
                        </span>
                    </div>
                    <div class="w-12 h-12 bg-[#221022] border border-[#f20df2]/30 group-hover:border-[#f20df2]/50 rounded-xl flex items-center justify-center text-[#f20df2] transition-all duration-500 mb-6 group-hover:scale-110">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m7.5 4.27 9 5.15"/><path d="M21 8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16Z"/><path d="m3.3 7 8.7 5 8.7-5"/><path d="M12 22V12"/></svg>
                    </div>
                    <div class="text-xs font-bold text-[#f20df2] uppercase tracking-widest mb-2 transition-colors">Pakiet A — Self-Serve</div>
                    <h3 class="text-3xl font-bold text-white mb-4">Silent Starter Box</h3>
                    <p class="text-gray-400 text-sm mb-8 leading-relaxed font-medium group-hover:text-gray-300">
                        Rozpakuj, odpal, działaj. Optymalne rozwiązanie dla cyklicznych eventów.
                    </p>
                    <ul class="space-y-4 mb-8 flex-grow">
                        <li class="flex items-start text-sm text-gray-300 font-medium">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[#f20df2] mr-3 flex-shrink-0 mt-0.5"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                            <span>Pakiety od 30 słuchawek</span>
                        </li>
                        <li class="flex items-start text-sm text-gray-300 font-medium">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[#f20df2] mr-3 flex-shrink-0 mt-0.5"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                            <span>Konfiguracja w systemie Plug&Play</span>
                        </li>
                    </ul>
                    <div class="mt-auto border-t border-white/10 pt-6 group-hover:border-white/20">
                        <div class="flex items-end gap-2 mb-6">
                            <span class="text-gray-400 text-sm mb-1 font-medium">od</span>
                            <span class="text-4xl font-bold text-white group-hover:text-[#f20df2] transition-colors">890</span>
                            <span class="text-gray-400 text-sm mb-1 font-medium">PLN netto</span>
                        </div>
                        <a href="{{ section.settings.url_pakiet_a }}" class="w-full py-4 rounded-xl bg-[#f20df2]/20 text-[#f20df2] border border-[#f20df2]/50 hover:bg-white/20 group-hover:bg-[#f20df2] group-hover:text-white font-bold transition-all flex items-center justify-center gap-2">
                            Skonfiguruj pakiet 
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" x2="20" y1="21" y2="14"/><line x1="4" x2="20" y1="10" y2="3"/><line x1="12" x2="12" y1="21" y2="10"/><line x1="12" x2="12" y1="3" y2="14"/></svg>
                        </a>
                    </div>
                </div>
            </div>

            <!-- PAKIET B -->
            <div class="group relative p-[1px] rounded-3xl bg-gradient-to-b from-white/10 to-white/5 hover:from-[#ff5f1f] hover:to-orange-600 transition-all duration-500 hover:shadow-[0_0_40px_rgba(255,95,31,0.4)] hover:-translate-y-2">
                <div class="h-full bg-[#221022] rounded-[23px] p-8 relative overflow-hidden flex flex-col group-hover:bg-[#221022] transition-colors duration-500">
                    <div class="w-12 h-12 bg-[#221022] border border-white/10 group-hover:border-[#ff5f1f]/50 rounded-xl flex items-center justify-center text-gray-400 group-hover:text-[#ff5f1f] transition-all duration-500 mb-6 group-hover:scale-110">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 14h3a2 2 0 0 1 2 2v3a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-7a9 9 0 0 1 18 0v7a2 2 0 0 1-2 2h-1a2 2 0 0 1-2-2v-3a2 2 0 0 1 2-2h3"/></svg>
                    </div>
                    <div class="text-xs font-bold text-gray-500 group-hover:text-[#ff5f1f] uppercase tracking-widest mb-2 transition-colors">Pakiet B — Wynajem + Support</div>
                    <h3 class="text-3xl font-bold text-white mb-4">Pro Rental</h3>
                    <p class="text-gray-400 text-sm mb-8 leading-relaxed font-medium group-hover:text-gray-300">
                        Profesjonalny sprzęt z pełnym zapleczem technicznym i zdalną pomocą.
                    </p>
                    <ul class="space-y-4 mb-8 flex-grow">
                        <li class="flex items-start text-sm text-gray-300 font-medium">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-gray-600 group-hover:text-[#ff5f1f] mr-3 flex-shrink-0 mt-0.5"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                            <span>Słuchawki + transmitery (3 kanały)</span>
                        </li>
                    </ul>
                    <div class="mt-auto border-t border-white/10 pt-6 group-hover:border-white/20">
                        <div class="flex items-end gap-2 mb-6">
                            <span class="text-gray-400 text-sm mb-1 font-medium">od</span>
                            <span class="text-4xl font-bold text-white group-hover:text-[#ff5f1f] transition-colors">1 900</span>
                            <span class="text-gray-400 text-sm mb-1 font-medium">PLN netto</span>
                        </div>
                        <a href="{{ section.settings.url_pakiet_b }}" class="w-full py-4 rounded-xl border border-white/10 hover:bg-white/5 group-hover:bg-[#ff5f1f] group-hover:border-[#ff5f1f] text-white font-bold transition-all flex items-center justify-center gap-2">
                            Skonfiguruj pakiet
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" x2="20" y1="21" y2="14"/><line x1="4" x2="20" y1="10" y2="3"/><line x1="12" x2="12" y1="21" y2="10"/><line x1="12" x2="12" y1="3" y2="14"/></svg>
                        </a>
                    </div>
                </div>
            </div>

            <!-- PAKIET C -->
            <div class="group relative p-[1px] rounded-3xl bg-gradient-to-b from-white/10 to-white/5 hover:from-[#ffd700] hover:to-yellow-600 transition-all duration-500 hover:shadow-[0_0_40px_rgba(255,215,0,0.4)] hover:-translate-y-2">
                <div class="h-full bg-[#221022] rounded-[23px] p-8 relative overflow-hidden flex flex-col group-hover:bg-[#221022] transition-colors duration-500">
                    <div class="absolute top-6 right-6">
                        <span class="border border-white/20 text-gray-400 group-hover:border-[#ffd700] group-hover:text-[#ffd700] group-hover:bg-[#ffd700]/10 transition-all text-[10px] font-bold px-3 py-1.5 rounded-full uppercase tracking-wider">
                            Premium
                        </span>
                    </div>
                    <div class="w-12 h-12 bg-[#221022] border border-white/10 group-hover:border-[#ffd700]/50 rounded-xl flex items-center justify-center text-gray-400 group-hover:text-[#ffd700] transition-all duration-500 mb-6 group-hover:scale-110">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"/><path d="M5 3v4"/><path d="M19 17v4"/><path d="M3 5h4"/><path d="M17 19h4"/></svg>
                    </div>
                    <div class="text-xs font-bold text-gray-500 group-hover:text-[#ffd700] uppercase tracking-widest mb-2 transition-colors">Pakiet C — Full Service</div>
                    <h3 class="text-3xl font-bold text-white mb-4">Full Service</h3>
                    <p class="text-gray-400 text-sm mb-8 leading-relaxed font-medium group-hover:text-gray-300">
                        Kompleksowa realizacja eventu z obsługą na miejscu. My dbamy o detale.
                    </p>
                    <ul class="space-y-4 mb-8 flex-grow">
                        <li class="flex items-start text-sm text-gray-300 font-medium">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-gray-600 group-hover:text-[#ffd700] mr-3 flex-shrink-0 mt-0.5"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                            <span>Obsługa DJ i techniczna na miejscu</span>
                        </li>
                    </ul>
                    <div class="mt-auto border-t border-white/10 pt-6 group-hover:border-white/20">
                        <div class="flex items-end gap-2 mb-6">
                            <span class="text-gray-400 text-sm mb-1 font-medium">od</span>
                            <span class="text-4xl font-bold text-white group-hover:text-[#ffd700] transition-colors">4 900</span>
                            <span class="text-gray-400 text-sm mb-1 font-medium">PLN netto</span>
                        </div>
                        <a href="{{ section.settings.url_pakiet_c }}" class="w-full py-4 rounded-xl border border-white/10 hover:bg-white/5 group-hover:bg-[#ffd700] group-hover:border-[#ffd700] group-hover:text-black text-white font-bold transition-all flex items-center justify-center gap-2">
                            Skonfiguruj event
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" x2="20" y1="21" y2="14"/><line x1="4" x2="20" y1="10" y2="3"/><line x1="12" x2="12" y1="21" y2="10"/><line x1="12" x2="12" y1="3" y2="14"/></svg>
                        </a>
                    </div>
                </div>
            </div>
            
        </div>
    </div>
</section>

{% schema %}
{
  "name": "Services Grid",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Nasze"
    },
    {
      "type": "text",
      "id": "highlight_text",
      "label": "Highlight Text",
      "default": "Pakiety"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Wybierz bazę swojego wydarzenia i skonfiguruj ją w naszym sklepie, aby otrzymać natychmiastową wycenę."
    },
    {
      "type": "url",
      "id": "url_pakiet_a",
      "label": "Link: Pakiet A"
    },
    {
      "type": "url",
      "id": "url_pakiet_b",
      "label": "Link: Pakiet B"
    },
    {
      "type": "url",
      "id": "url_pakiet_c",
      "label": "Link: Pakiet C"
    }
  ],
  "presets": [
    {
      "name": "Services Grid"
    }
  ]
}
{% endschema %}
