<section class="bg-[#221022]" id="custom-technology-{{ section.id }}" style="padding-top: clamp(50px, 6vw, 60px); padding-bottom: clamp(50px, 6vw, 60px);">
    <div class="max-w-7xl mx-auto px-5">
        <div class="flex flex-col justify-center items-center md:flex-row md:items-stretch gap-12 w-full mx-auto p-8 lg:p-12 rounded-[2rem] glass-card border border-[#f20df2]/40 shadow-[0_0_20px_rgba(242,13,242,0.15)] relative overflow-hidden group">
            <!-- Tło do hovera -->
            <div class="absolute inset-0 bg-[#f20df2]/5 opacity-0 group-hover:opacity-100 transition-opacity duration-700 pointer-events-none"></div>
            
            <div class="w-full md:w-1/2 lg:w-5/12 mx-auto relative aspect-square rounded-2xl overflow-hidden border border-[#f20df2]/40 shadow-[0_0_30px_rgba(242,13,242,0.15)] bg-background-dark flex items-center justify-center">
            {% if section.settings.tech_video != blank %}
                <video
                    class="absolute inset-0 w-full h-full object-cover object-center filter brightness-90 group-hover:brightness-100 transition-all duration-700"
                    style="width: 100% !important; height: 100% !important; object-fit: cover !important; object-position: center !important; position: absolute !important; top: 0 !important; left: 0 !important; margin: 0 !important; padding: 0 !important;"
                    autoplay loop muted playsinline preload="auto"
                >
                    {% for source in section.settings.tech_video.sources %}
                        <source src="{{ source.url }}" type="video/{{ source.format }}">
                    {% endfor %}
                </video>
            {% elsif section.settings.tech_image != blank %}
                <img
                    src="{{ section.settings.tech_image | image_url: width: 800, format: 'webp' }}"
                    alt="{{ section.settings.title | escape }}"
                    class="absolute inset-0 w-full h-full object-cover object-center filter brightness-90 group-hover:brightness-100 transition-all duration-700"
                    style="width: 100% !important; height: 100% !important; object-fit: cover !important; object-position: center !important; position: absolute !important; top: 0 !important; left: 0 !important;"
                    loading="lazy"
                />
            {% else %}
                <!-- Placeholder -->
                <div class="absolute inset-0 bg-[url('https://images.unsplash.com/photo-1510520614131-0df0b2dede1d?q=80&w=800&auto=format&fit=crop')] bg-cover bg-center filter brightness-50 group-hover:brightness-75 transition-all duration-700"></div>
            {% endif %}
            
            {% if section.settings.tech_video == blank %}
                <!-- Play button visible only if it's an image/placeholder just as a decoration -->
                <button class="relative z-10 w-20 h-20 rounded-full bg-[#f20df2]/20 border border-[#f20df2] text-[#f20df2] flex items-center justify-center hover:bg-[#f20df2] hover:text-white transition-all hover:scale-110 shadow-[0_0_40px_rgba(242,13,242,0.4)] backdrop-blur-md">
                    <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="ml-2"><polygon points="6 3 20 12 6 21 6 3"/></svg>
                </button>
            {% endif %}
            
            <!-- Etykieta 3D -->
            <span class="absolute top-4 left-4 bg-black/60 backdrop-blur px-3 py-1 rounded-full text-xs font-bold text-white border border-white/20 uppercase tracking-widest flex items-center gap-2 z-20">
                <span class="w-2 h-2 rounded-full bg-[#f20df2] animate-pulse"></span> 3D Render
            </span>
        </div>

        <div class="w-full md:w-1/2 lg:w-7/12 relative z-10 flex flex-col justify-center">
            {% assign title_words = section.settings.title | split: ' ' %}
            {% assign first_word = title_words | first %}
            {% assign rest_words = section.settings.title | remove_first: first_word | strip %}
            <div class="mt-4 mb-6">
                <h2 class="text-4xl md:text-6xl font-black text-white uppercase italic tracking-tighter group cursor-default">
                    <span class="inline-block transform -rotate-1 group-hover:rotate-0 transition-transform duration-500 origin-bottom-left">
                        {{ first_word }}
                    </span>
                    <br class="hidden md:block" />
                    <span class="inline-block text-transparent bg-clip-text bg-gradient-to-r from-[#f20df2] to-[#ff5f1f] transform rotate-2 group-hover:rotate-0 transition-transform duration-500 origin-bottom-right pb-2">
                        {{ rest_words }}
                    </span>
                </h2>
                <div class="line-glow-scroll w-full h-px mt-[18px] style="background: linear-gradient(to right, transparent, #f20df2, transparent); box-shadow: 0 0 20px rgba(242,13,242,0.8);"></div>
            </div>
            <div class="text-gray-300 text-lg mb-8 leading-relaxed">
                {{ section.settings.description | newline_to_br }}
            </div>
            
            {% if section.settings.button_label != blank %}
            <div class="flex flex-col sm:flex-row gap-4">
                <a href="#rental-products-produkty" class="inline-flex items-center justify-center gap-3 px-8 py-4 bg-white/5 border border-white/20 rounded-xl hover:bg-white/10 hover:border-white/40 transition-all text-white font-bold text-sm tracking-widest uppercase cursor-pointer">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14"/><path d="m19 12-7 7-7-7"/></svg>
                    {{ section.settings.button_label }}
                </a>
            </div>
            {% endif %}
        </div>
        </div>
    </div>
</section>

{% schema %}
{
  "name": "Technologia (PDF)",
  "settings": [
    {
      "type": "video",
      "id": "tech_video",
      "label": "Film 3D Render (mp4)"
    },
    {
      "type": "image_picker",
      "id": "tech_image",
      "label": "Zdjęcie (Zastępcze)"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Mały nagłówek",
      "default": "Poznaj sprzęt"
    },
    {
      "type": "html",
      "id": "title",
      "label": "Główny Nagłówek (można użyć <span> dla kolorów)",
      "default": "Technologia <br/><span class=\"text-transparent bg-clip-text bg-gradient-to-r from-[#f20df2] to-[#ff5f1f]\">Silent Disco</span>"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Opis",
      "default": "Nasze słuchawki to nie tylko rewelacyjny design, ale przede wszystkim genialna izolacja akustyczna i czysty przekaz audio na 3 niezależnych kanałach. Zobacz z bliska, co zamawiasz."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Tekst Przycisku",
      "default": "Dowiedz się więcej"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Link Przycisku (np. widok PDF)"
    }
  ],
  "presets": [
    {
      "name": "Technologia (PDF)"
    }
  ]
}
{% endschema %}
