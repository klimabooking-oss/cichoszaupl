<section class="min-h-[90vh] bg-background-dark relative overflow-hidden" id="city-landing">
    
    <!-- Hero Section -->
    <div class="relative min-h-[90vh] flex items-center overflow-hidden">
        
        <!-- === WARSTWA 1: Gradient fioletowy (najniżej) === -->
        <div class="absolute inset-0 pointer-events-none" style="z-index: 0;">
            <div class="absolute inset-0 bg-gradient-to-r from-[#221022] via-[#221022]/90 to-[#221022]/30"></div>
        </div>

        <!-- === WARSTWA 2: Film / Zdjęcie (po prawej, za napisami) === -->
        {% if section.settings.hero_video != blank %}
            <div class="absolute inset-0 pointer-events-none" style="z-index: 10;">
                <div class="absolute inset-0 bg-gradient-to-r from-[#221022] via-[#221022]/70 to-transparent" style="z-index: 20;"></div>
                <video
                    class="absolute inset-0 w-full h-full object-cover"
                    autoplay loop muted playsinline preload="auto"
                    style="opacity: 0.85; z-index: 10;"
                >
                    {% for source in section.settings.hero_video.sources %}
                        <source src="{{ source.url }}" type="video/{{ source.format }}">
                    {% endfor %}
                </video>
            </div>
        {% elsif section.settings.hero_image != blank %}
            <div class="absolute inset-0 pointer-events-none" style="z-index: 10;">
                <div class="absolute inset-0 bg-gradient-to-r from-[#221022] via-[#221022]/70 to-transparent" style="z-index: 20;"></div>
                <img
                    src="{{ section.settings.hero_image | image_url: width: 1920, format: 'webp' }}"
                    alt="{{ metaobject.nazwa.value | default: 'Wynajem Słuchawek' }}"
                    class="absolute inset-0 w-full h-full object-cover"
                    style="opacity: 0.85; z-index: 10;"
                    loading="eager"
                    fetchpriority="high"
                />
            </div>
        {% else %}
            <!-- Fallback Image -->
            <div class="absolute inset-0 pointer-events-none" style="z-index: 10;">
                <div class="absolute inset-0 bg-gradient-to-r from-[#221022] via-[#221022]/70 to-transparent" style="z-index: 20;"></div>
                <img src="https://images.unsplash.com/photo-1556761175-5973dc0f32e7?q=80&w=1920&auto=format&fit=crop" class="absolute inset-0 w-full h-full object-cover" style="opacity: 0.85; z-index: 10;" />
            </div>
        {% endif %}

        <!-- === WARSTWA 3: Treść (napisów i przycisk po lewej) === -->
        <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 w-full py-24 flex items-center" style="z-index: 30;">
            <div class="w-full max-w-2xl" data-animate="fade-up">
                <span class="inline-block px-4 py-2 rounded-full bg-yellow-400/20 text-yellow-400 border border-yellow-400/50 font-bold uppercase tracking-widest text-sm mb-6 animate-fade-in-up">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="inline-block mr-2 -mt-1"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg> Strefa Dostaw
                </span>
                
                <h1 class="text-4xl sm:text-5xl md:text-7xl lg:text-8xl font-black text-white mb-4 uppercase italic leading-none animate-fade-in-up md:delay-100 flex flex-col items-start">
                    <span class="text-sm md:text-base text-gray-300 font-bold tracking-widest uppercase mb-4 not-italic font-sans">Profesjonalny Wynajem Słuchawek</span>
                    <span>Silent Disco</span>
                    <span class="text-transparent bg-clip-text bg-gradient-to-r from-[#f20df2] via-[#ff5f1f] to-[#ffd700]">{{ metaobject.nazwa.value }}</span>
                </h1>
                
                <p class="text-xl md:text-2xl text-gray-300 font-medium mb-12 leading-relaxed animate-fade-in-up md:delay-200 max-w-xl">
                    {{ metaobject.krotki_opis.value | default: 'Wynajem bezprzewodowych słuchawek z szybką dostawą kurierską prosto pod Twoje drzwi.' }}
                </p>
                
                <button
                    onclick="document.getElementById('kalkulator')?.scrollIntoView({ behavior: 'smooth' })"
                    class="inline-flex items-center justify-center px-12 py-5 bg-[#f20df2] text-white font-black text-lg uppercase tracking-wider rounded-full shadow-[0_0_40px_rgba(242,13,242,0.4)] hover:scale-105 transition-transform gap-3 animate-fade-in-up md:delay-300"
                >
                    Sprawdź Cennik i Zamów
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" x2="11" y1="2" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
                </button>
            </div>
        </div>
    </div>

    <!-- Reszta zawartości na dole (Boxy itp) -->
    <div class="relative z-20 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

        <!-- 3 Info Boxy (Czas dostawy, Ilość słuchawek itp) -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-24 max-w-5xl mx-auto" data-animate-stagger="fade-up">
            <div class="p-8 rounded-3xl bg-white/[0.02] border border-white/5 backdrop-blur-sm flex flex-col items-center text-center group hover:bg-[#f20df2]/5 hover:border-[#f20df2]/20 transition-all duration-300">
                <div class="w-16 h-16 rounded-full bg-[#f20df2]/10 flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
                    <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#f20df2" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 18H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h3.2a2 2 0 0 1 1.93 1.46l1.37 5.08A2 2 0 0 0 11.43 14h5.14a2 2 0 0 0 1.93-1.46l1.37-5.08A2 2 0 0 1 21.8 6H24"/><circle cx="8" cy="18" r="2"/><circle cx="19" cy="18" r="2"/></svg>
                </div>
                <h3 class="text-white font-black text-xl mb-2 tracking-wide uppercase">Dostawa Kurierska</h3>
                <p class="text-[#f20df2] font-black text-lg mb-2">{{ metaobject.czas_dostawy.value | default: 'Sprawnie i bezpiecznie' }}</p>
                <p class="text-gray-400 text-sm">Przesyłki obsługiwane przez sprawdzone firmy kurierskie (DPD/DHL).</p>
            </div>

            <div class="p-8 rounded-3xl bg-white/[0.02] border border-white/5 backdrop-blur-sm flex flex-col items-center text-center group hover:bg-[#ff5f1f]/5 hover:border-[#ff5f1f]/20 transition-all duration-300">
                <div class="w-16 h-16 rounded-full bg-[#ff5f1f]/10 flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
                    <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#ff5f1f" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
                </div>
                <h3 class="text-white font-black text-xl mb-2 tracking-wide uppercase">Elastyczny Zasięg</h3>
                <p class="text-[#ff5f1f] font-black text-lg mb-2">{{ metaobject.nazwa.value }} i okolice</p>
                <p class="text-gray-400 text-sm">Wynajmujemy sprzęt na terenie miasta, przedmieść oraz całej Polski.</p>
            </div>

            <div class="p-8 rounded-3xl bg-white/[0.02] border border-white/5 backdrop-blur-sm flex flex-col items-center text-center group hover:bg-[#ffd700]/5 hover:border-[#ffd700]/20 transition-all duration-300">
                <div class="w-16 h-16 rounded-full bg-[#ffd700]/10 flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
                    <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#ffd700" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 9a3 3 0 0 1 0 6v2a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-2a3 3 0 0 1 0-6V7a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2Z"/></svg>
                </div>
                <h3 class="text-white font-black text-xl mb-2 tracking-wide uppercase">Ilość Słuchawek</h3>
                <p class="text-[#ffd700] font-black text-lg mb-2">{{ metaobject.liczba_sluchawek.value | default: 'Dowolna ilość' }}</p>
                <p class="text-gray-400 text-sm">Zapewniamy sprzęt na domówki jak i masowe imprezy plenerowe.</p>
            </div>
        </div>

        <!-- Usunięty główny tekst SEO z tego miejsca - przeniesiony na dół pliku pod lejek -->

        <!-- Sekcja Technologiczna: Sprzęt 3D i PDF -->
        <div class="mt-20 mb-20">
            <div class="flex flex-col lg:flex-row items-center gap-12 max-w-6xl mx-auto p-8 lg:p-12 rounded-[2rem] bg-gradient-to-br from-white/5 to-transparent border border-white/10 shadow-2xl relative overflow-hidden group">
                <!-- Tło do hovera -->
                <div class="absolute inset-0 bg-[#f20df2]/5 opacity-0 group-hover:opacity-100 transition-opacity duration-700 pointer-events-none"></div>
                
                <div class="w-full lg:w-1/2 relative aspect-video sm:aspect-[4/3] rounded-2xl overflow-hidden border border-white/10 shadow-[0_0_30px_rgba(242,13,242,0.15)] bg-background-dark flex items-center justify-center">
                    {% if section.settings.tech_video != blank %}
                        <video
                            class="absolute inset-0 w-full h-full object-cover filter brightness-75 group-hover:brightness-100 transition-all duration-700"
                            autoplay loop muted playsinline preload="auto"
                        >
                            {% for source in section.settings.tech_video.sources %}
                                <source src="{{ source.url }}" type="video/{{ source.format }}">
                            {% endfor %}
                        </video>
                    {% elsif section.settings.tech_image != blank %}
                        <img
                            src="{{ section.settings.tech_image | image_url: width: 800, format: 'webp' }}"
                            alt="Technologia Silent Disco"
                            class="absolute inset-0 w-full h-full object-cover filter brightness-50 group-hover:brightness-75 transition-all duration-700"
                            loading="lazy"
                        />
                    {% else %}
                        <!-- Placeholder -->
                        <div class="absolute inset-0 bg-[url('https://images.unsplash.com/photo-1510520614131-0df0b2dede1d?q=80&w=800&auto=format&fit=crop')] bg-cover bg-center filter brightness-50 group-hover:brightness-75 transition-all duration-700"></div>
                    {% endif %}
                    
                    {% if section.settings.tech_video == blank %}
                        <!-- Play button visible only if it's an image/placeholder just as a decoration -->
                        <button class="relative z-10 w-20 h-20 rounded-full bg-[#f20df2]/20 border border-[#f20df2] text-[#f20df2] flex items-center justify-center hover:bg-[#f20df2] hover:text-white transition-all hover:scale-110 shadow-[0_0_40px_rgba(242,13,242,0.4)] backdrop-blur-md">
                            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="ml-2"><polygon points="6 3 20 12 6 21 6 3"/></svg>
                        </button>
                    {% endif %}
                    
                    <!-- Etykieta 3D -->
                    <span class="absolute top-4 left-4 bg-black/60 backdrop-blur px-3 py-1 rounded-full text-xs font-bold text-white border border-white/20 uppercase tracking-widest flex items-center gap-2 z-20">
                        <span class="w-2 h-2 rounded-full bg-[#f20df2] animate-pulse"></span> 3D Render
                    </span>
                </div>

                <div class="w-full lg:w-1/2">
                    <span class="text-[#f20df2] font-black uppercase tracking-widest text-sm mb-2 block border-l-2 border-[#f20df2] pl-3">Poznaj sprzęt</span>
                    <h2 class="text-3xl md:text-5xl font-black text-white italic tracking-tighter mb-6">
                        Technologia <br/>
                        <span class="text-transparent bg-clip-text bg-gradient-to-r from-[#f20df2] to-[#ff5f1f]">Silent Disco</span>
                    </h2>
                    <p class="text-gray-300 text-lg mb-8 leading-relaxed">
                        Nasze słuchawki to nie tylko rewelacyjny design, ale przede wszystkim genialna izolacja akustyczna i czysty przekaz audio na 3 niezależnych kanałach. Zobacz z bliska, co zamawiasz.
                    </p>
                    
                    <div class="flex flex-col sm:flex-row gap-4">
                        <a href="#" target="_blank" class="inline-flex items-center justify-center gap-3 px-8 py-4 bg-white/5 border border-white/20 rounded-xl hover:bg-white/10 hover:border-white/40 transition-all text-white font-bold text-sm tracking-widest uppercase">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/></svg>
                            Pobierz PDF (Specyfikacja)
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Sekcja Cross-Selling (Alternatywa - Pakiet z DJ) -->
        <div class="mb-24 mt-12">
            <div class="max-w-6xl mx-auto bg-[#ff5f1f] rounded-[2rem] p-8 md:p-14 relative overflow-hidden group">
                <!-- Tło SVG/Gradient -->
                <div class="absolute inset-0 bg-[url('https://grainy-gradients.vercel.app/noise.svg')] opacity-20 pointer-events-none mix-blend-overlay"></div>
                <!-- Animowana plama na hover -->
                <div class="absolute -right-20 -bottom-20 w-96 h-96 bg-[#ffd700] rounded-full filter blur-[100px] opacity-0 group-hover:opacity-40 transition-opacity duration-1000 z-0"></div>

                <div class="relative z-10 flex flex-col md:flex-row items-center justify-between gap-10">
                    <div class="md:w-2/3">
                        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-black/20 text-white text-[10px] font-black uppercase tracking-widest mb-6 border border-white/10">
                            🔥 Rozszerzenie Pakietu
                        </div>
                        <h2 class="text-4xl md:text-5xl font-black text-white italic tracking-tighter mb-4 leading-none">
                            Impreza na gotowo? <br/>
                            <span class="text-black">Zatrudnij naszego DJ-a!</span>
                        </h2>
                        <p class="text-white/90 text-lg md:text-xl font-medium max-w-2xl leading-relaxed">
                            Nie wiesz, jaka muzyka sprawdzi się najlepiej, albo nie masz sprzętu konsoletowego? Załatwimy to kompleksowo. Nasi DJe rozkręcili już setki imprez silent disco. Dojeżdżamy do miasta: {{ metaobject.nazwa.value }}.
                        </p>
                    </div>
                    
                    <div class="md:w-1/3 w-full flex justify-center md:justify-end">
                        <a href="/pages/kontakt" class="px-10 py-5 bg-[#221022] text-white font-black text-sm uppercase tracking-widest rounded-full hover:scale-105 hover:bg-black transition-all shadow-xl whitespace-nowrap">
                            Wyślij zapytanie
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Przeniesiony z góry Główny Tekst SEO dla Google (Teraz na samym dole ekranu) -->
        {% if metaobject.tekst_seo.value != blank %}
        <div class="max-w-4xl mx-auto mt-20 mb-32 relative" id="tekst-seo" data-animate="fade-up">
            
            <div class="text-center mb-10">
                <span class="text-[#f20df2] font-black uppercase tracking-widest text-xs mb-3 inline-block">Poznaj swoje miasto</span>
                <h2 class="text-3xl md:text-5xl font-black text-white italic tracking-tighter">
                    Dlaczego warto z nami <br/>
                    <span class="text-transparent bg-clip-text bg-gradient-to-r from-[#f20df2] to-[#ff5f1f]">imprezować?</span>
                </h2>
            </div>

            <div class="p-8 md:p-14 rounded-[2.5rem] bg-[#221022]/80 border border-white/10 relative overflow-hidden shadow-[0_20px_50px_rgba(0,0,0,0.5)] backdrop-blur-xl group">
                <!-- Dekoracyjne tło pod tekstem -->
                <div class="absolute -top-40 -right-40 w-96 h-96 bg-[#f20df2] rounded-full mix-blend-screen filter blur-[120px] opacity-10 group-hover:opacity-20 transition-opacity duration-1000 z-0"></div>
                <div class="absolute -bottom-40 -left-40 w-96 h-96 bg-[#ff5f1f] rounded-full mix-blend-screen filter blur-[120px] opacity-10 group-hover:opacity-20 transition-opacity duration-1000 z-0"></div>
                
                <div class="absolute top-0 left-0 w-full h-1" style="background: linear-gradient(90deg, #f20df2, #ff5f1f, #ffd700);"></div>
                
                <!-- Formatowanie HTML w zalanym tekście SEO (Tailwind Typography) -->
                <div class="relative z-10 prose prose-invert prose-lg max-w-none 
                            prose-headings:font-black prose-headings:tracking-tight prose-headings:text-transparent prose-headings:bg-clip-text prose-headings:bg-gradient-to-r prose-headings:from-white prose-headings:to-gray-400 prose-headings:mb-6 prose-headings:mt-12
                            prose-h2:text-4xl prose-h3:text-2xl 
                            prose-p:text-gray-300 prose-p:leading-relaxed prose-p:mb-8
                            prose-strong:text-white prose-strong:font-bold prose-strong:bg-white/5 prose-strong:px-1 prose-strong:rounded
                            prose-ul:list-none prose-ul:pl-0 prose-ul:space-y-4
                            prose-li:flex prose-li:items-start prose-li:text-gray-300
                            marker:text-[#f20df2]
                            prose-a:text-[#f20df2] prose-a:font-bold prose-a:no-underline hover:prose-a:text-[#ff5f1f] transition-all
                            text-[1.1rem]">
                    
                    {{ metaobject.tekst_seo.value | replace: '<ul>', '<ul class="space-y-4 my-8">' | replace: '<li>', '<li class="flex items-start gap-4 p-4 rounded-2xl bg-white/5 border border-white/5 hover:border-[#f20df2]/30 transition-colors"><div class="text-[#f20df2] mt-1 shrink-0"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg></div><span class="block">' | replace: '</li>', '</span></li>' }}
                </div>
            </div>
        </div>
        {% endif %}

    </div>
    
    <!-- Pływający przycisk Sticky CTA (Pojawia się tylko na małych i średnich ekranach dla wygody) -->
    <div class="fixed bottom-6 left-0 right-0 z-50 flex justify-center px-4 pointer-events-none md:hidden">
        <a href="#kalkulator" class="pointer-events-auto w-full max-w-md inline-flex items-center justify-center px-8 py-4 text-sm font-black tracking-widest text-[#0a050a] uppercase bg-gradient-to-r from-[#f20df2] via-[#ff5f1f] to-[#ffd700] rounded-full shadow-[0_10px_40px_rgba(242,13,242,0.5)] border border-white/20 animate-bounce transition-all">
            Wyceń wynajem w {{ metaobject.nazwa.value }}
        </a>
    </div>
</section>

<!-- JSON-LD LocalBusiness dla Local SEO -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "RentalService",
  "name": "Wynajem Silent Disco {{ metaobject.nazwa.value }} - Cichoszau",
  "image": "https://cichoszau.pl/cdn/shop/files/cichoszau-og.png",
  "@id": "{{ shop.url }}/pages/miasto/{{ metaobject.system.handle }}",
  "url": "{{ shop.url }}/pages/miasto/{{ metaobject.system.handle }}",
  "telephone": "+48 500 000 000",
  "priceRange": "$$",
  "areaServed": {
    "@type": "City",
    "name": "{{ metaobject.nazwa.value }}"
  },
  "description": "{{ metaobject.krotki_opis.value | strip_html | escape }}",
  "provider": {
    "@type": "Organization",
    "name": "Cichoszau",
    "url": "https://cichoszau.pl"
  }
}
</script>

{% schema %}
{
  "name": "City Landing Page SEO",
  "settings": [
    {
      "type": "header",
      "content": "Tło Hero (Film / Zdjęcie)"
    },
    {
      "type": "video",
      "id": "hero_video",
      "label": "Film w tle Hero (mp4)"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Zdjęcie w tle Hero (fallback)"
    },
    {
      "type": "header",
      "content": "Sekcja Technologiczna (3D Render)"
    },
    {
      "type": "video",
      "id": "tech_video",
      "label": "Film produktu 3D (mp4)"
    },
    {
      "type": "image_picker",
      "id": "tech_image",
      "label": "Zdjęcie produktu (fallback dla 3D)"
    }
  ],
  "presets": [
    {
      "name": "City Landing Page SEO"
    }
  ]
}
{% endschema %}
