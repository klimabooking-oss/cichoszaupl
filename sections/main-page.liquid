<section class="bg-[#221022] min-h-screen border-t border-white/5" id="main-page" style="padding-top: 15px; padding-bottom: 15px;">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        
        <div class="text-center mb-16">
            <h1 class="text-4xl md:text-6xl font-black text-white uppercase italic tracking-tighter mb-6">
                {{ page.title }}
            </h1>
            <div class="w-24 h-1 bg-gradient-to-r from-[#f20df2] to-[#ff5f1f] mx-auto rounded-full"></div>
        </div>

        <div class="prose prose-lg prose-invert max-w-none text-gray-300 leading-relaxed bg-[#221022]/50 backdrop-blur-md border border-white/5 rounded-3xl p-8 md:p-12 shadow-2xl">
            {{ page.content }}
        </div>

    </div>
</section>

{% schema %}
{
  "name": "Main Page",
  "settings": []
}
{% endschema %}
