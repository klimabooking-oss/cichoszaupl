<section class="bg-[#221022] min-h-screen border-t border-[#f20df2]/40 shadow-[0_0_20px_rgba(242,13,242,0.15)]" id="main-page" style="padding-top: clamp(50px, 6vw, 60px); padding-bottom: clamp(50px, 6vw, 60px);">
    <div class="max-w-4xl mx-auto px-5">
        
        <div class="text-center mb-16">
            <h1 class="text-4xl md:text-6xl font-black text-white uppercase italic tracking-tighter mb-6">
                {{ page.title }}
            </h1>
            <div class="w-24 h-1 bg-gradient-to-r from-[#f20df2] to-[#ff5f1f] mx-auto rounded-full"></div>
        </div>

        <div class="prose prose-lg prose-invert max-w-none text-gray-300 leading-relaxed bg-[#221022]/50 backdrop-blur-md border border-[#f20df2]/40 shadow-[0_0_20px_rgba(242,13,242,0.15)] rounded-3xl p-8 md:p-12 shadow-2xl">
            {{ page.content }}
        </div>

    </div>
</section>

{% schema %}
{
  "name": "Main Page",
  "settings": []
}
{% endschema %}
