<section class="min-h-screen bg-[#221022] relative overflow-hidden" id="service-landing-{{ section.id }}" style="padding-top: 15px; padding-bottom: 15px;">

    <!-- Hero Section -->
    <div class="relative min-h-[90vh] flex items-center overflow-hidden">
        
        <!-- === WARSTWA 1: Gradient fioletowy (najniżej) === -->
        <div class="absolute inset-0 pointer-events-none" style="z-index: 0;">
            <div class="absolute inset-0 bg-gradient-to-r from-[#221022] via-[#221022]/90 to-[#221022]/30"></div>
        </div>

        <!-- === WARSTWA 2: Film / Zdjęcie (po prawej, za napisami) === -->
        {% if section.settings.hero_video != blank %}
            <div class="absolute inset-0 pointer-events-none" style="z-index: 10;">
                <div class="absolute inset-0 bg-gradient-to-r from-[#221022] via-[#221022]/70 to-transparent" style="z-index: 20;"></div>
                <video
                    class="absolute inset-0 w-full h-full object-cover"
                    autoplay loop muted playsinline preload="auto"
                    style="opacity: 0.85; z-index: 10;"
                >
                    {% for source in section.settings.hero_video.sources %}
                        <source src="{{ source.url }}" type="video/{{ source.format }}">
                    {% endfor %}
                </video>
            </div>
        {% elsif section.settings.hero_image != blank %}
            <div class="absolute inset-0 pointer-events-none" style="z-index: 10;">
                <div class="absolute inset-0 bg-gradient-to-r from-[#221022] via-[#221022]/70 to-transparent" style="z-index: 20;"></div>
                <img
                    src="{{ section.settings.hero_image | image_url: width: 1920, format: 'webp' }}"
                    alt="{{ section.settings.title }}"
                    class="absolute inset-0 w-full h-full object-cover"
                    style="opacity: 0.85; z-index: 10;"
                    loading="eager"
                    fetchpriority="high"
                />
            </div>
        {% else %}
            <!-- Fallback Image -->
            <div class="absolute inset-0 pointer-events-none" style="z-index: 10;">
                <div class="absolute inset-0 bg-gradient-to-r from-[#221022] via-[#221022]/70 to-transparent" style="z-index: 20;"></div>
                <img src="https://images.unsplash.com/photo-1556761175-5973dc0f32e7?q=80&w=1920&auto=format&fit=crop" class="absolute inset-0 w-full h-full object-cover" style="opacity: 0.85; z-index: 10;" />
            </div>
        {% endif %}

        <!-- === WARSTWA 3: Treść (napisów i przycisk po lewej) === -->
        <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 w-full py-24 flex items-center" style="z-index: 30;">
            <div class="w-full max-w-2xl" data-animate="fade-up">
                <span class="inline-block px-4 py-2 rounded-full bg-yellow-400/20 text-yellow-400 border border-yellow-400/50 font-bold uppercase tracking-widest text-sm mb-6 animate-fade-in-up">
                    Oferta Specjalna
                </span>
                
                <h1 class="text-4xl sm:text-5xl md:text-7xl lg:text-8xl font-black text-white mb-4 uppercase italic leading-none animate-fade-in-up md:delay-100">
                    {{ section.settings.title | default: page.title }}
                </h1>
                
                <p class="text-xl md:text-2xl text-gray-300 font-medium mb-12 leading-relaxed animate-fade-in-up md:delay-200 max-w-xl">
                    {{ section.settings.subtitle | default: 'Rozwiązania dopasowane do Twoich potrzeb.' }}
                </p>
                
                <button
                    onclick="document.getElementById('rental')?.scrollIntoView({ behavior: 'smooth' })"
                    class="inline-flex items-center justify-center px-12 py-5 bg-[#f20df2] text-white font-black text-lg uppercase tracking-wider rounded-full shadow-[0_0_40px_rgba(242,13,242,0.4)] hover:scale-105 transition-transform gap-3 animate-fade-in-up md:delay-300"
                >
                    {{ section.settings.cta_text | default: 'Odbierz wycenę' }} 
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" x2="11" y1="2" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
                </button>
            </div>
        </div>
    </div>

    <!-- EDUCATIONAL SECTION - "How it works" -->
    <div class="py-24 bg-[#221022] relative border-t border-white/5 overflow-hidden">
        
        <!-- Decorative Cut-out Style Element -->
        <div class="hidden lg:block absolute right-0 bottom-0 w-1/3 h-full z-10 pointer-events-none mix-blend-lighten opacity-80">
            <div class="absolute inset-0 bg-gradient-to-l from-[#221022] to-transparent z-20"></div>
            {% if section.settings.cutout_image %}
                <img src="{{ section.settings.cutout_image | image_url: width: 800 }}" class="absolute inset-0 w-full h-full object-cover object-top mask-image-gradient" style="mask-image: linear-gradient(to bottom, black 80%, transparent 100%); -webkit-mask-image: linear-gradient(to bottom, black 80%, transparent 100%);" />
            {% endif %}
        </div>

        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-20">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
                <div>
                    <span class="text-[#f20df2] font-bold uppercase tracking-widest text-sm mb-2 flex items-center gap-2">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
                        Strefa Wiedzy
                    </span>
                    
                    <h2 class="text-2xl sm:text-3xl md:text-5xl font-black text-white uppercase italic tracking-tighter mb-4 group cursor-default">
                        <span class="inline-block transform -rotate-1 group-hover:rotate-0 transition-transform duration-500">Jak to</span>
                        <span class="inline-block text-transparent bg-clip-text bg-gradient-to-r from-[#f20df2] via-[#ff5f1f] to-[#ffd700] transform rotate-2 group-hover:rotate-0 transition-transform duration-500">Działa?</span>
                    </h2>

                    <div class="space-y-8 mt-12">
                        {% assign process_blocks = section.blocks | where: "type", "process" %}
                        {% for block in process_blocks %}
                            <div class="flex gap-6 group">
                                <div class="flex-shrink-0 w-12 h-12 rounded-full bg-[#221022] border border-white/10 flex items-center justify-center text-xl font-black text-white group-hover:bg-[#f20df2] group-hover:border-[#f20df2] transition-colors">
                                    {{ forloop.index }}
                                </div>
                                <div>
                                    <h3 class="text-xl font-bold text-white mb-2">{{ block.settings.title }}</h3>
                                    <p class="text-gray-400 leading-relaxed">{{ block.settings.description }}</p>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                </div>

                <!-- Requirements Card -->
                <div class="bg-[#221022]/80 backdrop-blur-md border border-white/10 rounded-3xl p-8 relative lg:mr-24 shadow-2xl">
                    <div class="absolute -top-6 -right-6 w-16 h-16 bg-yellow-400 text-[#0a050a] rounded-2xl flex items-center justify-center rotate-12 shadow-lg">
                        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"/><circle cx="12" cy="12" r="3"/></svg>
                    </div>
                    <h3 class="text-2xl font-black text-white uppercase italic mb-6">Czego potrzebujemy?</h3>
                    <p class="text-gray-400 text-sm mb-6">Lista techniczna (Rider), aby event się udał:</p>

                    <ul class="space-y-4">
                        {% assign req_blocks = section.blocks | where: "type", "requirement" %}
                        {% for block in req_blocks %}
                            <li class="flex items-start gap-3 text-gray-300 font-medium text-sm border-b border-white/5 pb-3 last:border-0">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-gray-500 mt-0.5 flex-shrink-0"><path d="M12 22v-5"/><path d="M9 8V2"/><path d="M15 8V2"/><path d="M18 8v5a4 4 0 0 1-4 4h-4a4 4 0 0 1-4-4V8Z"/></svg>
                                {{ block.settings.text }}
                            </li>
                        {% endfor %}
                    </ul>

                    <div class="mt-8 bg-[#f20df2]/10 border border-[#f20df2]/20 rounded-xl p-4 flex items-start gap-3">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[#f20df2] flex-shrink-0 mt-1"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg>
                        <p class="text-xs text-[#f20df2] font-bold">
                            Pamiętaj: My dostarczamy cały sprzęt Silent Disco. Ty zapewniasz tylko prąd i muzykę (lub DJ-a).
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Festival Special Layout -->
    {% if section.settings.show_festival_channels %}
        <div class="py-24 bg-[#221022] border-t border-white/5 overflow-hidden">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <div class="text-center mb-16">
                    <h2 class="text-2xl sm:text-3xl md:text-5xl font-black text-white uppercase italic tracking-tighter mb-4 group cursor-default">
                        <span class="inline-block transform -rotate-1 group-hover:rotate-0 transition-transform duration-500">3 Kanały,</span>
                        <span class="inline-block text-transparent bg-clip-text bg-gradient-to-r from-[#f20df2] via-[#ff5f1f] to-[#ffd700] transform rotate-2 group-hover:rotate-0 transition-transform duration-500">3 Emocje</span>
                    </h2>
                    <p class="text-gray-400 mt-6 max-w-2xl mx-auto">
                        Uczestnicy sami decydują o klimacie. Na słuchawkach za pomocą jednego przycisku mogą zmienić kanał i dołączyć do innej imprezy.
                    </p>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-3 gap-8 text-center">
                    <div class="p-8 rounded-3xl bg-blue-900/20 border border-blue-500/30 group">
                        <div class="w-16 h-16 mx-auto bg-blue-500/20 rounded-full flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
                            <div class="w-8 h-8 rounded-full bg-blue-500 shadow-[0_0_20px_rgba(59,130,246,0.8)] animate-pulse"></div>
                        </div>
                        <h3 class="text-xl font-bold text-white mb-2">Kanał Niebieski</h3>
                        <p class="text-gray-400">Elektroniczna, Techno, House</p>
                    </div>
                    <div class="p-8 rounded-3xl bg-red-900/20 border border-red-500/30 group">
                        <div class="w-16 h-16 mx-auto bg-red-500/20 rounded-full flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
                            <div class="w-8 h-8 rounded-full bg-red-500 shadow-[0_0_20px_rgba(239,68,68,0.8)] animate-pulse" style="animation-delay: 0.2s"></div>
                        </div>
                        <h3 class="text-xl font-bold text-white mb-2">Kanał Czerwony</h3>
                        <p class="text-gray-400">Rap, Hip-Hop, RnB</p>
                    </div>
                    <div class="p-8 rounded-3xl bg-green-900/20 border border-green-500/30 group">
                        <div class="w-16 h-16 mx-auto bg-green-500/20 rounded-full flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
                            <div class="w-8 h-8 rounded-full bg-green-500 shadow-[0_0_20px_rgba(34,197,94,0.8)] animate-pulse" style="animation-delay: 0.4s"></div>
                        </div>
                        <h3 class="text-xl font-bold text-white mb-2">Kanał Zielony</h3>
                        <p class="text-gray-400">Lata 80/90, Pop, Guilty Pleasures</p>
                    </div>
                </div>
            </div>
        </div>
    {% endif %}

    <!-- Description & Benefits -->
    <div class="py-24 bg-[#221022] relative border-t border-white/5">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
                <div>
                    <h2 class="text-2xl md:text-3xl font-black text-white uppercase italic mb-6">
                        {{ section.settings.features_heading | default: 'Dlaczego Warto?' }}
                    </h2>
                    <p class="text-gray-400 text-lg leading-relaxed mb-8">
                        {{ section.settings.body_description | default: 'Cichoszau to innowacyjna forma rozrywki...' }}
                    </p>
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                        {% assign ben_blocks = section.blocks | where: "type", "benefit" %}
                        {% for block in ben_blocks %}
                            <div class="flex items-start gap-3">
                                <div class="mt-1 w-6 h-6 rounded-full bg-[#f20df2]/20 flex items-center justify-center text-[#f20df2] flex-shrink-0">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" stroke="none"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
                                </div>
                                <span class="text-white font-bold text-sm">{{ block.settings.text }}</span>
                            </div>
                        {% endfor %}
                    </div>
                </div>

                <!-- Visual Card -->
                <div class="relative">
                    <div class="absolute inset-0 bg-gradient-to-br from-[#f20df2] to-[#ff5f1f] opacity-20 blur-3xl rounded-full"></div>
                    <div class="relative bg-[#221022] border border-white/10 rounded-3xl p-8 transform rotate-3 hover:rotate-0 transition-transform duration-500 shadow-2xl">
                        <div class="flex items-center gap-4 mb-6 border-b border-white/10 pb-6">
                            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" class="text-green-500" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                            <div>
                                <div class="text-white font-bold text-lg">Gwarancja Satysfakcji</div>
                                <div class="text-gray-400 text-xs">Sprawdzone przez 500+ klientów</div>
                            </div>
                        </div>
                        <div class="space-y-4">
                            <div class="h-4 bg-white/10 rounded w-3/4"></div>
                            <div class="h-4 bg-white/10 rounded w-full"></div>
                            <div class="h-4 bg-white/10 rounded w-5/6"></div>
                        </div>
                        <div class="mt-8 pt-6 border-t border-white/10">
                            <div class="text-yellow-400 font-black uppercase text-xl">
                                Oszczędź do 20%
                            </div>
                            <div class="text-gray-500 text-sm">Przy stałej współpracy</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

{% schema %}
{
  "name": "Service Landing",
  "settings": [
    {
      "type": "header",
      "content": "Tło Hero (Film / Zdjęcie)"
    },
    {
      "type": "video",
      "id": "hero_video",
      "label": "Film w tle Hero (mp4)"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Zdjęcie w tle Hero (fallback)"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Main Title",
      "default": "Eventy Firmowe & Integracje"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Zbuduj zespół w ciszy, która robi hałas."
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA Button Text",
      "default": "Zamów ofertę"
    },
    {
      "type": "image_picker",
      "id": "cutout_image",
      "label": "Cutout Image (How it works)"
    },
    {
      "type": "textarea",
      "id": "body_description",
      "label": "Body Description",
      "default": "Firmowa impreza bez krzyczenia do ucha? Silent Disco to idealne rozwiązanie..."
    },
    {
      "type": "text",
      "id": "features_heading",
      "label": "Features H2 Heading",
      "default": "Dlaczego Warto?"
    },
    {
      "type": "checkbox",
      "id": "show_festival_channels",
      "label": "Show Festival 3 Channels Demo",
      "default": false
    }
  ],
  "blocks": [
    {
      "type": "process",
      "name": "Process Step",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Step Title"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Step Description"
        }
      ]
    },
    {
      "type": "requirement",
      "name": "Technical Requirement",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Requirement Details"
        }
      ]
    },
    {
      "type": "benefit",
      "name": "Benefit",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Benefit Details"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Service Landing"
    }
  ]
}
{% endschema %}
