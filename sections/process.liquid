<section class="bg-[#221022] relative overflow-hidden" id="process" style="padding-top: clamp(50px, 6vw, 60px); padding-bottom: clamp(50px, 6vw, 60px);">

    <div class="max-w-7xl mx-auto px-5 relative z-10">

        <div class="text-center mb-16" data-animate="fade-up">
            <div class="mt-6 flex justify-center">
                <h2 class="text-4xl md:text-6xl font-black text-white uppercase italic tracking-tighter mb-6 group cursor-default">
                    <span class="inline-block transform -rotate-1 group-hover:rotate-0 transition-transform duration-500 origin-bottom-left">
                        {{ section.settings.title | default: '3 etapy do' | replace: '[MIASTO]', metaobject.nazwa.value | replace: ' [MIASTO]', '' }}
                    </span>
                    <br class="hidden md:block" />
                    <span class="inline-block text-transparent bg-clip-text bg-gradient-to-r from-[#f20df2] via-[#ff5f1f] to-[#ffd700] transform rotate-2 group-hover:rotate-0 transition-transform duration-500 origin-bottom-right pb-2">
                        {{ section.settings.highlight_text | default: 'PERFEKCJI' }}
                    </span>
                </h2>
            </div>
            <div class="line-glow-scroll w-full h-px mt-6" style="margin-top: 20px !important; height: 1px; width: 100%; background: linear-gradient(to right, transparent, #f20df2, transparent); box-shadow: 0 0 20px rgba(242,13,242,0.8);"></div>
        </div>

        <div class="relative grid grid-cols-1 md:grid-cols-3 gap-12 md:gap-16 text-center">
            
            <!-- Etap 1 -->
            <div class="group glass-card rounded-3xl p-8 border border-[#f20df2]/40 shadow-[0_0_20px_rgba(242,13,242,0.15)] hover:shadow-[0_0_30px_rgba(242,13,242,0.3)] transition-all duration-500" data-animate="fade-up" data-tilt>
                <div class="w-20 h-20 md:w-24 md:h-24 rounded-3xl glass-card border border-[#f20df2]/40 shadow-[0_0_20px_rgba(242,13,242,0.15)] flex items-center justify-center mx-auto mb-6 group-hover:bg-[#f20df2] group-hover:border-[#f20df2] transition-all duration-300 transform group-hover:rotate-6 shadow-xl">
                    <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[#f20df2] group-hover:text-white"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
                </div>
                <h3 class="text-xl md:text-2xl font-black text-white mb-4 uppercase">{{ section.settings.step1_title | default: '1. Szybka Wycena' }}</h3>
                <p class="text-gray-400 font-medium text-sm md:text-base px-4">{{ section.settings.step1_desc | default: 'Użyj kalkulatora B2B. Wybierz pakiet, wskaż parametry i wygeneruj profesjonalną ofertę PDF w 30 sekund. Cała papierologia cyfrowo.' }}</p>
            </div>

            <!-- Etap 2 -->
            <div class="group glass-card rounded-3xl p-8 border border-[#f20df2]/40 shadow-[0_0_20px_rgba(242,13,242,0.15)] hover:shadow-[0_0_30px_rgba(242,13,242,0.3)] transition-all duration-500" data-animate="fade-up" data-animate-delay="200" data-tilt>
                <div class="w-20 h-20 md:w-24 md:h-24 rounded-3xl glass-card border border-[#f20df2]/40 shadow-[0_0_20px_rgba(242,13,242,0.15)] flex items-center justify-center mx-auto mb-6 group-hover:bg-[#f20df2] group-hover:border-[#f20df2] transition-all duration-300 transform group-hover:-rotate-6 shadow-xl">
                    <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[#f20df2] group-hover:text-white"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon></svg>
                </div>
                <h3 class="text-xl md:text-2xl font-black text-white mb-4 uppercase">{{ section.settings.step2_title | default: '2. Plug & Play' }}</h3>
                <p class="text-gray-400 font-medium text-sm md:text-base px-4">{{ section.settings.step2_desc | default: 'Otrzymujesz sterylne skrzynie. Słuchawki w 100% naładowane. Podłączasz nadajnik do zasilania (230V) i impreza gotowa.' }}</p>
            </div>

            <!-- Etap 3 -->
            <div class="group glass-card rounded-3xl p-8 border border-[#f20df2]/40 shadow-[0_0_20px_rgba(242,13,242,0.15)] hover:shadow-[0_0_30px_rgba(242,13,242,0.3)] transition-all duration-500" data-animate="fade-up" data-animate-delay="400" data-tilt>
                <div class="w-20 h-20 md:w-24 md:h-24 rounded-3xl glass-card border border-[#f20df2]/40 shadow-[0_0_20px_rgba(242,13,242,0.15)] flex items-center justify-center mx-auto mb-6 group-hover:bg-[#f20df2] group-hover:border-[#f20df2] transition-all duration-300 transform group-hover:rotate-6 shadow-xl">
                    <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[#f20df2] group-hover:text-[#0a050a]"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"></rect><line x1="12" y1="18" x2="12.01" y2="18"></line></svg>
                </div>
                <h3 class="text-xl md:text-2xl font-black text-white mb-4 uppercase">{{ section.settings.step3_title | default: '3. Aplikacja Zero Strat' }}</h3>
                <p class="text-gray-400 font-medium text-sm md:text-base px-4">{{ section.settings.step3_desc | default: 'Wydajesz słuchawki skanując kody naszą autorską aplikacją CichoszauRent. Eliminuje to kolejki do zera i chroni przed kradzieżą.' }}</p>
            </div>

        </div>
    </div>
</section>

{% schema %}
{
  "name": "Process Pipeline",
  "settings": [
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Metodologia"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "3 etapy do"
    },
    {
      "type": "text",
      "id": "highlight_text",
      "label": "Highlight Text",
      "default": "PERFEKCJI"
    },
    {
      "type": "header",
      "content": "Step 1"
    },
    {
      "type": "text",
      "id": "step1_title",
      "label": "Title",
      "default": "1. Konsultacja"
    },
    {
      "type": "textarea",
      "id": "step1_desc",
      "label": "Description",
      "default": "Analiza potrzeb technicznych, wybór skali oraz rezerwacja terminu realizacji."
    },
    {
      "type": "header",
      "content": "Step 2"
    },
    {
      "type": "text",
      "id": "step2_title",
      "label": "Title",
      "default": "2. Przygotowanie"
    },
    {
      "type": "textarea",
      "id": "step2_desc",
      "label": "Description",
      "default": "Konfiguracja, testy jakościowe oraz bezpieczna wysyłka zestawu pod wskazany adres."
    },
    {
      "type": "header",
      "content": "Step 3"
    },
    {
      "type": "text",
      "id": "step3_title",
      "label": "Title",
      "default": "3. Realizacja"
    },
    {
      "type": "textarea",
      "id": "step3_desc",
      "label": "Description",
      "default": "Bezproblemowy przebieg wydarzenia pod nadzorem naszego zaplecza wsparcia."
    }
  ],
  "presets": [
    {
      "name": "Process Pipeline"
    }
  ]
}
{% endschema %}
