<section class="bg-[#221022] relative overflow-hidden" id="how-it-works-video-{{ section.id }}" style="padding-top: clamp(50px, 6vw, 60px); padding-bottom: clamp(50px, 6vw, 60px);">

    <div class="max-w-7xl mx-auto px-5 relative z-20">
        
        <div class="text-center mb-16" data-animate="fade-up">
            {% if section.settings.title != blank %}
            {% assign title_words = section.settings.title | split: ' ' %}
            {% assign first_word = title_words | first %}
            {% assign rest_words = section.settings.title | remove_first: first_word | strip %}
            <div class="mt-6 flex justify-center">
                <h2 class="text-4xl md:text-6xl font-black text-white uppercase italic tracking-tighter mb-6 group cursor-default">
                    <span class="inline-block transform -rotate-1 group-hover:rotate-0 transition-transform duration-500 origin-bottom-left">
                        {{ first_word }}
                    </span>
                    <br class="hidden md:block" />
                    <span class="inline-block text-transparent bg-clip-text bg-gradient-to-r from-[#f20df2] to-[#ff5f1f] transform rotate-2 group-hover:rotate-0 transition-transform duration-500 origin-bottom-right pb-2">
                        {{ rest_words }}
                    </span>
                </h2>
            </div>
            {% endif %}
            
            <div class="line-glow-scroll w-full h-px mt-6" style="margin-top: 20px !important; height: 1px; width: 100%; background: linear-gradient(to right, transparent, #f20df2, transparent); box-shadow: 0 0 20px rgba(242,13,242,0.8);"></div>
        </div>

        <div class="flex flex-col lg:flex-col items-center gap-12">
            
            <!-- Video 16:9 -->
            <div class="w-full mx-auto relative aspect-video rounded-3xl overflow-hidden glass-card border border-[#f20df2]/40 shadow-[0_0_20px_rgba(242,13,242,0.15)] group">
                {% if section.settings.video != blank %}
                    <video
                        class="absolute inset-0 w-full h-full object-cover object-center filter brightness-90 group-hover:brightness-100 transition-all duration-700"
                        style="width: 100% !important; height: 100% !important; object-fit: cover !important; object-position: center !important; position: absolute !important; top: 0 !important; left: 0 !important; margin: 0 !important; padding: 0 !important;"
                        autoplay loop muted playsinline preload="auto"
                    >
                        {% for source in section.settings.video.sources %}
                            <source src="{{ source.url }}" type="video/{{ source.format }}">
                        {% endfor %}
                    </video>
                {% elsif section.settings.image != blank %}
                    <img
                        src="{{ section.settings.image | image_url: width: 1920, format: 'webp' }}"
                        alt="Instruktaż Silent Disco"
                        class="absolute inset-0 w-full h-full object-cover object-center filter brightness-75 group-hover:brightness-90 transition-all duration-700"
                        style="width: 100% !important; height: 100% !important; object-fit: cover !important; object-position: center !important; position: absolute !important; top: 0 !important; left: 0 !important; margin: 0 !important; padding: 0 !important;"
                        loading="lazy"
                    />
                {% else %}
                    <!-- Placeholder -->
                    <div class="absolute inset-0 bg-[#221022] flex items-center justify-center">
                        <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" class="text-white/20"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/></svg>
                    </div>
                {% endif %}
                <div class="absolute inset-0 bg-gradient-to-t from-[#1a0c1a] via-transparent to-transparent opacity-60 pointer-events-none"></div>
            </div>

            <!-- Kroki instruktażowe (3 Cards) -->
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6 w-full max-w-5xl mx-auto mt-4">
                
                <!-- Krok 1 -->
                <div class="group relative glass-card p-8 rounded-3xl border border-[#f20df2]/40 shadow-[0_0_20px_rgba(242,13,242,0.15)] hover:shadow-[0_0_30px_rgba(242,13,242,0.3)] hover:border-[#f20df2]/80 transition-all duration-500 hover:-translate-y-2">
                    <div class="absolute -top-4 -left-4 w-10 h-10 rounded-full bg-[#f20df2] text-white flex items-center justify-center font-black text-lg border-4 border-[#1a0c1a] shadow-lg group-hover:scale-110 transition-transform">1</div>
                    <div class="pt-2">
                        <h3 class="text-xl font-black text-white uppercase italic mb-2 group-hover:text-[#f20df2] transition-colors">{{ section.settings.step1_title | default: "Odbierasz Paczkę" }}</h3>
                        <p class="text-gray-400 text-sm leading-relaxed">{{ section.settings.step1_desc | default: "Kurier dostarcza sterylną skrzynię pełną naładowanych w 100% słuchawek prosto pod Twoje drzwi." }}</p>
                    </div>
                </div>

                <!-- Krok 2 -->
                <div class="group relative glass-card p-8 rounded-3xl border border-[#f20df2]/40 shadow-[0_0_20px_rgba(242,13,242,0.15)] hover:shadow-[0_0_30px_rgba(242,13,242,0.3)] hover:border-[#f20df2]/80 transition-all duration-500 hover:-translate-y-2">
                    <div class="absolute -top-4 -left-4 w-10 h-10 rounded-full bg-[#f20df2] text-white flex items-center justify-center font-black text-lg border-4 border-[#1a0c1a] shadow-lg group-hover:scale-110 transition-transform">2</div>
                    <div class="pt-2">
                        <h3 class="text-xl font-black text-white uppercase italic mb-2 group-hover:text-[#ff5f1f] transition-colors">{{ section.settings.step2_title | default: "Podpinasz Kable" }}</h3>
                        <p class="text-gray-400 text-sm leading-relaxed">{{ section.settings.step2_desc | default: "Podłączasz nadajnik do prądu i wpinasz telefon/laptopa załączonym minijackiem. Zero konfiguracji." }}</p>
                    </div>
                </div>

                <!-- Krok 3 -->
                <div class="group relative glass-card p-8 rounded-3xl border border-[#f20df2]/40 shadow-[0_0_20px_rgba(242,13,242,0.15)] hover:shadow-[0_0_30px_rgba(242,13,242,0.3)] hover:border-[#f20df2]/80 transition-all duration-500 hover:-translate-y-2">
                    <div class="absolute -top-4 -left-4 w-10 h-10 rounded-full bg-[#f20df2] text-black flex items-center justify-center font-black text-lg border-4 border-[#1a0c1a] shadow-lg group-hover:scale-110 transition-transform">3</div>
                    <div class="pt-2">
                        <h3 class="text-xl font-black text-white uppercase italic mb-2 group-hover:text-[#ffd700] transition-colors">{{ section.settings.step3_title | default: "Rozdajesz i Grasz" }}</h3>
                        <p class="text-gray-400 text-sm leading-relaxed">{{ section.settings.step3_desc | default: "Włączasz słuchawki jednym suwakiem na nauszniku. Twoi goście od razu słyszą grającą muzykę!" }}</p>
                    </div>
                </div>

            </div>

        </div>
    </div>
</section>

{% schema %}
{
  "name": "Wideo Instruktażowe 16:9",
  "settings": [
    {
      "type": "text",
      "id": "pill_text",
      "label": "Tekst w pigułce",
      "default": "PLUG & PLAY"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Główny Tytuł",
      "default": "Jak to podłączyć?"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Podtytuł",
      "default": "To bajecznie proste. 3 krórtkie kroki do uruchomienia."
    },
    {
      "type": "video",
      "id": "video",
      "label": "Instruktaż Wideo 16:9"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Alternatywne Zdjęcie 16:9 (jesli brak wideo)"
    },
    {
      "type": "text",
      "id": "step1_title",
      "label": "Tytuł - Krok 1",
      "default": "Odbierasz Paczkę"
    },
    {
      "type": "textarea",
      "id": "step1_desc",
      "label": "Opis - Krok 1",
      "default": "Kurier dostarcza sterylną skrzynię pełną naładowanych w 100% słuchawek prosto pod Twoje drzwi."
    },
    {
      "type": "text",
      "id": "step2_title",
      "label": "Tytuł - Krok 2",
      "default": "Podpinasz Kable"
    },
    {
      "type": "textarea",
      "id": "step2_desc",
      "label": "Opis - Krok 2",
      "default": "Podłączasz nadajnik do prądu i wpinasz telefon/laptopa załączonym minijackiem. Zero konfiguracji."
    },
    {
      "type": "text",
      "id": "step3_title",
      "label": "Tytuł - Krok 3",
      "default": "Rozdajesz i Grasz"
    },
    {
      "type": "textarea",
      "id": "step3_desc",
      "label": "Opis - Krok 3",
      "default": "Włączasz słuchawki jednym suwakiem na nauszniku. Twoi goście od razu słyszą grającą muzykę!"
    }
  ],
  "presets": [
    {
      "name": "Wideo Instruktażowe 16:9"
    }
  ]
}
{% endschema %}
