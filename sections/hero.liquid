<section class="relative aspect-video w-full flex items-center justify-center overflow-hidden" id="hero-section" style="padding-top: clamp(50px, 6vw, 60px); padding-bottom: clamp(50px, 6vw, 60px);">
    <!-- === WARSTWA 1: Gradient fioletowy (najniżej) === -->
    <div class="absolute inset-0 pointer-events-none" style="z-index: 0;">
        <div class="absolute inset-0 bg-gradient-to-r from-[#221022] via-[#221022]/90 to-[#221022]/30"></div>
    </div>

    <!-- === WARSTWA 2: Film / Zdjęcie (po prawej, za napisami) === -->
    {% if section.settings.bg_video != blank or section.settings.bg_video_mobile != blank %}
        <div class="absolute inset-0 pointer-events-none" style="z-index: 10;">
            {% if section.settings.bg_video != blank %}
            <video
                id="hero-bg-video-desktop"
                class="w-full h-full object-cover will-change-transform {% if section.settings.bg_video_mobile != blank %}hidden md:block{% else %}block{% endif %}"
                style="opacity: 0.85;"
                autoplay loop muted playsinline preload="auto" fetchpriority="high"
                {% if section.settings.bg_image %}poster="{{ section.settings.bg_image | image_url: width: 1920 }}"{% endif %}
            >
                {% for source in section.settings.bg_video.sources %}
                    <source src="{{ source.url }}" type="video/{{ source.format }}">
                {% endfor %}
            </video>
            {% endif %}

            {% if section.settings.bg_video_mobile != blank %}
            <video
                id="hero-bg-video-mobile"
                class="w-full h-full object-cover will-change-transform {% if section.settings.bg_video != blank %}block md:hidden{% else %}block{% endif %}"
                style="opacity: 0.85;"
                autoplay loop muted playsinline preload="auto" fetchpriority="high"
                {% if section.settings.bg_image_mobile %}poster="{{ section.settings.bg_image_mobile | image_url: width: 800 }}"{% elsif section.settings.bg_image %}poster="{{ section.settings.bg_image | image_url: width: 800 }}"{% endif %}
            >
                {% for source in section.settings.bg_video_mobile.sources %}
                    <source src="{{ source.url }}" type="video/{{ source.format }}">
                {% endfor %}
            </video>
            {% endif %}
            <div class="absolute inset-0 bg-gradient-to-r from-[#221022] via-[#221022]/70 to-transparent" style="z-index: 20;"></div>
        </div>
    {% elsif section.settings.bg_image or section.settings.bg_image_mobile %}
        <div class="absolute inset-0 pointer-events-none" style="z-index: 10;">
            <picture>
                {% if section.settings.bg_image_mobile %}
                <source media="(max-width: 767px)" srcset="{{ section.settings.bg_image_mobile | image_url: width: 600, format: 'webp' }} 600w, {{ section.settings.bg_image_mobile | image_url: width: 800, format: 'webp' }} 800w">
                {% endif %}
                {% if section.settings.bg_image %}
                <source media="(min-width: 768px)" srcset="{{ section.settings.bg_image | image_url: width: 1200, format: 'webp' }} 1200w, {{ section.settings.bg_image | image_url: width: 1920, format: 'webp' }} 1920w">
                <img
                    alt="{{ section.settings.bg_image.alt | default: 'CICHOSZAU Silent Disco' }}"
                    class="w-full h-full object-cover transition-all duration-1000 will-change-transform"
                    style="opacity: 0.85;"
                    id="hero-bg-img"
                    src="{{ section.settings.bg_image | image_url: width: 1920, format: 'webp' }}"
                    fetchpriority="high"
                    loading="eager"
                />
                {% elsif section.settings.bg_image_mobile %}
                <img
                    alt="{{ section.settings.bg_image_mobile.alt | default: 'CICHOSZAU Silent Disco Mobile' }}"
                    class="w-full h-full object-cover transition-all duration-1000 will-change-transform"
                    style="opacity: 0.85;"
                    id="hero-bg-img"
                    src="{{ section.settings.bg_image_mobile | image_url: width: 800, format: 'webp' }}"
                    fetchpriority="high"
                    loading="eager"
                />
                {% endif %}
            </picture>
            <div class="absolute inset-0 bg-gradient-to-r from-[#221022] via-[#221022]/70 to-transparent" style="z-index: 20;"></div>
        </div>
    {% else %}
        <div class="absolute inset-0 pointer-events-none" style="z-index: 10;">
            <img
                alt="Silent Disco Party Crowd"
                class="w-full h-full object-cover transition-all duration-1000 will-change-transform"
                style="opacity: 0.85;"
                id="hero-bg-img"
                src="https://images.unsplash.com/photo-1516450360452-9312f5e86fc7?q=80&w=1920&auto=format&fit=crop"
                fetchpriority="high"
                loading="eager"
            />
            <div class="absolute inset-0 bg-gradient-to-r from-[#221022] via-[#221022]/70 to-transparent" style="z-index: 20;"></div>
        </div>
    {% endif %}

    <!-- Dynamic overlay gradients -->
    <div class="absolute inset-0 z-[15] pointer-events-none">
        <div class="absolute inset-0 bg-gradient-to-b from-[#221022]/90 via-[#221022]/40 to-[#221022] z-10 pointer-events-none"></div>
        <div class="absolute inset-0 bg-[#f20df2]/10 mix-blend-overlay z-10"></div>
        <!-- Pulsing mesh gradient overlay -->
        <div class="absolute inset-0 opacity-40 bg-[radial-gradient(circle_at_50%_50%,rgba(242,13,242,0.2),transparent_70%)]" style="animation: pulse-slow 8s infinite ease-in-out;"></div>
        <div class="absolute inset-0 opacity-20 bg-[radial-gradient(circle_at_20%_30%,rgba(255,95,31,0.2),transparent_50%)]" style="animation: pulse-slow 8s infinite ease-in-out; animation-delay: 2s;"></div>
    </div>

    <!-- Animated Blobs with Wavy Motion -->
    <div class="bg-[#f20df2] w-[300px] md:w-[600px] h-[300px] md:h-[600px] rounded-full absolute top-[-10%] left-[-10%] blur-[120px] opacity-30 z-10" style="animation: blob 7s infinite alternate ease-in-out;" data-parallax="0.15"></div>
    <div class="bg-[#ff5f1f] w-[250px] md:w-[500px] h-[250px] md:h-[500px] rounded-full absolute bottom-[-5%] right-[-5%] blur-[100px] opacity-30 z-10" style="animation: blob 7s infinite alternate ease-in-out; animation-delay: 3s;" data-parallax="-0.12"></div>
    <div class="bg-[#ffd700] w-[200px] md:w-[400px] h-[200px] md:h-[400px] rounded-full absolute top-[40%] right-[10%] opacity-10 blur-[80px] z-10" style="animation: blob 7s infinite alternate ease-in-out; animation-delay: 5s;" data-parallax="0.08"></div>

    <div class="relative w-full max-w-7xl mx-auto px-5 text-center z-20 py-10">
        <div class="inline-flex items-center px-6 py-2 rounded-full border border-[#f20df2]/50 glass-card mb-8 transform -rotate-2 hover:rotate-0 transition-transform duration-300">
            <span class="flex h-3 w-3 rounded-full bg-[#ffd700] mr-3 animate-ping"></span>
            <span class="text-sm font-bold text-white tracking-widest uppercase">High Energy Events Agency</span>
        </div>
        
        <h1 class="sr-only">Wypożyczalnia słuchawek Silent Disco, organizacja imprez i festiwali bezprzewodowych | CICHOSZAU</h1>
        <div aria-hidden="true" class="text-5xl md:text-7xl lg:text-[6.5rem] font-black text-white tracking-tighter mb-4 lg:mb-6 leading-[0.9] drop-shadow-2xl">
            <div class="transform -rotate-1 hover:rotate-0 transition-transform duration-500"><span id="hero-typewriter">SILENT DISCO</span><span class="hero-cursor" style="border-right:3px solid #f20df2;margin-left:2px;animation:blink-cursor 0.75s step-end infinite;"> </span></div>
            <div class="text-transparent bg-clip-text bg-gradient-to-r from-[#f20df2] via-[#ff5f1f] to-[#ffd700] transform rotate-2 hover:rotate-0 transition-transform duration-500 pb-2">TECHNOLOGIA</div>
            <div class="transform -rotate-1 hover:rotate-0 transition-transform duration-500" style="-webkit-text-stroke: 1px rgba(255, 255, 255, 0.4); color: transparent;">DOŚWIADCZENIE</div>
        </div>
        
        <p class="mt-4 lg:mt-6 max-w-3xl mx-auto text-base md:text-xl text-gray-200 mb-8 lg:mb-10 font-medium leading-relaxed drop-shadow-lg">
            Tworzymy <span class="text-[#ffd700] font-bold">niezapomniane</span> wydarzenia. Połącz magię dźwięku z festiwalową energią Twojej marki.
        </p>
        
        <!-- ═══ SPLIT HERO — 3-Card Segment Selector ═══ -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4 lg:gap-6 mb-8 lg:mb-10 max-w-7xl mx-auto w-full" id="split-hero-cards">

            <!-- Card 1: B2B -->
            <a href="/pages/b2b"
               aria-label="Przejdź do oferty dla Firm B2B"
               class="odbierz-wycene-trigger split-card group relative flex flex-col justify-between p-4 md:p-5 rounded-3xl border border-[#f20df2]/40 shadow-[0_0_20px_rgba(242,13,242,0.15)] hover:shadow-[0_0_30px_rgba(242,13,242,0.3)] glass-card overflow-hidden cursor-pointer hover:border-[#f20df2]/80 transition-all duration-500 hover:-translate-y-2 text-left"
               data-accent="blue" data-tilt>
                <!-- Usunięto bg-gradient na prośbę ujednolicenia -->
                <div>
                    <div class="w-12 h-12 md:w-14 md:h-14 rounded-2xl glass-card border border-[#f20df2]/40 shadow-[0_0_20px_rgba(242,13,242,0.15)] flex items-center justify-center mx-auto mb-4 md:mb-5 group-hover:scale-110 group-hover:bg-[#f20df2] group-hover:border-[#f20df2] transition-all duration-300 shadow-xl">
                        <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[#f20df2] group-hover:text-white"><path d="M6 22V4a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v18Z"/><path d="M6 12H4a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h2"/><path d="M18 9h2a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2h-2"/><path d="M10 6h4"/><path d="M10 10h4"/><path d="M10 14h4"/><path d="M10 18h4"/></svg>
                    </div>
                    <div class="text-[9px] md:text-[10px] font-black uppercase tracking-[0.2em] text-[#f20df2] mb-1 md:mb-2 text-center">Dla Firm</div>
                    <h2 class="text-lg md:text-xl lg:text-2xl font-black text-white uppercase italic leading-tight mb-2 md:mb-3 group-hover:text-[#f20df2] transition-colors text-center">Eventy B2B<br>& Integracje</h2>
                    <p class="text-gray-400 text-xs md:text-sm leading-relaxed text-center">Firmówki, wigilie, konferencje, budowanie zespołu. Pełna obsługa + faktura VAT.</p>
                </div>
                <div class="mt-5 md:mt-6 inline-flex justify-center items-center gap-2 text-white font-black text-[11px] md:text-[12px] lg:text-sm uppercase tracking-widest rounded-[1.5rem] px-5 py-3 lg:px-6 lg:py-4 w-full group-hover:scale-[1.02] transition-all duration-300 text-center transform hover:-translate-y-1 active:translate-y-0 active:border-b-0" style="background-color: #3b82f6; border-bottom: 5px solid #2563eb; box-shadow: 0 10px 20px rgba(59,130,246,0.4), 0 0 15px rgba(59,130,246,0.6);">
                    Odbierz wycenę
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" class="group-hover:translate-x-1 transition-transform" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                </div>
            </a>

            <!-- Card 2: Wynajem (center — primary) -->
            <a href="/pages/wynajem"
               class="odbierz-wycene-trigger split-card group relative flex flex-col justify-between p-4 md:p-5 rounded-3xl glass-card border border-[#f20df2]/40 shadow-[0_0_20px_rgba(242,13,242,0.15)] hover:shadow-[0_0_30px_rgba(242,13,242,0.3)] overflow-hidden cursor-pointer hover:-translate-y-2 transition-all duration-500 text-left"
               data-accent="pink">
                <!-- Badge -->
                <div class="absolute top-4 right-4 px-3 py-1 rounded-full bg-[#f20df2] text-white text-[9px] md:text-[10px] font-black uppercase tracking-widest">Popularne</div>
                <!-- Usunięto bg-gradient -->
                <div>
                    <div class="w-12 h-12 md:w-14 md:h-14 rounded-2xl glass-card border border-[#f20df2]/40 shadow-[0_0_20px_rgba(242,13,242,0.15)] flex items-center justify-center mx-auto mb-4 md:mb-5 group-hover:scale-110 group-hover:bg-[#f20df2] group-hover:border-[#f20df2] transition-all duration-300 shadow-xl">
                        <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[#f20df2] group-hover:text-white"><path d="M3 14h3a2 2 0 0 1 2-2h8a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-7a9 9 0 0 1 18 0v7a2 2 0 0 1-2 2h-1a2 2 0 0 1-2-2v-3a2 2 0 0 1 2-2h3"/></svg>
                    </div>
                    <div class="text-[9px] md:text-[10px] font-black uppercase tracking-[0.2em] text-[#f20df2] mb-1 md:mb-2 text-center">Wynajem Sprzętu</div>
                    <h2 class="text-lg md:text-xl lg:text-2xl font-black text-white uppercase italic leading-tight mb-2 md:mb-3 group-hover:text-[#f20df2] transition-colors text-center">Słuchawki<br>Plug & Play</h2>
                    <p class="text-gray-400 text-xs md:text-sm leading-relaxed text-center">Dostawa kurierem, 10h bateria, zasięg 500m. Domówka, wesele, własny event.</p>
                </div>
                <div class="mt-5 md:mt-6 inline-flex justify-center items-center gap-2 text-white font-black text-[11px] md:text-[12px] lg:text-sm uppercase tracking-widest rounded-[1.5rem] px-5 py-3 lg:px-6 lg:py-4 w-full group-hover:scale-[1.02] transition-all duration-300 text-center transform hover:-translate-y-1 active:translate-y-0 active:border-b-0" style="background-color: #f20df2; border-bottom: 5px solid #b800b8; box-shadow: 0 10px 20px rgba(242,13,242,0.4), 0 0 15px rgba(242,13,242,0.6);">
                    Odbierz wycenę
                </div>
            </a>

            <!-- Card 3: B2C / Imprezy -->
            <a href="/pages/bilety"
               aria-label="Przejdź do kalendarza najbliższych imprez"
               class="odbierz-wycene-trigger split-card group relative flex flex-col justify-between p-4 md:p-5 rounded-3xl glass-card border border-[#f20df2]/40 shadow-[0_0_20px_rgba(242,13,242,0.15)] hover:shadow-[0_0_30px_rgba(242,13,242,0.3)] overflow-hidden cursor-pointer hover:-translate-y-2 transition-all duration-500 text-left"
               data-accent="yellow">
                <!-- Usunięto bg-gradient -->
                <div>
                    <div class="w-12 h-12 md:w-14 md:h-14 rounded-2xl glass-card border border-[#f20df2]/40 shadow-[0_0_20px_rgba(242,13,242,0.15)] flex items-center justify-center mx-auto mb-4 md:mb-5 group-hover:scale-110 group-hover:bg-[#f20df2] group-hover:border-[#f20df2] transition-all duration-300 shadow-xl">
                        <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[#f20df2] group-hover:text-[#0a050a]"><path d="M2 9a3 3 0 0 1 0 6v2a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-2a3 3 0 0 1 0-6V7a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2Z"/><path d="M13 5v2"/><path d="M13 17v2"/><path d="M13 11v2"/></svg>
                    </div>
                    <div class="text-[9px] md:text-[10px] font-black uppercase tracking-[0.2em] text-[#f20df2] mb-1 md:mb-2 text-center">Imprezy & Bilety</div>
                    <h2 class="text-lg md:text-xl lg:text-2xl font-black text-white uppercase italic leading-tight mb-2 md:mb-3 group-hover:text-[#f20df2] transition-colors text-center">Najbliższe<br>Eventy</h2>
                    <p class="text-gray-400 text-xs md:text-sm leading-relaxed text-center">Beach bary, festiwale, kino plenerowe. Kup bilet i dołącz do następnej imprezy.</p>
                </div>
                <div class="mt-5 md:mt-6 inline-flex justify-center items-center gap-2 font-black text-[11px] md:text-[12px] lg:text-sm uppercase tracking-widest rounded-[1.5rem] px-5 py-3 lg:px-6 lg:py-4 w-full group-hover:scale-[1.02] text-center transition-all duration-300 transform hover:-translate-y-1 active:translate-y-0 active:border-b-0 text-[#0a050a]" style="background-color: #ffd700; border-bottom: 5px solid #ccac00; box-shadow: 0 10px 20px rgba(255,215,0,0.4), 0 0 15px rgba(255,215,0,0.6);">
                    Złap bilet
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" class="group-hover:translate-x-1 transition-transform" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                </div>
            </a>

        </div>
        <!-- ═══ END SPLIT HERO ═══ -->

        <!-- Stats Grid with Count-up Animations -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-6 max-w-5xl mx-auto mt-4 px-5 sm:px-5" style="perspective: 1000px;">
            <div data-val="200" data-suffix="+" data-float="false" class="stat-card p-4 md:p-5 rounded-2xl glass-card transition duration-300 transform group" style="border: 1px solid rgba(242,13,242,0.2); box-shadow: 0 0 15px rgba(242,13,242,0.05);" onmouseenter="this.style.borderColor='rgba(242,13,242,0.5)'; this.style.boxShadow='0 0 25px rgba(242,13,242,0.2)'; this.style.transform='translateY(-6px) rotate(0)'" onmouseleave="this.style.borderColor='rgba(242,13,242,0.2)'; this.style.boxShadow='0 0 15px rgba(242,13,242,0.05)'; this.style.transform='translateY(0) rotate(-2deg)'">
                <div class="text-2xl md:text-4xl font-black text-white mb-2 group-hover:text-[#f20df2] transition-colors"><span class="counter">0</span>+</div>
                <div class="text-[9px] md:text-[10px] font-bold text-gray-400 uppercase tracking-widest">Liczba Eventów</div>
            </div>
            <div data-val="10" data-suffix="K+" data-float="false" class="stat-card p-4 md:p-5 rounded-2xl glass-card transition duration-300 transform group" style="border: 1px solid rgba(242,13,242,0.2); box-shadow: 0 0 15px rgba(242,13,242,0.05);" onmouseenter="this.style.borderColor='rgba(242,13,242,0.5)'; this.style.boxShadow='0 0 25px rgba(242,13,242,0.2)'; this.style.transform='translateY(-6px) rotate(0)'" onmouseleave="this.style.borderColor='rgba(242,13,242,0.2)'; this.style.boxShadow='0 0 15px rgba(242,13,242,0.05)'; this.style.transform='translateY(0) rotate(2deg)'">
                <div class="text-2xl md:text-4xl font-black text-white mb-2 group-hover:text-[#f20df2] transition-colors"><span class="counter">0</span>K+</div>
                <div class="text-[9px] md:text-[10px] font-bold text-gray-400 uppercase tracking-widest">Uczestników</div>
            </div>
            <div data-val="7.4" data-suffix="%" data-float="true" class="stat-card p-4 md:p-5 rounded-2xl glass-card transition duration-300 transform group" style="border: 1px solid rgba(242,13,242,0.2); box-shadow: 0 0 15px rgba(242,13,242,0.05);" onmouseenter="this.style.borderColor='rgba(242,13,242,0.5)'; this.style.boxShadow='0 0 25px rgba(242,13,242,0.2)'; this.style.transform='translateY(-6px) rotate(0)'" onmouseleave="this.style.borderColor='rgba(242,13,242,0.2)'; this.style.boxShadow='0 0 15px rgba(242,13,242,0.05)'; this.style.transform='translateY(0) rotate(-2deg)'">
                <div class="text-2xl md:text-4xl font-black text-white mb-2 group-hover:text-[#f20df2] transition-colors"><span class="counter">0</span>%</div>
                <div class="text-[9px] md:text-[10px] font-bold text-gray-400 uppercase tracking-widest">ROAS</div>
            </div>
            <div data-val="24" data-suffix="h" data-float="false" class="stat-card p-4 md:p-5 rounded-2xl glass-card transition duration-300 transform group" style="border: 1px solid rgba(242,13,242,0.2); box-shadow: 0 0 15px rgba(242,13,242,0.05);" onmouseenter="this.style.borderColor='rgba(242,13,242,0.5)'; this.style.boxShadow='0 0 25px rgba(242,13,242,0.2)'; this.style.transform='translateY(-6px) rotate(0)'" onmouseleave="this.style.borderColor='rgba(242,13,242,0.2)'; this.style.boxShadow='0 0 15px rgba(242,13,242,0.05)'; this.style.transform='translateY(0) rotate(2deg)'">
                <div class="text-2xl md:text-4xl font-black text-white mb-2 group-hover:text-[#f20df2] transition-colors"><span class="counter">0</span>h</div>
                <div class="text-[9px] md:text-[10px] font-bold text-gray-400 uppercase tracking-widest">Support</div>
            </div>
        </div>
    </div>


    <script>
        document.addEventListener('DOMContentLoaded', () => {
            // Parallax usunięty by zachować sztywne proporcje 16:9


            // Stat Counter Animation
            const statCards = document.querySelectorAll('.stat-card');

            const animateCounter = (el) => {
                if (el.dataset.animated) return;
                el.dataset.animated = 'true';
                const counterSpan = el.querySelector('.counter');
                const targetVal = parseFloat(el.getAttribute('data-val'));
                const isFloat = el.getAttribute('data-float') === 'true';
                const duration = 2000;
                const startTime = performance.now();

                const updateCount = (currentTime) => {
                    const elapsed = currentTime - startTime;
                    const progress = Math.min(elapsed / duration, 1);
                    const easeProgress = 1 - Math.pow(1 - progress, 4);
                    const currentVal = easeProgress * targetVal;

                    if (isFloat) {
                        // Polish decimal comma (7,4 instead of 7.4)
                        counterSpan.innerText = currentVal.toFixed(1).replace('.', ',');
                    } else {
                        counterSpan.innerText = Math.floor(currentVal);
                    }

                    if (progress < 1) requestAnimationFrame(updateCount);
                    else counterSpan.innerText = isFloat
                        ? targetVal.toFixed(1).replace('.', ',')
                        : targetVal;
                };

                requestAnimationFrame(updateCount);
            };

            // Fire immediately for visible elements, then watch for scroll
            const observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        animateCounter(entry.target);
                        observer.unobserve(entry.target);
                    }
                });
            }, { threshold: 0.1, rootMargin: '0px 0px -20px 0px' });

            statCards.forEach(card => {
                // Check if already visible on load
                const rect = card.getBoundingClientRect();
                if (rect.top < window.innerHeight && rect.bottom > 0) {
                    setTimeout(() => animateCounter(card), 300);
                } else {
                    observer.observe(card);
                }
            });
        });
    </script>
</section>

{% schema %}
{
  "name": "Hero",
  "settings": [
    {
      "type": "header",
      "content": "Tlo Hero"
    },
    {
      "type": "video",
      "id": "bg_video",
      "label": "Video tla Hero (Desktop 16:9)"
    },
    {
      "type": "video",
      "id": "bg_video_mobile",
      "label": "Video tla Hero (Mobile 9:16)"
