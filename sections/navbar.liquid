<script>
    document.addEventListener('DOMContentLoaded', () => {
        const nav = document.getElementById('main-navbar');
        
        // Scroll Effect
        window.addEventListener('scroll', () => {
            if (window.scrollY > 50) {
                nav.classList.add('bg-[#221022]/65', 'backdrop-blur-xl', 'border-b', 'border-white/5', 'shadow-2xl');
                nav.classList.remove('bg-transparent');
            } else {
                nav.classList.remove('bg-[#221022]/65', 'backdrop-blur-xl', 'border-b', 'border-white/5', 'shadow-2xl');
                nav.classList.add('bg-transparent');
            }
        });

        // Services Dropdown (Desktop)
        const servicesContainer = document.getElementById('services-dropdown-container');
        const servicesMenu = document.getElementById('services-menu');
        const servicesBtn = document.getElementById('services-btn');
        const servicesChevron = document.getElementById('services-chevron');
        let timeout;

        if(servicesContainer && servicesMenu) {
            servicesContainer.addEventListener('mouseenter', () => {
                clearTimeout(timeout);
                servicesMenu.classList.remove('opacity-0', 'translate-y-4', 'scale-95', 'invisible', 'pointer-events-none');
                servicesMenu.classList.add('opacity-100', 'translate-y-0', 'scale-100', 'visible', 'pointer-events-auto');
                servicesBtn.classList.add('bg-white/10', 'text-white');
                servicesChevron.classList.add('rotate-180');
            });

            servicesContainer.addEventListener('mouseleave', () => {
                timeout = setTimeout(() => {
                    servicesMenu.classList.add('opacity-0', 'translate-y-4', 'scale-95', 'invisible', 'pointer-events-none');
                    servicesMenu.classList.remove('opacity-100', 'translate-y-0', 'scale-100', 'visible', 'pointer-events-auto');
                    servicesBtn.classList.remove('bg-white/10', 'text-white');
                    servicesChevron.classList.remove('rotate-180');
                }, 200);
            });
        }

        // Profile Dropdown (Desktop)
        const profileContainer = document.getElementById('profile-dropdown-container');
        const profileMenu = document.getElementById('profile-menu');
        const profileBtn = document.getElementById('profile-btn');
        const profileChevron = document.getElementById('profile-chevron');

        if(profileContainer && profileMenu) {
            profileBtn.addEventListener('click', () => {
                profileMenu.classList.toggle('opacity-0');
                profileMenu.classList.toggle('scale-95');
                profileMenu.classList.toggle('invisible');
                profileMenu.classList.toggle('pointer-events-none');
                
                profileMenu.classList.toggle('opacity-100');
                profileMenu.classList.toggle('scale-100');
                profileMenu.classList.toggle('visible');
                profileMenu.classList.toggle('pointer-events-auto');
                
                profileChevron.classList.toggle('rotate-180');
            });
            // Click outside to close
            document.addEventListener('click', (e) => {
                if(!profileContainer.contains(e.target) && !profileMenu.classList.contains('opacity-0')) {
                    profileMenu.classList.add('opacity-0', 'scale-95', 'invisible', 'pointer-events-none');
                    profileMenu.classList.remove('opacity-100', 'scale-100', 'visible', 'pointer-events-auto');
                    profileChevron.classList.remove('rotate-180');
                }
            });
        }

        // Mobile Menu Toggle
        const mobileBtn = document.getElementById('mobile-menu-btn');
        const mobileMenu = document.getElementById('mobile-menu');
        const iconMenu = document.getElementById('icon-menu');
        const iconClose = document.getElementById('icon-close');
        
        if(mobileBtn && mobileMenu) {
            mobileBtn.addEventListener('click', () => {
                const isOpen = mobileMenu.classList.contains('py-8');
                if (isOpen) {
                    mobileMenu.classList.remove('max-h-[85vh]', 'overflow-y-auto', 'py-8');
                    mobileMenu.classList.add('max-h-0');
                    iconMenu.classList.remove('hidden');
                    iconClose.classList.add('hidden');
                    if (window.scrollY <= 50) {
                        nav.classList.remove('bg-[#221022]/65', 'backdrop-blur-xl', 'border-b', 'border-white/5', 'shadow-2xl');
                        nav.classList.add('bg-transparent');
                    }
                } else {
                    mobileMenu.classList.remove('max-h-0');
                    mobileMenu.classList.add('max-h-[85vh]', 'overflow-y-auto', 'py-8');
                    iconMenu.classList.add('hidden');
                    iconClose.classList.remove('hidden');
                    nav.classList.remove('bg-transparent');
                    nav.classList.add('bg-[#221022]/65', 'backdrop-blur-xl', 'border-b', 'border-white/5', 'shadow-2xl');
                }
            });
        }
    });
</script>

