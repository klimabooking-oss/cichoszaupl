<section class="bg-[#221022] relative overflow-hidden" id="testimonials" style="padding-top: clamp(50px, 6vw, 60px); padding-bottom: clamp(50px, 6vw, 60px);">
    <div class="absolute -right-40 top-20 w-80 h-80 bg-[#f20df2] rounded-full blur-[120px] opacity-15 pointer-events-none"></div>
    <div class="absolute -left-40 bottom-20 w-80 h-80 bg-[#ff5f1f] rounded-full blur-[120px] opacity-10 pointer-events-none"></div>

    <div class="max-w-7xl mx-auto px-5">

        <div class="text-center mb-16" data-animate="fade-up">
            <div class="mt-6 flex justify-center">
                <h2 class="sr-only">Opinie Klientów Wypożyczalni CICHOSZAU - Zobacz Co O Nas Mówią</h2>
                <div aria-hidden="true" class="text-4xl md:text-6xl font-black text-white uppercase italic tracking-tighter mb-6 group cursor-default">
                    <span class="inline-block transform -rotate-1 group-hover:rotate-0 transition-transform duration-500 origin-bottom-left">
                        Co mówią
                    </span>
                    <br class="hidden md:block" />
                    <span class="inline-block text-transparent bg-clip-text bg-gradient-to-r from-[#f20df2] to-[#ff5f1f] transform rotate-2 group-hover:rotate-0 transition-transform duration-500 origin-bottom-right pb-2">
                        nasi klienci?
                    </span>
                </div>
            </div>
            <div class="line-glow-scroll w-full h-px mt-6" style="margin-top: 20px !important; height: 1px; width: 100%; background: linear-gradient(to right, transparent, #f20df2, transparent); box-shadow: 0 0 20px rgba(242,13,242,0.8);"></div>
        </div>

        <!-- Carousel wrapper -->
        <div class="relative w-full overflow-hidden" id="testimonials-wrapper">
