<div class="min-h-screen bg-[#221022] pt-32 pb-20 px-4 md:px-8">
    <div class="max-w-6xl mx-auto">
        <div class="flex flex-col md:flex-row md:items-center justify-between gap-6 mb-12">
            <div>
                <h1 class="text-4xl md:text-5xl font-black text-white uppercase italic tracking-wider mb-2">Moje Konto</h1>
                <p class="text-gray-400 text-lg">Witaj, {{ customer.first_name | default: 'Użytkowniku' }}</p>
            </div>
            <div class="flex flex-wrap items-center gap-4">
                <a href="/pages/moje-bilety" class="inline-flex items-center justify-center px-6 py-3 rounded-full text-[#0a050a] bg-gradient-to-r from-[#f20df2] via-[#ff5f1f] to-[#ffd700] hover:scale-105 transition-transform gap-2 font-black text-sm tracking-wider uppercase shadow-[0_0_20px_rgba(242,13,242,0.3)]">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 9a3 3 0 0 1 0 6v2a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-2a3 3 0 0 1 0-6V7a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2Z"/><path d="M13 5v2"/><path d="M13 17v2"/><path d="M13 11v2"/></svg>
                    Moje Bilety QR
                </a>
                <a href="{{ routes.account_logout_url }}" class="inline-flex items-center justify-center px-6 py-3 border border-white/20 rounded-full text-white hover:bg-white hover:text-[#0a050a] transition-colors gap-2 font-bold text-sm tracking-wider uppercase">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" x2="9" y1="12" y2="12"/></svg>
                    Wyloguj
                </a>
            </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            <div class="lg:col-span-2 space-y-8">
                <div class="bg-[#221022] border border-white/10 rounded-3xl p-8 relative overflow-hidden group">
                    <div class="absolute inset-0 bg-gradient-to-r from-[#f20df2]/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none"></div>
                    <div class="relative z-10">
                        <h2 class="text-2xl font-black text-white uppercase tracking-wider mb-6 flex items-center gap-3">
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#f20df2" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/><path d="M3 6h18"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
                            Historia Zamówień
                        </h2>
                        
                        {% if customer.orders.size > 0 %}
                            <div class="space-y-4">
                                {% for order in customer.orders %}
                                    <div class="border border-white/5 bg-black/30 rounded-2xl p-6 hover:border-white/10 transition-colors">
                                        <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-4 pb-4 border-b border-white/5">
                                            <div>
                                                <div class="text-[#f20df2] font-bold text-lg">Zamówienie {{ order.name }}</div>
                                                <div class="text-gray-400 text-sm mt-1">{{ order.created_at | time_tag: format: 'date' }}</div>
                                            </div>
                                            <div class="flex items-center gap-4">
                                                <div class="px-3 py-1 bg-white/5 rounded-full text-xs font-bold uppercase tracking-wider text-white">
                                                    {{ order.financial_status_label }}
                                                </div>
                                                <div class="px-3 py-1 bg-[#f20df2]/10 rounded-full text-xs font-bold uppercase tracking-wider text-[#f20df2]">
                                                    {{ order.fulfillment_status_label }}
                                                </div>
                                            </div>
                                        </div>
                                        <div class="flex items-center justify-between">
                                            <div class="text-gray-400 text-sm">{{ order.line_items.size }} produkty</div>
                                            <div class="text-white font-black text-xl">{{ order.total_price | money }}</div>
                                        </div>
                                        <a href="{{ order.customer_url }}" class="mt-4 w-full block text-center py-3 bg-white/5 hover:bg-white/10 rounded-xl text-white text-sm font-bold uppercase tracking-wider transition-colors">
                                            Zobacz szczegóły
                                        </a>
                                    </div>
                                {% endfor %}
                            </div>
                        {% else %}
                            <div class="text-center py-12 bg-black/30 rounded-2xl border border-white/5">
                                <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" class="mx-auto text-gray-600 mb-4"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/><path d="M3 6h18"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
                                <p class="text-gray-400 mb-6">Nie złożyłeś jeszcze żadnego zamówienia.</p>
                                <a href="{{ routes.all_products_collection_url }}" class="inline-block px-8 py-3 bg-[#f20df2] text-white font-black uppercase tracking-widest rounded-xl hover:shadow-[0_0_20px_rgba(242,13,242,0.4)] transition-shadow">Rozpocznij zakupy</a>
                            </div>
                        {% endif %}
                    </div>
                </div>
            </div>
            
            <div class="space-y-8">
                <div class="bg-[#221022] border border-white/10 rounded-3xl p-8 relative overflow-hidden group h-full">
                    <div class="absolute inset-0 bg-gradient-to-b from-purple-600/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none"></div>
                    <div class="relative z-10">
                        <h2 class="text-2xl font-black text-white uppercase tracking-wider mb-6 flex items-center gap-3">
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-purple-400"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
                            Dane Konta
                        </h2>
                        
                        <div class="space-y-6">
                            <div class="border-b border-white/5 pb-6">
                                <h3 class="text-xs font-bold text-gray-500 uppercase tracking-widest mb-2">Główny adres</h3>
                                {% if customer.default_address %}
                                    <div class="text-gray-300 text-sm space-y-1">
                                        <p class="text-white font-bold">{{ customer.default_address.first_name }} {{ customer.default_address.last_name }}</p>
                                        <p>{{ customer.default_address.address1 }}</p>
                                        {% if customer.default_address.address2 != "" %}
                                            <p>{{ customer.default_address.address2 }}</p>
                                        {% endif %}
                                        <p>{{ customer.default_address.zip }} {{ customer.default_address.city }}</p>
                                        {% if customer.default_address.province != "" %}
                                            <p>{{ customer.default_address.province }}</p>
                                        {% endif %}
                                        <p>{{ customer.default_address.country }}</p>
                                    </div>
                                {% else %}
                                    <p class="text-gray-400 text-sm italic">Brak zapisanego adresu</p>
                                {% endif %}
                            </div>
                            
                            <a href="{{ routes.account_addresses_url }}" class="w-full block text-center py-4 bg-white/5 border border-white/10 hover:bg-white hover:text-[#0a050a] rounded-xl text-white text-sm font-bold uppercase tracking-wider transition-all duration-300">
                                Zarządzaj adresami ({{ customer.addresses_count }})
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
