<section class="bg-[#221022] relative" id="faq" style="padding-top: clamp(50px, 6vw, 60px); padding-bottom: clamp(50px, 6vw, 60px);">
    <div class="max-w-4xl mx-auto px-5">
        
        <div class="text-center mb-16" data-animate="fade-up">
            <div class="mt-6 flex justify-center">
                <h2 class="sr-only">Wypożyczalnia CICHOSZAU - Najczęstsze Pytania i Odpowiedzi (FAQ)</h2>
                <div aria-hidden="true" class="text-4xl md:text-6xl font-black text-white uppercase italic tracking-tighter mb-6 group cursor-default">
                    <span class="inline-block transform -rotate-1 group-hover:rotate-0 transition-transform duration-500 origin-bottom-left">
                        {{ section.settings.title | default: 'Częste' | replace: '[MIASTO]', metaobject.nazwa.value | replace: ' [MIASTO]', '' }}
                    </span>
                    <span class="inline-block text-transparent bg-clip-text bg-gradient-to-r from-[#f20df2] via-[#ff5f1f] to-[#ffd700] transform rotate-2 group-hover:rotate-0 transition-transform duration-500 origin-bottom-right pb-2">
                        {{ section.settings.highlight | default: 'Pytania' }}
                    </span>
                </div>
            </div>
            <div class="line-glow-scroll w-full h-px mt-6" style="margin-top: 20px !important; height: 1px; width: 100%; background: linear-gradient(to right, transparent, #f20df2, transparent); box-shadow: 0 0 20px rgba(242,13,242,0.8);"></div>
        </div>

        <div class="space-y-4" id="faq-accordion" data-animate-stagger="fade-up">
            {% assign faqs = section.blocks | where: "type", "faq" %}
            {% for block in faqs %}
                <div class="faq-item rounded-3xl glass-card overflow-hidden transition-all duration-500 border border-[#f20df2]/40 shadow-[0_0_20px_rgba(242,13,242,0.15)] hover:shadow-[0_0_30px_rgba(242,13,242,0.3)]">
                    <button class="faq-btn w-full px-6 py-5 flex justify-between items-center text-left focus:outline-none group select-none" aria-expanded="false">
                        <span class="faq-question text-lg font-bold text-white group-hover:text-[#f20df2] transition-colors duration-300">
                            {{ block.settings.question }}
                        </span>
                    </button>
                    <div class="faq-content grid grid-rows-[0fr] opacity-0 transition-all duration-300 ease-in-out">
                        <div class="overflow-hidden">
                            <div class="px-6 pb-6 pt-0 text-gray-400 leading-relaxed border-t border-[#f20df2]/40 shadow-[0_0_20px_rgba(242,13,242,0.15)] mt-2 pt-4">
                                {{ block.settings.answer }}
                            </div>
                        </div>
                    </div>
                </div>
            {% else %}
                <!-- Fallback defaults -->
            {% assign def_q = 'Ile kosztuje wynajem i logistyka sprzętu do miasta [MIASTO]?,Z jakim wyprzedzeniem muszę zarezerwować sprzęt na event w mieście [MIASTO]?,Jak wygląda powrót paczek ze słuchawkami z miasta [MIASTO]?,Czy sprzęt jest trudny w obsłudze?,Jaki jest zasięg słuchawek?,Czy mogę podłączyć własną muzykę?' | split: ',' %}
                {% assign def_a = "Koszty dostawy kurierskiej dla miasta [MIASTO] są w pełni zryczałtowane. Podstawiasz paczkę z wyposażeniem i płacisz tylko za czas wynajmu.|Zalecamy rezerwację minimum 2 tygodnie przed wydarzeniem w sezonie. Często jednak realizujemy ekspresowe zamówienia (last minute) dla klientów z miasta [MIASTO] i okolic z dostawą w 24h.|Paczka posiada automatycznie wygenerowany list przewozowy zwrotny. Po zakończeniu integracji w mieście [MIASTO], po prostu przekazujesz zamkniętą skrzynię kurierowi w wyznaczonym dniu.|Absolutnie nie! Nasz system jest typu 'Plug & Play'. Wystarczy podłączyć nadajnik do prądu i źródła dźwięku (telefon, laptop, mikser).|W otwartej przestrzeni nasze nadajniki mają zasięg do 500 metrów. Wewnątrz budynków sygnał swobodnie przenika przez stropy.|Tak, nadajniki posiadają standardowe wejścia, co pozwala podłączyć telefon czy konsolę DJ-ską." | split: '|' %}
                
                {% for question in def_q %}
                    {% assign current_q = question | replace: '[MIASTO]', metaobject.nazwa.value | replace: ' [MIASTO]', '' %}
                    {% assign current_a = def_a[forloop.index0] | replace: '[MIASTO]', metaobject.nazwa.value | replace: ' [MIASTO]', '' %}
                    <div class="faq-item rounded-3xl glass-card overflow-hidden transition-all duration-500 border border-[#f20df2]/40 shadow-[0_0_20px_rgba(242,13,242,0.15)] hover:shadow-[0_0_30px_rgba(242,13,242,0.3)]">
                    <button class="faq-btn w-full px-6 py-5 flex justify-between items-center text-left focus:outline-none group select-none" aria-expanded="false">
                        <span class="faq-question text-lg font-bold text-white group-hover:text-[#f20df2] transition-colors duration-300">
                            {{ current_q }}
                        </span>
                    </button>
                    <div class="faq-content grid grid-rows-[0fr] opacity-0 transition-all duration-300 ease-in-out">
                        <div class="overflow-hidden">
                            <div class="px-6 pb-6 pt-0 text-gray-400 leading-relaxed border-t border-[#f20df2]/40 shadow-[0_0_20px_rgba(242,13,242,0.15)] mt-2 pt-4">
                                {{ current_a }}
                            </div>
                        </div>
                    </div>
                </div>
                {% endfor %}
            {% endfor %}
        </div>

        <!-- Internal linking — powiązane strony -->
        <div class="mt-14 pt-10 grid grid-cols-1 sm:grid-cols-3 gap-4" data-animate="fade-up">
            <a href="/#rental"
               class="group flex items-center gap-3 p-4 rounded-2xl bg-white/[0.02] transition-all duration-300" style="border: 1px solid rgba(242,13,242,0.4); box-shadow: 0 0 20px rgba(242,13,242,0.15);" onmouseenter="this.style.borderColor='rgba(242,13,242,0.6)'; this.style.boxShadow='0 0 30px rgba(242,13,242,0.2)'" onmouseleave="this.style.borderColor='rgba(242,13,242,0.3)'; this.style.boxShadow='0 0 20px rgba(242,13,242,0.1)'">
                <div class="w-8 h-8 rounded-full bg-[#f20df2]/15 flex items-center justify-center flex-shrink-0 group-hover:bg-[#f20df2]/30 transition-all">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#f20df2" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 9a3 3 0 0 1 0 6v2a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-2a3 3 0 0 1 0-6V7a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2Z"/></svg>
                </div>
                <div>
                    <div class="text-white font-black text-xs uppercase tracking-wider group-hover:text-[#f20df2] transition-colors">Wynajem słuchawek</div>
                    <div class="text-gray-600 text-xs">Oferta i cennik →</div>
                </div>
            </a>
            <a href="/#rental"
               class="group flex items-center gap-3 p-4 rounded-2xl bg-white/[0.02] transition-all duration-300" style="border: 1px solid rgba(242,13,242,0.4); box-shadow: 0 0 20px rgba(242,13,242,0.15);" onmouseenter="this.style.borderColor='rgba(242,13,242,0.6)'; this.style.boxShadow='0 0 30px rgba(242,13,242,0.2)'" onmouseleave="this.style.borderColor='rgba(242,13,242,0.3)'; this.style.boxShadow='0 0 20px rgba(242,13,242,0.1)'">
                <div class="w-8 h-8 rounded-full bg-[#ff5f1f]/15 flex items-center justify-center flex-shrink-0 group-hover:bg-[#ff5f1f]/30 transition-all">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#ff5f1f" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="14" x="2" y="5" rx="2"/><line x1="2" x2="22" y1="10" y2="10"/></svg>
                </div>
                <div>
                    <div class="text-white font-black text-xs uppercase tracking-wider group-hover:text-[#ff5f1f] transition-colors">Kalkulator online</div>
                    <div class="text-gray-600 text-xs">Wycena w 30 sekund →</div>
                </div>
            </a>
            <a href="/pages/imprezy-firmowe-silent-disco"
               class="group flex items-center gap-3 p-4 rounded-2xl bg-white/[0.02] transition-all duration-300" style="border: 1px solid rgba(242,13,242,0.4); box-shadow: 0 0 20px rgba(242,13,242,0.15);" onmouseenter="this.style.borderColor='rgba(242,13,242,0.6)'; this.style.boxShadow='0 0 30px rgba(242,13,242,0.2)'" onmouseleave="this.style.borderColor='rgba(242,13,242,0.3)'; this.style.boxShadow='0 0 20px rgba(242,13,242,0.1)'">
                <div class="w-8 h-8 rounded-full bg-[#ffd700]/15 flex items-center justify-center flex-shrink-0 group-hover:bg-[#ffd700]/30 transition-all">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#ffd700" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="14" x="2" y="7" rx="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>
                </div>
                <div>
                    <div class="text-white font-black text-xs uppercase tracking-wider group-hover:text-[#ffd700] transition-colors">Imprezy firmowe</div>
                    <div class="text-gray-600 text-xs">B2B & integracje →</div>
                </div>
            </a>
        </div>

    </div>

    <!-- FAQ Accordion JS -->
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const faqItems = document.querySelectorAll('.faq-item');
            let openIndex = 0; // First item open by default like original

            const toggle = (index) => {
                faqItems.forEach((item, i) => {
                    const btn = item.querySelector('.faq-btn');
                    const content = item.querySelector('.faq-content');
                    const icon = item.querySelector('.faq-icon');
                    const question = item.querySelector('.faq-question');

                    if (i === index) {
                        // If it's the clicked item, toggle it
                        if (openIndex === index) {
                            // Close it
                            content.classList.replace('grid-rows-[1fr]', 'grid-rows-[0fr]');
                            content.classList.replace('opacity-100', 'opacity-0');
                            question.classList.remove('text-[#f20df2]');
                            question.classList.add('text-white');
                            openIndex = null;
                        } else {
                            // Open it
                            content.classList.replace('grid-rows-[0fr]', 'grid-rows-[1fr]');
                            content.classList.replace('opacity-0', 'opacity-100');
                            question.classList.add('text-[#f20df2]');
                            question.classList.remove('text-white');
                            openIndex = index;
                        }
                    } else {
                        // Close others
                        content.classList.replace('grid-rows-[1fr]', 'grid-rows-[0fr]');
                        content.classList.replace('opacity-100', 'opacity-0');
                        question.classList.remove('text-[#f20df2]');
                        question.classList.add('text-white');
                    }
                });
            };

            // Init first item
            if (faqItems.length > 0) {
                const item = faqItems[0];
                const content = item.querySelector('.faq-content');
                const question = item.querySelector('.faq-question');
                
                content.classList.replace('grid-rows-[0fr]', 'grid-rows-[1fr]');
                content.classList.replace('opacity-0', 'opacity-100');
                question.classList.add('text-[#f20df2]');
                question.classList.remove('text-white');
            }

            // Listeners
            faqItems.forEach((item, index) => {
                const btn = item.querySelector('.faq-btn');
                btn.addEventListener('click', () => toggle(index));
            });
        });
    </script>

    <!-- SEO Schema Markup for FAQ -->
    {% if section.blocks.size > 0 %}
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {% for block in faqs %}
        {
          "@type": "Question",
          {% assign schema_q = block.settings.question | replace: '[MIASTO]', metaobject.nazwa.value | replace: ' [MIASTO]', '' %}
          {% assign schema_a = block.settings.answer | replace: '[MIASTO]', metaobject.nazwa.value | replace: ' [MIASTO]', '' %}
          "name": {{ schema_q | json }},
          "acceptedAnswer": {
            "@type": "Answer",
            "text": {{ schema_a | json }}
          }
        }{% unless forloop.last %},{% endunless %}
        {% endfor %}
      ]
    }
    </script>
    {% else %}
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {% for question in def_q %}
        {
          "@type": "Question",
          {% assign schema_def_q = question | replace: '[MIASTO]', metaobject.nazwa.value | replace: ' [MIASTO]', '' %}
          {% assign schema_def_a = def_a[forloop.index0] | replace: '[MIASTO]', metaobject.nazwa.value | replace: ' [MIASTO]', '' %}
          "name": {{ schema_def_q | json }},
          "acceptedAnswer": {
            "@type": "Answer",
            "text": {{ schema_def_a | json }}
          }
        }{% unless forloop.last %},{% endunless %}
        {% endfor %}
      ]
    }
    </script>
    {% endif %}
</section>

{% schema %}
{
  "name": "FAQ Section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Częste"
    },
    {
      "type": "text",
      "id": "highlight",
      "label": "Highlight Text",
      "default": "Pytania"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Wszystko, co musisz wiedzieć o organizacji cichej imprezy."
    }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "FAQ Item",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "Twoje pytanie tutaj"
        },
        {
          "type": "textarea",
          "id": "answer",
          "label": "Answer",
          "default": "Twoja odpowiedź tutaj..."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ Section"
    }
  ]
}
{% endschema %}
