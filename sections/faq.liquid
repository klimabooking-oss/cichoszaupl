<section class="bg-[#221022] relative" id="faq" style="padding-top: 60px; padding-bottom: 60px;">
    <div class="section-sep" aria-hidden="true"></div>
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        
        <div class="text-center mb-16" data-animate="fade-up">
            <span class="text-gray-400 font-bold uppercase tracking-widest text-sm mb-2 flex items-center justify-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><path d="M12 17h.01"/></svg>
                Baza Wiedzy
            </span>
            <div class="mt-6 flex justify-center">
                <h2 class="sr-only">Wypożyczalnia CICHOSZAU - Najczęstsze Pytania i Odpowiedzi (FAQ)</h2>
                <div aria-hidden="true" class="text-4xl md:text-6xl font-black text-white uppercase italic tracking-tighter mb-6 group cursor-default">
                    <span class="inline-block transform -rotate-1 group-hover:rotate-0 transition-transform duration-500 origin-bottom-left">
                        {{ section.settings.title | default: 'Częste' }}
                    </span>
                    <span class="inline-block text-transparent bg-clip-text bg-gradient-to-r from-[#f20df2] via-[#ff5f1f] to-[#ffd700] transform rotate-2 group-hover:rotate-0 transition-transform duration-500 origin-bottom-right pb-2">
                        {{ section.settings.highlight | default: 'Pytania' }}
                    </span>
                </div>
            </div>
            <p class="text-gray-400 max-w-lg mx-auto mt-4">
                {{ section.settings.subtitle | default: 'Wszystko, co musisz wiedzieć o organizacji cichej imprezy.' }}
            </p>
        </div>

        <div class="space-y-4" id="faq-accordion" data-animate-stagger="fade-up">
            {% assign faqs = section.blocks | where: "type", "faq" %}
            {% for block in faqs %}
                <div class="faq-item border border-white/10 rounded-2xl bg-[#221022] overflow-hidden transition-all duration-300 hover:border-white/20">
                    <button class="faq-btn w-full px-6 py-5 flex justify-between items-center text-left focus:outline-none group select-none">
                        <span class="faq-question text-lg font-bold text-white group-hover:text-[#f20df2] transition-colors duration-300">
                            {{ block.settings.question }}
                        </span>
                    </button>
                    <div class="faq-content grid grid-rows-[0fr] opacity-0 transition-all duration-300 ease-in-out">
                        <div class="overflow-hidden">
                            <div class="px-6 pb-6 pt-0 text-gray-400 leading-relaxed border-t border-white/5 mt-2 pt-4">
                                {{ block.settings.answer }}
                            </div>
                        </div>
                    </div>
                </div>
            {% else %}
                <!-- Fallback defaults -->
                {% assign def_q = 'Czym dokładnie jest Silent Disco?,Ile wcześniej muszę zarezerwować sprzęt?,Jak wygląda kwestia higieny słuchawek?,Czy sprzęt jest trudny w obsłudze?,Jaki jest zasięg słuchawek?,Czy mogę podłączyć własną muzykę?' | split: ',' %}
                {% assign def_a = "Silent Disco to impreza, na której uczestnicy słuchają muzyki przez bezprzewodowe słuchawki, a nie z głośników. Każdy zestaw ma przełącznik kanałów, co pozwala wybierać między 3 różnymi stylami muzycznymi granymi przez DJ-ów jednocześnie. To idealne rozwiązanie na eventy w miejscach, gdzie hałas jest problemem.|Zalecamy rezerwację minimum 2 tygodnie przed planowanym wydarzeniem, szczególnie w sezonie letnim i karnawałowym. Jednak dzięki dużemu magazynowi często jesteśmy w stanie zrealizować zamówienia 'last minute' nawet z dnia na dzień.|Bezpieczeństwo i higiena to nasz priorytet. Każda para słuchawek po zwrocie przechodzi proces dezynfekcji i czyszczenia. Dodatkowo oferujemy jednorazowe nakładki higieniczne na nauszniki dla pełnego komfortu uczestników.|Absolutnie nie! Nasz system jest typu 'Plug & Play'. Wystarczy podłączyć nadajnik do prądu i źródła dźwięku (telefon, laptop, mikser DJ). Do każdego zestawu dołączamy prostą instrukcję wideo oraz checklistę. Słuchawki łączą się automatycznie.|W otwartej przestrzeni nasze nadajniki mają zasięg do 500 metrów. Wewnątrz budynków sygnał swobodnie przenika przez ściany i stropy, pokrywając zazwyczaj 2-3 kondygnacje lub kilka sal konferencyjnych bez zakłóceń.|Tak, nadajniki posiadają standardowe wejścia (RCA, Mini-Jack), co pozwala podłączyć telefon, laptopa, tablet czy profesjonalną konsolę DJ-ską. Możesz puścić gotową playlistę ze Spotify lub zatrudnić DJ-a." | split: '|' %}
                
                {% for question in def_q %}
                    <div class="faq-item border border-white/10 rounded-2xl bg-[#221022] overflow-hidden transition-all duration-300 hover:border-white/20">
                    <button class="faq-btn w-full px-6 py-5 flex justify-between items-center text-left focus:outline-none group select-none">
                        <span class="faq-question text-lg font-bold text-white group-hover:text-[#f20df2] transition-colors duration-300">
                            {{ question }}
                        </span>
                    </button>
                    <div class="faq-content grid grid-rows-[0fr] opacity-0 transition-all duration-300 ease-in-out">
                        <div class="overflow-hidden">
                            <div class="px-6 pb-6 pt-0 text-gray-400 leading-relaxed border-t border-white/5 mt-2 pt-4">
                                {{ def_a[forloop.index0] }}
                            </div>
                        </div>
                    </div>
                </div>
                {% endfor %}
            {% endfor %}
        </div>

        <!-- Internal linking — powiązane strony -->
        <div class="mt-14 pt-10 border-t border-white/5 grid grid-cols-1 sm:grid-cols-3 gap-4" data-animate="fade-up">
            <a href="/#rental"
               class="group flex items-center gap-3 p-4 rounded-2xl border border-white/10 bg-white/[0.02] hover:border-[#f20df2]/40 hover:bg-[#f20df2]/5 transition-all duration-300">
                <div class="w-8 h-8 rounded-full bg-[#f20df2]/15 flex items-center justify-center flex-shrink-0 group-hover:bg-[#f20df2]/30 transition-all">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#f20df2" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 9a3 3 0 0 1 0 6v2a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-2a3 3 0 0 1 0-6V7a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2Z"/></svg>
                </div>
                <div>
                    <div class="text-white font-black text-xs uppercase tracking-wider group-hover:text-[#f20df2] transition-colors">Wynajem słuchawek</div>
                    <div class="text-gray-600 text-xs">Oferta i cennik →</div>
                </div>
            </a>
            <a href="/#rental"
               class="group flex items-center gap-3 p-4 rounded-2xl border border-white/10 bg-white/[0.02] hover:border-[#ff5f1f]/40 hover:bg-[#ff5f1f]/5 transition-all duration-300">
                <div class="w-8 h-8 rounded-full bg-[#ff5f1f]/15 flex items-center justify-center flex-shrink-0 group-hover:bg-[#ff5f1f]/30 transition-all">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#ff5f1f" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="14" x="2" y="5" rx="2"/><line x1="2" x2="22" y1="10" y2="10"/></svg>
                </div>
                <div>
                    <div class="text-white font-black text-xs uppercase tracking-wider group-hover:text-[#ff5f1f] transition-colors">Kalkulator online</div>
                    <div class="text-gray-600 text-xs">Wycena w 30 sekund →</div>
                </div>
            </a>
            <a href="/pages/imprezy-firmowe-silent-disco"
               class="group flex items-center gap-3 p-4 rounded-2xl border border-white/10 bg-white/[0.02] hover:border-[#ffd700]/40 hover:bg-[#ffd700]/5 transition-all duration-300">
                <div class="w-8 h-8 rounded-full bg-[#ffd700]/15 flex items-center justify-center flex-shrink-0 group-hover:bg-[#ffd700]/30 transition-all">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#ffd700" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="14" x="2" y="7" rx="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>
                </div>
                <div>
                    <div class="text-white font-black text-xs uppercase tracking-wider group-hover:text-[#ffd700] transition-colors">Imprezy firmowe</div>
                    <div class="text-gray-600 text-xs">B2B & integracje →</div>
                </div>
            </a>
        </div>

    </div>

    <!-- FAQ Accordion JS -->
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const faqItems = document.querySelectorAll('.faq-item');
            let openIndex = 0; // First item open by default like original

            const toggle = (index) => {
                faqItems.forEach((item, i) => {
                    const btn = item.querySelector('.faq-btn');
                    const content = item.querySelector('.faq-content');
                    const icon = item.querySelector('.faq-icon');
                    const question = item.querySelector('.faq-question');

                    if (i === index) {
                        // If it's the clicked item, toggle it
                        if (openIndex === index) {
                            // Close it
                            content.classList.replace('grid-rows-[1fr]', 'grid-rows-[0fr]');
                            content.classList.replace('opacity-100', 'opacity-0');
                            question.classList.remove('text-[#f20df2]');
                            question.classList.add('text-white');
                            openIndex = null;
                        } else {
                            // Open it
                            content.classList.replace('grid-rows-[0fr]', 'grid-rows-[1fr]');
                            content.classList.replace('opacity-0', 'opacity-100');
                            question.classList.add('text-[#f20df2]');
                            question.classList.remove('text-white');
                            openIndex = index;
                        }
                    } else {
                        // Close others
                        content.classList.replace('grid-rows-[1fr]', 'grid-rows-[0fr]');
                        content.classList.replace('opacity-100', 'opacity-0');
                        question.classList.remove('text-[#f20df2]');
                        question.classList.add('text-white');
                    }
                });
            };

            // Init first item
            if (faqItems.length > 0) {
                const item = faqItems[0];
                const content = item.querySelector('.faq-content');
                const question = item.querySelector('.faq-question');
                
                content.classList.replace('grid-rows-[0fr]', 'grid-rows-[1fr]');
                content.classList.replace('opacity-0', 'opacity-100');
                question.classList.add('text-[#f20df2]');
                question.classList.remove('text-white');
            }

            // Listeners
            faqItems.forEach((item, index) => {
                const btn = item.querySelector('.faq-btn');
                btn.addEventListener('click', () => toggle(index));
            });
        });
    </script>

    <!-- SEO Schema Markup for FAQ -->
    {% if section.blocks.size > 0 %}
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {% for block in faqs %}
        {
          "@type": "Question",
          "name": {{ block.settings.question | json }},
          "acceptedAnswer": {
            "@type": "Answer",
            "text": {{ block.settings.answer | json }}
          }
        }{% unless forloop.last %},{% endunless %}
        {% endfor %}
      ]
    }
    </script>
    {% else %}
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {% for question in def_q %}
        {
          "@type": "Question",
          "name": {{ question | json }},
          "acceptedAnswer": {
            "@type": "Answer",
            "text": {{ def_a[forloop.index0] | json }}
          }
        }{% unless forloop.last %},{% endunless %}
        {% endfor %}
      ]
    }
    </script>
    {% endif %}
</section>

{% schema %}
{
  "name": "FAQ Section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Częste"
    },
    {
      "type": "text",
      "id": "highlight",
      "label": "Highlight Text",
      "default": "Pytania"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Wszystko, co musisz wiedzieć o organizacji cichej imprezy."
    }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "FAQ Item",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "Twoje pytanie tutaj"
        },
        {
          "type": "textarea",
          "id": "answer",
          "label": "Answer",
          "default": "Twoja odpowiedź tutaj..."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ Section"
    }
  ]
}
{% endschema %}
