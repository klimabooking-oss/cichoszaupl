<section class="bg-[#221022] py-20 relative overflow-hidden" id="b2b-features">
    <!-- Tło noise -->
    <div class="absolute inset-0 bg-[url('https://grainy-gradients.vercel.app/noise.svg')] opacity-10 pointer-events-none z-10 mix-blend-overlay"></div>

    <div class="max-w-7xl mx-auto px-5 relative z-20">
        
        <!-- Nagłówek -->
        <div class="text-center mb-16" data-animate="fade-up">
            <div class="inline-flex items-center px-4 py-1.5 rounded-full border border-[#f20df2]/30 glass-card mb-6">
                <span class="flex h-2 w-2 rounded-full bg-[#f20df2] mr-2 animate-pulse"></span>
                <span class="text-[10px] font-bold text-white tracking-widest uppercase">Sprawdzone na setkach firmówek</span>
            </div>
            <h2 class="text-3xl md:text-5xl font-black text-white uppercase italic tracking-tighter mb-6 group cursor-default">
                Dlaczego Silent Disco<br>
                <span class="text-transparent bg-clip-text bg-gradient-to-r from-[#f20df2] to-[#ff5f1f]">to strzał w dziesiątkę?</span>
            </h2>
            <p class="text-gray-400 max-w-2xl mx-auto text-sm md:text-base leading-relaxed">
                Idealne rozwiązanie dla działów HR i organizatorów eventów. Gwarancja doskonałej frekwencji na parkiecie bez ryzyka skarg na hałas.
            </p>
        </div>

        <!-- Karty korzyści -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6" data-animate-stagger="fade-up">
            
            <!-- Karta 1 -->
            <div class="glass-card border border-[#f20df2]/30 shadow-[0_0_20px_rgba(242,13,242,0.1)] rounded-3xl p-8 hover:-translate-y-2 transition-transform duration-300 group">
                <div class="w-14 h-14 rounded-2xl bg-[#f20df2]/10 border border-[#f20df2]/30 flex items-center justify-center mb-6 group-hover:bg-[#f20df2] transition-colors duration-300">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[#f20df2] group-hover:text-white"><path d="M12 2a3 3 0 0 0-3 3v7a3 3 0 0 0 6 0V5a3 3 0 0 0-3-3Z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" x2="12" y1="19" y2="22"/></svg>
                </div>
                <h3 class="text-xl font-bold text-white mb-3">Koniec ze skargami na hałas</h3>
                <p class="text-gray-400 text-sm leading-relaxed">
                    Organizacja imprezy w centrum miasta czy w obiekcie, gdzież zaraz obok śpią inni goście hotelowi? Muzyka gra tylko w słuchawkach, a na zewnątrz panuje absolutna cisza. 
                </p>
            </div>

            <!-- Karta 2 -->
            <div class="glass-card border border-[#ff5f1f]/30 shadow-[0_0_20px_rgba(255,95,31,0.1)] rounded-3xl p-8 hover:-translate-y-2 transition-transform duration-300 group">
                <div class="w-14 h-14 rounded-2xl bg-[#ff5f1f]/10 border border-[#ff5f1f]/30 flex items-center justify-center mb-6 group-hover:bg-[#ff5f1f] transition-colors duration-300">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[#ff5f1f] group-hover:text-white"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                </div>
                <h3 class="text-xl font-bold text-white mb-3">Łączymy pokolenia</h3>
                <p class="text-gray-400 text-sm leading-relaxed">
                    Zarząd, managerowie i młodsi pracownicy będa bawić się razem. Słuchawki włączają do wspólnego tańca wszystkich, niezależnie od gustów, ułatwiając networking zespołowy.
                </p>
            </div>

            <!-- Karta 3 -->
            <div class="glass-card border border-[#3b82f6]/30 shadow-[0_0_20px_rgba(59,130,246,0.1)] rounded-3xl p-8 hover:-translate-y-2 transition-transform duration-300 group">
                <div class="w-14 h-14 rounded-2xl bg-[#3b82f6]/10 border border-[#3b82f6]/30 flex items-center justify-center mb-6 group-hover:bg-[#3b82f6] transition-colors duration-300">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[#3b82f6] group-hover:text-white"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg>
                </div>
                <h3 class="text-xl font-bold text-white mb-3">3 Kanały Muzyczne</h3>
                <p class="text-gray-400 text-sm leading-relaxed">
                    Uczestnicy sami decydują czego i z kim słuchają! W tym samym czasie w sali gra np. klubowy DJ, klasyczny rock oraz przeboje lat 80 / 90. Trzech DJ-ów, trzy uśmiechy!
                </p>
            </div>

        </div>
    </div>
</section>

{% schema %}
{
  "name": "B2B Features",
  "settings": [],
  "presets": [
    {
      "name": "B2B Features"
    }
  ]
}
{% endschema %}
