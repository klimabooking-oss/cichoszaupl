<section class="bg-[#221022] relative overflow-hidden" id="rental-b2b" style="padding-top: clamp(50px, 6vw, 60px); padding-bottom: clamp(50px, 6vw, 60px);">
    <div class="absolute inset-0 bg-[url('https://grainy-gradients.vercel.app/noise.svg')] opacity-10 pointer-events-none z-10 mix-blend-overlay"></div>

    <div class="max-w-7xl mx-auto px-5 relative z-20">

        <div class="mb-16 text-center" data-animate="fade-up">
            <div class="mt-6 flex justify-center">
                <h2 class="text-4xl md:text-6xl font-black text-white uppercase italic tracking-tighter mb-6 group cursor-default">
                    <span class="inline-block transform -rotate-1 group-hover:rotate-0 transition-transform duration-500 origin-bottom-left">
                        {{ section.settings.title | default: 'Wycena' }}
                    </span>
                    <br class="hidden md:block" />
                    <span class="inline-block text-transparent bg-clip-text bg-gradient-to-r from-[#f20df2] to-[#ff5f1f] transform rotate-2 group-hover:rotate-0 transition-transform duration-500 origin-bottom-right pb-2">
                        {{ section.settings.highlight | default: 'Eventu B2B' }}
                    </span>
                </h2>
            </div>
            <div class="line-glow-scroll w-full h-px mt-6" style="margin-top: 20px !important; height: 1px; width: 100%; background: linear-gradient(to right, transparent, #f20df2, transparent); box-shadow: 0 0 20px rgba(242,13,242,0.8);"></div>
        </div>

        <div class="grid grid-cols-1 xl:grid-cols-12 gap-6 md:gap-8">

            <!-- CONFIGURATION -->
            <div class="xl:col-span-8 space-y-4 md:space-y-6">

                <!-- People -->
                <div class="glass-card border border-[#f20df2]/40 shadow-[0_0_20px_rgba(242,13,242,0.15)] rounded-2xl md:rounded-3xl p-5 md:p-8">
                    <div class="flex justify-between items-center mb-6">
                        <div class="flex items-center gap-3">
                            <div class="w-10 h-10 rounded-full bg-[#f20df2]/20 flex items-center justify-center text-[#f20df2]">
                                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                            </div>
                            <h3 class="text-sm md:text-lg font-bold text-white uppercase tracking-wider">Ilość osób</h3>
                        </div>
                        <div class="flex items-center gap-2">
                            <input
                                type="number"
                                id="calc-ppl-input"
                                value="50"
                                min="20" max="2000"
                                class="w-16 md:w-24 glass-card border border-[#f20df2]/40 shadow-[0_0_20px_rgba(242,13,242,0.15)] rounded-lg px-2 py-1.5 text-base md:text-lg font-black text-white text-right focus:border-[#f20df2] outline-none transition-colors"
                            />
                        </div>
                    </div>

                    <input
                        type="range"
                        id="calc-ppl-slider"
                        min="20"
                        max="1000"
                        step="10"
                        value="50"
                        class="w-full h-2 bg-gray-700 rounded-lg appearance-none cursor-pointer accent-[#f20df2] mb-2"
                        style="background: linear-gradient(to right, #f20df2 5%, #374151 5%);"
                    />
                    <div class="flex justify-between text-[10px] text-gray-500 font-bold uppercase">
                        <span>20</span>
                        <span>500</span>
                        <span>1000+</span>
                    </div>
                </div>

                <!-- Channels & Dates Grid -->
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div class="glass-card border border-[#f20df2]/40 shadow-[0_0_20px_rgba(242,13,242,0.15)] rounded-2xl p-5">
                        <div class="flex justify-between items-center mb-4">
                            <div class="flex items-center gap-3">
                                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[#f20df2]"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg>
                                <h3 class="text-[10px] md:text-xs font-bold text-white uppercase tracking-wider">Liczba DJ-ów (Kanały)</h3>
                            </div>
                            <span id="calc-ch-val" class="text-xl font-black text-white">3</span>
                        </div>
                        <input
                            type="range"
                            id="calc-ch-slider"
                            min="0" max="3" step="1"
                            value="3"
                            class="w-full h-1.5 bg-gray-700 rounded-lg appearance-none cursor-pointer accent-[#f20df2]"
                            style="background: linear-gradient(to right, #f20df2 100%, #374151 100%);"
                        />
                    </div>

                    <div class="glass-card border border-[#f20df2]/40 shadow-[0_0_20px_rgba(242,13,242,0.15)] rounded-2xl p-5 flex flex-col justify-between gap-4">
                        <div class="grid grid-cols-2 gap-4">
                            <div>
                                <label class="text-[10px] font-bold text-gray-500 uppercase block mb-1">Od</label>
                                <input type="date" id="calc-date-start" onclick="if(this.showPicker) this.showPicker()" class="w-full bg-black/30 border border-[#f20df2]/40 shadow-[0_0_20px_rgba(242,13,242,0.15)] rounded px-2 py-1.5 md:py-2 text-xs md:text-sm text-white outline-none cursor-pointer placeholder-gray-400" />
                            </div>
                            <div>
                                <label class="text-[10px] font-bold text-gray-500 uppercase block mb-1">Do</label>
                                <input type="date" id="calc-date-end" onclick="if(this.showPicker) this.showPicker()" class="w-full bg-black/30 border border-[#f20df2]/40 shadow-[0_0_20px_rgba(242,13,242,0.15)] rounded px-2 py-1.5 md:py-2 text-xs md:text-sm text-white outline-none cursor-pointer placeholder-gray-400" />
                            </div>
                        </div>
                        <div>
                            <label class="text-[10px] font-bold text-gray-500 uppercase block mb-1">Lokalizacja (Miasto)</label>
                            <input type="text" id="calc-location" placeholder="np. Wrocław, Warszawa" class="w-full bg-black/30 border border-[#f20df2]/40 shadow-[0_0_20px_rgba(242,13,242,0.15)] rounded px-2 py-1 text-xs text-white outline-none focus:border-[#f20df2] transition-colors" />
                        </div>
                    </div>
                </div>

                <!-- Extras -->
                <div class="glass-card border border-[#f20df2]/40 shadow-[0_0_20px_rgba(242,13,242,0.15)] rounded-2xl p-5">
                    <h3 class="text-[10px] font-bold text-gray-500 uppercase tracking-widest mb-4">Opcje Dodatkowe (Wideo & Event Service)</h3>
                    <div class="grid grid-cols-2 gap-2" id="calc-extras-group">
                        <button data-xtra="video" data-color="#a855f7" class="calc-xt-btn flex flex-col items-center justify-center py-4 rounded-xl border glass-card bg-[#221022]/50 border-[#f20df2]/40 shadow-[0_0_20px_rgba(242,13,242,0.15)] text-gray-400 hover:text-white transition-all">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mb-2"><path d="m22 8-6 4 6 4V8Z"/><rect width="14" height="12" x="2" y="6" rx="2" ry="2"/></svg>
                            <span class="text-xs font-bold uppercase">Nagranie Wideo / Reels</span>
                        </button>
                        <button data-xtra="fullservice" data-color="#3b82f6" class="calc-xt-btn flex flex-col items-center justify-center py-4 rounded-xl border glass-card bg-[#221022]/50 border-[#f20df2]/40 shadow-[0_0_20px_rgba(242,13,242,0.15)] text-gray-400 hover:text-white transition-all">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mb-2"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><line x1="10" y1="9" x2="8" y2="9"/></svg>
                            <span class="text-xs font-bold uppercase">Obsługa Wydarzenia</span>
                        </button>
                    </div>
                </div>
            </div>

            <!-- SUMMARY -->
            <div class="xl:col-span-4">
                <div class="sticky top-24">
                    <div class="glass-card border border-[#f20df2]/40 shadow-[0_0_20px_rgba(242,13,242,0.15)] rounded-2xl p-6">
                        <div class="flex justify-between items-start mb-6">
                            <div>
                                <h3 class="text-xl font-black text-white uppercase italic">Twoja Wycena (B2B)</h3>
                                <p class="text-[10px] text-gray-500 font-bold uppercase tracking-wider"><span id="calc-days-out">1</span> dni wynajmu</p>
                            </div>
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-gray-600"><line x1="4" x2="20" y1="21" y2="14"/><line x1="4" x2="20" y1="10" y2="3"/><line x1="12" x2="12" y1="21" y2="14"/><line x1="12" x2="12" y1="10" y2="3"/></svg>
                        </div>

                        <div class="space-y-2 mb-6 text-sm border-b border-[#f20df2]/40 pb-6" id="calc-breakdown">
                            <!-- Injected by JS -->
                        </div>

                        <div class="mb-2 flex justify-between items-end">
                            <span class="text-gray-500 text-xs font-bold uppercase">Suma Netto</span>
                            <div class="text-2xl font-black text-transparent bg-clip-text bg-gradient-to-r from-[#f20df2] to-[#ffd700]" id="calc-total-out">
                                0 zł
                            </div>
                        </div>
                        <div class="mb-8 flex justify-between items-end">
                            <span class="text-gray-500 text-[10px] font-bold uppercase">Suma Brutto (z 23% VAT)</span>
                            <div class="text-sm font-bold text-gray-400" id="calc-gross-out">
                                0 zł
                            </div>
                        </div>

                        <div class="mb-6 text-center text-gray-400 text-sm">
                            Szacunkowy koszt per uczestnik: <span id="calc-price-per">0</span> zł netto
                        </div>

                        <button
                            id="btn-open-form"
                            class="w-full py-5 rounded-2xl font-black uppercase tracking-widest text-sm text-[#0a050a] flex items-center justify-center gap-2 btn-glow hover:scale-[1.03] active:scale-[0.98] transition-transform"
                            style="background: linear-gradient(to right, #f20df2, #ff5f1f, #ffd700);"
                        >
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m22 2-7 20-4-9-9-4Z"/><path d="M22 2 11 13"/></svg>
                            Złóż zapytanie
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    {% if form.posted_successfully? %}
        <script>
            document.addEventListener('DOMContentLoaded', () => {
                const modal = document.getElementById('booking-modal');
                const formSuccess = document.getElementById('form-success');
                const bookingForm = document.getElementById('booking-form');
                if(modal && formSuccess && bookingForm) {
                    modal.classList.remove('hidden');
                    modal.classList.add('flex');
                    bookingForm.classList.add('hidden');
                    formSuccess.classList.remove('hidden');
                    setTimeout(() => {
                        modal.classList.remove('flex');
                        modal.classList.add('hidden');
                    }, 5000);
                }
            });
        </script>
    {% endif %}

    <!-- Booking Form Modal -->
    <div id="booking-modal" class="fixed inset-0 z-[100] bg-[#221022]/90 backdrop-blur-sm hidden items-center justify-center p-4">
        <div class="glass-card border border-[#f20df2]/40 shadow-[0_0_20px_rgba(242,13,242,0.15)] rounded-2xl w-full max-w-lg overflow-hidden shadow-2xl animate-fade-in-up">
            <div class="bg-[#221022] p-5 border-b border-[#f20df2]/40 shadow-[0_0_20px_rgba(242,13,242,0.15)] flex justify-between items-center">
                <h3 class="text-lg font-black text-white uppercase italic">Dane Firmy (B2B)</h3>
                <button id="btn-close-form" type="button" class="text-gray-400 hover:text-white">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
                </button>
            </div>

            <div id="form-success" class="hidden p-10 text-center">
                <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-green-500 mx-auto mb-4"><path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"/><path d="m9 12 2 2 4-4"/></svg>
                <h4 class="text-xl font-bold text-white mb-2">Zapytanie wysłane!</h4>
                <p class="text-gray-400 text-sm">Nasz account manager skontaktuje się z Tobą z gotową ofertą.</p>
            </div>
            
            {% form 'contact', id: 'booking-form', class: 'p-6 space-y-4' %}
                <input type="hidden" name="contact[Typ Zapytania]" value="EVENT B2B / FIRMA" />
                <textarea name="contact[body]" id="hidden-body" class="hidden"></textarea>
                <input type="hidden" id="form-hidden-details" value="" />
                
                <input required type="text" name="contact[name]" id="user-name" placeholder="Imię i nazwisko osoby kontaktowej" class="w-full glass-card border border-[#f20df2]/40 shadow-[0_0_20px_rgba(242,13,242,0.15)] rounded-lg px-4 py-2.5 text-white text-sm focus:border-[#f20df2] outline-none transition-colors" />
                <div class="grid grid-cols-2 gap-4">
                    <input required type="email" name="contact[email]" id="user-email" placeholder="Pracowniczy Email" class="w-full glass-card border border-[#f20df2]/40 shadow-[0_0_20px_rgba(242,13,242,0.15)] rounded-lg px-4 py-2.5 text-white text-sm focus:border-[#f20df2] outline-none transition-colors" />
                    <input required type="tel" name="contact[phone]" id="user-phone" placeholder="Telefon" class="w-full glass-card border border-[#f20df2]/40 shadow-[0_0_20px_rgba(242,13,242,0.15)] rounded-lg px-4 py-2.5 text-white text-sm focus:border-[#f20df2] outline-none transition-colors" />
                </div>
                <input required type="text" name="contact[Firma]" id="user-company" placeholder="Nazwa Firmy / NIP" class="w-full glass-card border border-[#f20df2]/40 shadow-[0_0_20px_rgba(242,13,242,0.15)] rounded-lg px-4 py-2.5 text-white text-sm focus:border-[#f20df2] outline-none transition-colors" />
                <textarea id="user-note" placeholder="Dodatkowe informacje (np. budżet, oczekiwania)..." rows="2" class="w-full glass-card border border-[#f20df2]/40 shadow-[0_0_20px_rgba(242,13,242,0.15)] rounded-lg px-4 py-2.5 text-white text-sm focus:border-[#f20df2] outline-none resize-none transition-colors"></textarea>

                <button type="submit" id="btn-submit-form" class="w-full py-3 bg-[#f20df2] text-white font-black uppercase text-xs tracking-widest rounded-lg flex items-center justify-center gap-2 hover:opacity-90 transition-opacity">
                    Wyślij zapytanie
                </button>
            {% endform %}
            
        </div>
    </div>

    <!-- Calc App JS -->
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            // Tymczasowy cennik B2B - flat 35 PLN w celach symulacji kalkulatora. Łatwo modyfikowalny wg zrobienia klienta.
            const Tiers = [
                { min: 0, max: 2000, price: 35 }
            ];

            const PRICES = {
                transmitter: 100,
                dj: 1500,
                video: 3000,
                fullservice: 2000
            };

            // State
            let state = {
                people: 50,
                channels: 3,
                startDate: new Date().toISOString().split('T')[0],
                endDate: new Date(Date.now() + 86400000).toISOString().split('T')[0],
                location: '',
                days: 1,
                extras: { video: false, fullservice: false }
            };

            // Elements
            const pplInput = document.getElementById('calc-ppl-input');
            const pplSlider = document.getElementById('calc-ppl-slider');
            const chSlider = document.getElementById('calc-ch-slider');
            const chVal = document.getElementById('calc-ch-val');
            const dateStart = document.getElementById('calc-date-start');
            const dateEnd = document.getElementById('calc-date-end');
            const locInput = document.getElementById('calc-location');
            
            const xtBtns = document.querySelectorAll('.calc-xt-btn');

            const outDays = document.getElementById('calc-days-out');
            const outBreakdown = document.getElementById('calc-breakdown');
            const outNet = document.getElementById('calc-total-out');
            const outGross = document.getElementById('calc-gross-out');
            const outPricePer = document.getElementById('calc-price-per');

            const modal = document.getElementById('booking-modal');
            const btnOpen = document.getElementById('btn-open-form');
            const btnClose = document.getElementById('btn-close-form');
            const form = document.getElementById('booking-form');
            const formSuccess = document.getElementById('form-success');
            const hiddenDetails = document.getElementById('form-hidden-details');

            // Init Dates
            dateStart.value = state.startDate;
            dateStart.min = state.startDate;
            dateEnd.value = state.endDate;
            dateEnd.min = state.startDate;

            // Logic
            function calculate() {
                // Tier pricing
                let pplTier = Tiers.find(t => state.people >= t.min && state.people <= t.max) || Tiers[0];
                let pricePer = pplTier.price;
                
                // Days
                let d1 = new Date(state.startDate);
                let d2 = new Date(state.endDate);
                let msDiff = d2.getTime() - d1.getTime();
                state.days = Math.max(1, Math.ceil(msDiff / (1000 * 3600 * 24)));
                let dayMult = state.days === 1 ? 1 : 1 + ((state.days - 1) * 0.5);

                let costPpl = Math.round(state.people * pricePer * dayMult);
                let costTx = Math.round(state.channels * PRICES.transmitter * dayMult);
                
                let costXt = 0;
                for (let k in state.extras) {
                    if (state.extras[k]) costXt += PRICES[k] || 0;
                }

                let total = costPpl + costTx + costXt;
                render(pricePer, costPpl, costTx, total);
            }

            function render(pricePer, costPpl, costTx, total) {
                outPricePer.textContent = pricePer;
                outDays.textContent = state.days;

                // Sync UI Sliders gradients
                pplSlider.style.background = `linear-gradient(to right, #f20df2 ${(state.people/1000)*100}%, #374151 ${(state.people/1000)*100}%)`;
                chSlider.style.background = `linear-gradient(to right, #f20df2 ${(state.channels/3)*100}%, #374151 ${(state.channels/3)*100}%)`;

                let bdHtml = `
                    <div class="flex justify-between">
                        <span class="text-gray-400">Budżet na uczestników (${state.people})</span>
                        <span class="text-white font-bold">${costPpl} zł</span>
                    </div>
                `;
                if(state.channels > 0) {
                    bdHtml += `
                    <div class="flex justify-between">
                        <span class="text-gray-400">Nadajniki (Kanały: ${state.channels})</span>
                        <span class="text-white font-bold">${costTx} zł</span>
                    </div>`;
                }
                
                for(let k in state.extras) {
                    if(state.extras[k]) {
                        bdHtml += `
                        <div class="flex justify-between text-[#f20df2]">
                            <span class="capitalize">${k === 'video' ? 'Nagranie Wideo/Reels' : 'Pełna Obsługa Wydarzenia'}</span>
                            <span class="font-bold">+${PRICES[k] || 2000} zł</span>
                        </div>`;
                    }
                }

                outBreakdown.innerHTML = bdHtml;

                outNet.textContent = `${total} zł`;
                outGross.textContent = `${Math.round(total * 1.23)} zł`;

                hiddenDetails.value = JSON.stringify({
                    people: state.people,
                    channels: state.channels,
                    startDate: state.startDate,
                    endDate: state.endDate,
                    location: state.location,
                    days: state.days,
                    extras: state.extras,
                    estimated_total: total
                });
            }

            // Listeners
            pplInput.addEventListener('input', (e) => {
                let v = parseInt(e.target.value) || 0;
                if(v > 2000) v = 2000;
                state.people = v;
                pplSlider.value = v > 1000 ? 1000 : v;
                calculate();
            });

            pplSlider.addEventListener('input', (e) => {
                let v = parseInt(e.target.value);
                state.people = v;
                pplInput.value = v;
                calculate();
            });

            chSlider.addEventListener('input', (e) => {
                let v = parseInt(e.target.value);
                if (v > 3) v = 3;
                state.channels = v;
                chVal.textContent = v;
                calculate();
            });

            dateStart.addEventListener('change', (e) => {
                state.startDate = e.target.value;
                dateEnd.min = state.startDate;
                if(new Date(state.endDate) < new Date(state.startDate)) {
                    state.endDate = state.startDate;
                    dateEnd.value = state.startDate;
                }
                calculate();
            });

            dateEnd.addEventListener('change', (e) => {
                state.endDate = e.target.value;
                calculate();
            });

            locInput.addEventListener('input', (e) => {
                state.location = e.target.value;
                calculate();
            });

            xtBtns.forEach(btn => btn.addEventListener('click', () => {
                let xtra = btn.getAttribute('data-xtra');
                let clr = btn.getAttribute('data-color');
                state.extras[xtra] = !state.extras[xtra];

                if(state.extras[xtra]) {
                    btn.classList.remove('bg-[#221022]/50', 'glass-card', 'border-[#f20df2]/40', 'shadow-[0_0_20px_rgba(242,13,242,0.15)]', 'text-gray-400');
                    btn.style.backgroundColor = `${clr}20`; // 20 hex alpha ≈ 12%
                    btn.style.borderColor = clr;
                    btn.style.color = 'white';
                } else {
                    btn.style.backgroundColor = '';
                    btn.style.borderColor = '';
                    btn.style.color = '';
                    btn.classList.add('bg-[#221022]/50', 'glass-card', 'border-[#f20df2]/40', 'shadow-[0_0_20px_rgba(242,13,242,0.15)]', 'text-gray-400');
                }
                calculate();
            }));

            // Modal
            btnOpen.addEventListener('click', () => {
                modal.classList.remove('hidden');
                modal.classList.add('flex');
            });
            btnClose.addEventListener('click', () => {
                modal.classList.remove('flex');
                modal.classList.add('hidden');
            });

            form.addEventListener('submit', (e) => {
                // Pozwalamy na natywne przeładowanie formularza Shopify (usuwamy e.preventDefault())
                const btnSubmit = document.getElementById('btn-submit-form');
                btnSubmit.textContent = 'Trwa wysyłanie...';

                // Build full message with rental details
                const details = JSON.parse(hiddenDetails.value || '{}');
                const formatDate = (d) => d ? new Date(d).toLocaleDateString('pl-PL') : '-';
                const noteVal    = document.getElementById('user-note').value;

                const msgBody = [
                    `=== ZAZNACZONE USŁUGI I WYCENA B2B ===`,
                    `Ilość osób: ${details.people || '-'} szt.`,
                    `Liczba DJ (Kanały): ${details.channels || '-'}`,
                    `Termin: ${formatDate(details.startDate)} – ${formatDate(details.endDate)} (${details.days || 1} dni)`,
                    `Lokalizacja: ${details.location || 'Nie podano'}`,
                    `Dodatki: ${Object.keys(details.extras || {}).filter(k => details.extras[k]).join(', ') || 'brak'}`,
                    `Szacunkowa wycena netto: ${details.estimated_total || 0} zł`,
                    ``,
                    `--- DODATKOWE INFORMACJE OD KLIENTA ---`,
                    `${noteVal || 'brak'}`
                ].join('\n');

                document.getElementById('hidden-body').value = msgBody;

                // ---> CONVERSION TRACKING (META & GOOGLE ADS) DLA B2B <---
                const leadValue = details.estimated_total || 0;
                
                window.dataLayer = window.dataLayer || [];
                window.dataLayer.push({
                    'event': 'generate_lead',
                    'value': leadValue,
                    'currency': 'PLN',
                    'lead_type': 'B2B_Quote'
                });

                if (typeof fbq !== 'undefined') {
                    fbq('track', 'Lead', {
                        value: leadValue,
                        currency: 'PLN',
                        content_name: 'Wycena Event Firmowy B2B'
                    });
                }

                if (typeof gtag !== 'undefined') {
                    gtag('event', 'generate_lead', {
                        value: leadValue,
                        currency: 'PLN',
                        event_category: 'B2B'
                    });
                }
            });

            // Initial calculation
            calculate();
        });
    </script>
</section>

{% schema %}
{
  "name": "Booking Calculator B2B",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Wycena"
    },
    {
      "type": "text",
      "id": "highlight",
      "label": "Highlight Text",
      "default": "Eventu B2B"
    }
  ],
  "presets": [
    {
      "name": "Booking Calculator B2B"
    }
  ]
}
{% endschema %}
