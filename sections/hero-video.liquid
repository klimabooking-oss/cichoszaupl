<section id="hero-video-section" style="position: relative; width: 100%; min-height: 100vh; display: flex; align-items: center; justify-content: center; overflow: hidden; background-color: #000;">
    <!-- === WARSTWA: Film / Zdjęcie (video only bez gradientów) === -->
        <div style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; z-index: 10;">
            <video
                id="hero-bg-parallax"
                class="will-change-transform"
                style="width: 100%; height: 100%; object-fit: cover; transform: scale(1.15);"
                autoplay loop muted playsinline preload="auto" fetchpriority="high"
            >
                <source src="{{ 'hero_parallax_video.mp4' | asset_url }}" type="video/mp4">
            </video>
        </div>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            // Strong Parallax scroll effect
            const bgEl = document.getElementById('hero-bg-parallax');
            
            if (bgEl) {
                window.addEventListener('scroll', () => {
                    const scrollY = window.scrollY;
                    if(scrollY < window.innerHeight) {
                        // Translate heavily by Y axis for parallax depth, scale lightly to prevent uncovering edges
                        bgEl.style.transform = `translateY(${scrollY * 0.4}px) scale(${1.15 + scrollY * 0.0002})`;
                    }
                }, { passive: true });
            }
        });
    </script>
</section>

{% schema %}
{
  "name": "Hero Video Only",
  "settings": [
    {
      "type": "header",
      "content": "Tlo Hero"
    },
    {
      "type": "video",
