<section class="bg-gradient-to-r from-[#f20df2] via-purple-600 to-indigo-900 text-white relative overflow-hidden" style="padding-top: 15px; padding-bottom: 15px;">
    <div class="absolute inset-0 bg-[url('https://grainy-gradients.vercel.app/noise.svg')] opacity-20 mix-blend-overlay"></div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col md:flex-row items-center justify-between relative z-10">
        <div class="mb-8 md:mb-0 text-center md:text-left" data-animate="fade-right">
            <h2 class="text-4xl font-black uppercase italic mb-2">{{ section.settings.title | default: 'Ready to Party?' }}</h2>
            <p class="text-purple-100 font-medium text-lg">{{ section.settings.subtitle | default: 'Złap nas na czacie, zanim termin ucieknie.' }}</p>
        </div>
        <div class="flex gap-4 flex-wrap justify-center md:justify-end mt-6 md:mt-0" data-animate="fade-left" data-animate-delay="200">
            <a href="/pages/wynajem-sluchawek-silent-disco" class="inline-flex items-center justify-center px-8 py-4 text-sm font-black tracking-widest text-[#0a050a] uppercase rounded-full hover:scale-105 transition-transform btn-glow" style="background:linear-gradient(to right,#f20df2,#ff5f1f,#ffd700); box-shadow:0 0 28px rgba(242,13,242,0.7), 0 0 60px rgba(242,13,242,0.3)">
                Zamów Słuchawki
            </a>
            
            {% if section.settings.whatsapp_url %}
            <a href="{{ section.settings.whatsapp_url }}" target="_blank" class="bg-white text-[#f20df2] px-8 py-3 rounded-full font-black uppercase text-sm shadow-xl hover:bg-gray-100 transition flex items-center transform hover:scale-105">
                {{ section.settings.btn1_text | default: 'WhatsApp' }}
            </a>
            {% endif %}
            
            <a href="{{ section.settings.primary_cta_link | default: '/pages/oferta' }}" class="inline-flex justify-center items-center gap-2 bg-white text-[#f20df2] font-black text-sm uppercase tracking-widest rounded-full px-8 py-4 hover:bg-[#f20df2] hover:text-white transition-all duration-300 w-full md:w-auto shadow-[0_0_20px_rgba(255,255,255,0.3)] hover:shadow-[0_0_30px_rgba(242,13,242,0.6)]">
                Zamów ofertę
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="group-hover:translate-x-1 transition-transform"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </a>
            
            <a href="/pages/wynajem-sluchawek-silent-disco" class="inline-flex justify-center items-center gap-2 font-black text-sm uppercase tracking-widest rounded-full px-8 py-4 hover:scale-[1.03] transition-all duration-300 w-full md:w-auto btn-glow text-[#0a050a]" style="background:linear-gradient(to right,#f20df2,#ff5f1f,#ffd700); box-shadow:0 0 28px rgba(242,13,242,0.7), 0 0 60px rgba(242,13,242,0.3)">
                Zamów Słuchawki
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </a>

            {% if section.settings.messenger_url %}
            <a href="{{ section.settings.messenger_url }}" target="_blank" class="bg-[#221022] text-white border border-white/20 px-8 py-3 rounded-full font-black uppercase text-sm shadow-xl hover:bg-black transition flex items-center transform hover:scale-105">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mr-2"><path d="m3 21 1.9-5.7a8.5 8.5 0 1 1 3.8 3.8z"/></svg>
                {{ section.settings.btn2_text | default: 'Messenger' }}
            </a>
            {% endif %}
        </div>
    </div>
</section>

{% schema %}
{
  "name": "CTA Banner",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Ready to Party?"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subheading",
      "default": "Złap nas na czacie, zanim termin ucieknie."
    },
    {
      "type": "text",
      "id": "btn1_text",
      "label": "Button 1 Text",
      "default": "WhatsApp"
    },
    {
      "type": "url",
      "id": "whatsapp_url",
      "label": "WhatsApp URL"
    },
    {
      "type": "text",
      "id": "btn2_text",
      "label": "Button 2 Text",
      "default": "Messenger"
    },
    {
      "type": "url",
      "id": "messenger_url",
      "label": "Messenger URL"
    }
  ],
  "presets": [
    {
      "name": "CTA Banner"
    }
  ]
}
{% endschema %}
