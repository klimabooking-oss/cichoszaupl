{% if metaobject.opis_sprzedazowy.value != blank or metaobject.tekst_seo.value != blank %}
<section class="bg-[#221022] relative py-20 pb-32" id="seo-content" data-animate="fade-up">
    <!-- Subtitle hook if exists -->
    {% if metaobject.krotki_hook.value != blank %}
    <div class="max-w-4xl mx-auto px-5 text-center mb-16">
        <span class="inline-block px-4 py-2 rounded-full border border-white/10 bg-white/5 text-gray-300 text-sm font-bold uppercase tracking-widest shadow-[0_0_20px_rgba(255,255,255,0.05)] mb-6">
            Lokalny Event
        </span>
        <h2 class="text-3xl md:text-5xl font-black text-white italic tracking-tighter leading-tight" style="text-wrap: balance;">
            {{ metaobject.krotki_hook.value }}
        </h2>
    </div>
    {% endif %}

    <div class="max-w-7xl mx-auto px-5">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 md:gap-12">
            <!-- Opis Sprzedażowy Box -->
            {% if metaobject.opis_sprzedazowy.value != blank %}
            <div class="p-8 md:p-12 rounded-[2.5rem] bg-white/[0.02] border border-[#f20df2]/30 shadow-[0_0_20px_rgba(242,13,242,0.1)] hover:border-[#f20df2]/60 hover:shadow-[0_0_40px_rgba(242,13,242,0.25)] transition-all duration-500 group relative overflow-hidden backdrop-blur-md h-full flex flex-col">
                 <!-- glow background effect -->
                 <div class="absolute -top-32 -right-32 w-80 h-80 bg-[#f20df2] rounded-full mix-blend-screen filter blur-[100px] opacity-10 group-hover:opacity-30 transition-opacity duration-700 pointer-events-none"></div>
                 
                 <h3 class="text-2xl md:text-3xl font-black text-white italic mb-8 uppercase tracking-wider flex items-center gap-4 relative z-10">
                    <span class="flex items-center justify-center w-12 h-12 rounded-full bg-[#f20df2]/20 border border-[#f20df2]/50 text-[#f20df2] shrink-0 group-hover:scale-110 transition-transform shadow-[0_0_20px_rgba(242,13,242,0.3)]">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
                    </span>
                    Dlaczego My?
                 </h3>
                 
                 <div class="relative z-10 prose prose-invert prose-lg max-w-none 
                            prose-p:text-gray-300 prose-p:leading-relaxed prose-p:mb-6
                            prose-strong:text-white prose-strong:font-black prose-strong:bg-white/5 prose-strong:px-1.5 prose-strong:py-0.5 prose-strong:rounded-md
                            prose-a:text-[#f20df2] hover:prose-a:text-[#ff5f1f] transition-colors
                            text-[1.1rem]">
                    {{ metaobject.opis_sprzedazowy | metafield_tag }}
                 </div>
            </div>
            {% endif %}

            <!-- Tekst SEO Box -->
            {% if metaobject.tekst_seo.value != blank %}
            <div class="p-8 md:p-12 rounded-[2.5rem] bg-white/[0.02] border border-[#ff5f1f]/30 shadow-[0_0_20px_rgba(255,95,31,0.1)] hover:border-[#ff5f1f]/60 hover:shadow-[0_0_40px_rgba(255,95,31,0.25)] transition-all duration-500 group relative overflow-hidden backdrop-blur-md h-full flex flex-col lg:mt-16">
                 <!-- glow background effect -->
                 <div class="absolute -bottom-32 -left-32 w-80 h-80 bg-[#ff5f1f] rounded-full mix-blend-screen filter blur-[100px] opacity-10 group-hover:opacity-30 transition-opacity duration-700 pointer-events-none"></div>
                 
                 <h3 class="text-2xl md:text-3xl font-black text-white italic mb-8 uppercase tracking-wider flex items-center gap-4 relative z-10">
                    <span class="flex items-center justify-center w-12 h-12 rounded-full bg-[#ff5f1f]/20 border border-[#ff5f1f]/50 text-[#ff5f1f] shrink-0 group-hover:scale-110 transition-transform shadow-[0_0_20px_rgba(255,95,31,0.3)]">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"></path><path d="M2 12h20"></path></svg>
                    </span>
                    Zasięg: {{ metaobject.nazwa.value }}
                 </h3>
                 
                 <div class="relative z-10 prose prose-invert prose-lg max-w-none 
                            prose-p:text-gray-300 prose-p:leading-relaxed prose-p:mb-6
                            prose-strong:text-white prose-strong:font-black prose-strong:bg-white/5 prose-strong:px-1.5 prose-strong:py-0.5 prose-strong:rounded-md
                            text-[1.1rem]">
                    {{ metaobject.tekst_seo | metafield_tag }}
                 </div>
            </div>
            {% endif %}
        </div>
    </div>
</section>
{% endif %}

{% schema %}
{
  "name": "SEO Metaobject Content",
  "presets": [
    {
      "name": "SEO Metaobject Content"
    }
  ]
}
{% endschema %}
